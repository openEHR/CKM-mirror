archetype (adl_version=1.4; uid=f5fa4407-13db-4262-8a0e-ad52b412f168)
	openEHR-EHR-EVALUATION.pregnancy_care_context.v0

concept
	[at0000]	-- Pregnancy care context
language
	original_language = <[ISO_639-1::en]>
description
	original_author = <
		["name"] = <"Heather Leslie">
		["organisation"] = <"Atomica Informatics">
		["email"] = <"heather.leslie@atomicainformatics.com">
		["date"] = <"2026-02-23">
	>
	details = <
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record the level of pregnancy-related precautions and care requirements applicable to an individual, as the basis for safe and appropriate clinical decision-making.">
			use = <"Use to record the level of pregnancy-related precautions and care requirements applicable to an individual, as the basis for safe and appropriate clinical decision-making. The context may be reassessed and updated over time as clinical circumstances change.

Each of the following mutually exclusive care states reflects a distinct circumstance in which a different level of pregnancy-related precautions is required:
- 'Baseline precautions' - the default state applying when none of the other defined states apply, requiring routine pregnancy-related precautions because an unrecognised pregnancy cannot be excluded.
- 'Planning pregnancy' - applies when the individual is actively planning or preparing for pregnancy, such as intentional discontinuation of contraception, preconception clinical optimisation, or commencement of fertility treatment, and elevated pregnancy-related precautions are required.
- 'Pregnant' - applies when pregnancy has been clinically confirmed and pregnancy-specific precautions apply.
- 'Post-pregnant' - applies during the recovery period following the end of a pregnancy, regardless of gestational age or outcome, during which 'Baseline precautions' apply in addition to any specific post-pregnancy care considerations.
- 'Not applicable' - applies when pregnancy is physiologically impossible and pregnancy-related precautions are not required in the individual's current circumstances.

Typical events that may trigger an update to the 'Pregnancy care context' include, but are not limited to:
- Documentation of menarche: transition from 'Not applicable' to 'Baseline precautions'.
- Decision to actively prepare for pregnancy, such as commencement of fertility treatment or intentional discontinuation of contraception: transition from 'Baseline precautions' to 'Planning pregnancy'.
- Confirmation of pregnancy: transition from 'Baseline precautions' or 'Planning pregnancy' to 'Pregnant'.
- Documented birth or pregnancy loss: transition from 'Pregnant' to 'Post-pregnant'.
- Completion of the post-pregnant recovery period: transition from 'Post-pregnant' to 'Baseline precautions'.
- Documentation of a formal diagnosis of menopause or a hysterectomy procedure: transition from 'Baseline precautions' to 'Not applicable'.

This archetype is intended to be used alongside the OBSERVATION.pregnancy_assertion archetype. Together they supersede the traditional representation of a single 'Pregnancy status' concept by separating pregnancy assertion from pregnancy care context. Pregnancy assertion records whether an individual is believed to be pregnant or not at a specific point in time, while Pregnancy care context records the broader and more persistent clinical context and associated pregnancy-related precautions relevant to clinical decision-making.">
			misuse = <"Not to record pregnancy confirmation or exclusion at a specific point in time. In particular, a clinician's determination that an individual is ‘not pregnant’ is only valid as a point-in-time clinical assertion and should not be used to represent an ongoing pregnancy care context. Use the OBSERVATION.pregnancy_assertion archetype for this purpose.

Not to be used to record a diagnosis of, suspicion of, or level of uncertainty about pregnancy. Use the EVALUATION.problem_diagnosis for this purpose.

Not to be used to record the summary information about a single pregnancy. Use the EVALUATION.pregnancy_summary for this purpose.">
			copyright = <"© openEHR Foundation">
		>
	>
	lifecycle_state = <"in_development">
	other_contributors = <>
	other_details = <
		["licence"] = <"This work is licensed under the Creative Commons Attribution-ShareAlike 4.0 International License. To view a copy of this license, visit http://creativecommons.org/licenses/by-sa/4.0/.">
		["custodian_organisation"] = <"openEHR Foundation">
		["original_namespace"] = <"org.openehr">
		["original_publisher"] = <"openEHR Foundation">
		["custodian_namespace"] = <"org.openehr">
		["MD5-CAM-1.0.1"] = <"185EC0BBCD312C8135DBAA9A774AC003">
		["build_uid"] = <"af1cdfa6-ac22-48f2-a0b7-576cce9de698">
		["revision"] = <"0.0.1-alpha">
	>

definition
	EVALUATION[at0000] matches {    -- Pregnancy care context
		data matches {
			ITEM_TREE[at0001] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0002] matches {    -- Care context
						value matches {
							DV_TEXT matches {*}
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0004,    -- Baseline precautions
									at0005,    -- Planning pregnancy
									at0006,    -- Pregnant
									at0007,    -- Post-pregnant
									at0016]    -- Not applicable
								}
							}
						}
					}
					ELEMENT[at0008] occurrences matches {0..1} matches {    -- Applicable from
						value matches {
							DV_DATE matches {*}
						}
					}
					ELEMENT[at0009] occurrences matches {0..1} matches {    -- Applicable until
						value matches {
							DV_DATE matches {*}
						}
					}
					ELEMENT[at0010] occurrences matches {0..1} matches {    -- Review date
						value matches {
							DV_DATE matches {*}
						}
					}
					ELEMENT[at0012] occurrences matches {0..1} matches {    -- Comment
						value matches {
							DV_TEXT matches {*}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0013] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0015] occurrences matches {0..1} matches {    -- Last updated
						value matches {
							DV_DATE_TIME matches {*}
						}
					}
					allow_archetype CLUSTER[at0014] occurrences matches {0..*} matches {    -- Extension
						include
							archetype_id/value matches {/.*/}
					}
				}
			}
		}
	}


ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Pregnancy care context">
					description = <"The current pregnancy care context of an individual, used to support safe and appropriate clinical decision-making.">
				>
				["at0001"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Care context">
					description = <"A category that identifies the level of pregnancy-related precautions applicable to an individual.">
					comment = <"The context may be assigned by a clinician or automatically updated by a clinical system when a qualifying clinical event is documented. Examples where 'Not applicable' is appropriate include premenarchal individuals, postmenopausal individuals, and those who do not have a uterus.">
				>
				["at0004"] = <
					text = <"Baseline precautions">
					description = <"The default state, which applies to individuals for whom pregnancy is physiologically possible but none of the other defined states apply, requiring routine pregnancy-related precautions because an unrecognised pregnancy cannot be excluded.">
				>
				["at0005"] = <
					text = <"Planning pregnancy">
					description = <"Applies when the individual is actively planning or preparing for pregnancy, and elevated pregnancy-related precautions are required beyond those of the 'Baseline precautions' state to support safe conception and early pregnancy.">
				>
				["at0006"] = <
					text = <"Pregnant">
					description = <"Applies when pregnancy has been clinically confirmed and pregnancy-specific precautions apply.">
				>
				["at0007"] = <
					text = <"Post-pregnant">
					description = <"Applies during the recovery period following the end of a pregnancy, regardless of gestational age or outcome, during which 'Baseline precautions' apply in addition to any specific post-pregnancy care considerations.">
				>
				["at0008"] = <
					text = <"Applicable from">
					description = <"The date from when the current care context applies.">
					comment = <"For example: the date of delivery when initiating a 'Post-pregnant' context; the date of a menopause diagnosis for a 'Not applicable' context; and the date of menarche when recording the 'Baseline precautions' context.">
				>
				["at0009"] = <
					text = <"Applicable until">
					description = <"The date until which the current care context applies.">
					comment = <"This date represents the anticipated end of the current context and does not imply that the state has been reviewed or changed. For example: 28 days after birth for a 'Post-pregnant' context.">
				>
				["at0010"] = <
					text = <"Review date">
					description = <"The date when the care context should be reviewed and reassessed.">
					comment = <"Review of the current 'Care context' may confirm that the current context remains applicable or result in a change to a different context. For example: a scheduled follow-up after commencing fertility treatment for a 'Planning pregnancy' context; or a postnatal review date for a 'Post-pregnant' context.">
				>
				["at0012"] = <
					text = <"Comment">
					description = <"Additional narrative about the pregnancy care context not captured in other fields.">
				>
				["at0013"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0014"] = <
					text = <"Extension">
					description = <"Additional information required to extend the model with local content or to align with other reference models or formalisms.">
					comment = <"For example: local information requirements; or additional metadata to align with FHIR.">
				>
				["at0015"] = <
					text = <"Last updated">
					description = <"The date when this pregnancy care context was last updated.">
				>
				["at0016"] = <
					text = <"Not applicable">
					description = <"Applies when pregnancy is physiologically impossible and pregnancy-related precautions are not required in the individual's current circumstances.">
				>
			>
		>
	>
