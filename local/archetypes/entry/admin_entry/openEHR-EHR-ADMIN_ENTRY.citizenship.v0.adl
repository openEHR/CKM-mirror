archetype (adl_version=1.4; uid=5f5a2167-2595-4739-b8c0-ffd32fa35990)
	openEHR-EHR-ADMIN_ENTRY.citizenship.v0

concept
	[at0000]	-- Citizenship
language
	original_language = <[ISO_639-1::en]>
	translations = <
		["nb"] = <
			language = <[ISO_639-1::nb]>
			author = <
			>
		>
	>
description
	original_author = <
		["name"] = <"Karsten Ovretveit">
		["organisation"] = <"Helse Vest IKT">
		["email"] = <"karsten.ovretveit@helse-vest-ikt.no">
		["date"] = <"2026-02-04">
	>
	details = <
		["nb"] = <
			language = <[ISO_639-1::nb]>
			purpose = <"For å registrere personens juridiske statsborgerskapsstatus ved å identifisere staten(e) personen er statsborger i. Arketypen kan også brukes for å dokumentere at personen er statsløs eller at personens statsborgerskap ikke kan fastslås.">
			use = <"Brukes for å registrere personens juridiske statsborgerskapsstatus ved å identifisere staten(e) personen er statsborger i. Arketypen kan også brukes for å dokumentere at personen er statsløs eller at personens statsborgerskap ikke kan fastslås.">
			keywords = <"statsborgerskap, statsborger, nasjonalitet, nasjon, statsløs, juridisk status, land, stat", ...>
			misuse = <"Brukes ikke for å registrere fødeland, etnisitet, kulturell identitet, immigrasjonsstatus, oppholdstillatelse eller språk. Dette kan registreres i andre arketyper, for eksempel EVALUATION.birth_details, EVALUATION.ethnicity og CLUSTER.language.">
			copyright = <"© openEHR Foundation">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record the individual’s legal citizenship status, identify the state(s) of which the individual is a citizen, or document that the individual is stateless or that their citizenship cannot be determined.">
			use = <"Use to record the individual’s legal citizenship status, identify the state(s) of which the individual is a citizen, or document that the individual is stateless or that their citizenship cannot be determined. Stateless indicates absence of any current citizenship. Historical citizenships may still be documented. Citizenship can be included in data submissions to national health registries and public health reporting systems, where citizenship status may affect cohort definitions, statistics, billing, legal rights, or reporting obligations.">
			keywords = <"citizen, nationality, nation, stateless, national, country, state", ...>
			misuse = <"Not to be used to record country of birth, this can be recorded in EVALUATION.birth_details.

Not to be used to record self-identified cultural or national identity, this can be recorded in EVALUATION.ethnicity.

Not to be used to record language, this can be recorded in CLUSTER.language.

Not to be used to record immigration status, residence permits, long-term visas, or language. The need for specific archetypes for these purposes is acknowledged but had not yet been developed at the time of the publication of this archetype.">
		>
	>
	lifecycle_state = <"in_development">
	other_contributors = <"Vebjørn Arntzen, Oslo University Hospital, Norway (openEHR Editor)", "Silje Ljosland Bakke, Helse Vest IKT AS, Norway (openEHR Editor)", "SB Bhattacharyya, Bhattacharyyas Clinical Records Research & Informatics LLP, India", "Hanne Marte Bårholm, Helse Vest IKT, Norway (openEHR Editor)", "Grete Hovde Bøe, Sykehuspartner HF, Norway (openEHR Editor)", "Gunn Elin Blakkisrud, DIPS ASA, Norway", "Kåre Flø, DIPS ASA, Norway", "Aleksander Furnes, Helse Nord IKT, Norway (openEHR Editor)", "Ciprian Gerstenberger, Helse Nord IKT, Norway (openEHR Editor)", "Heather Grain, Llewelyn Grain Informatics, Australia", "Marte Vassli Gullesen, Helse Nord IKT, Norway (openEHR Editor)", "Atle Hansen, Universitetssykehuset Nord-Norge, Norway", "Elin Kristiansen, Sykehuspartner HF, Norway (openEHR Editor)", "Kanika Kuwelker, Helse Vest IKT, Norway (openEHR Editor)", "Eli Larsen, UNN, Norway (openEHR Editor)", "Liv Laugen, ​Oslo University Hospital, Norway, Norway (openEHR Editor)", "Heather Leslie, Atomica Informatics, Australia (openEHR Editor)", "Ruth Lochan, Akademiska Sjukhuset Uppsala, Sweden", "Ian McNicoll, freshEHR Clinical Informatics, United Kingdom", "Martin Milde, Helse Vest IKT, Norway (openEHR Editor)", "Olha Nikolaieva, University Hospital Basel, Switzerland", "Mikael Nyström, Cambio Healthcare Systems AB, Sweden", "Ruben Rognmo, Helse Nord IKT, Norway", "Terje Sagmyr, Helse Vest IKT, Norway (openEHR Editor)", "Lena Schell-Majoor, University of Oldenburg, Germany", "Nyree Taylor, CSIRO, Australia", "John Tore Valand, Helse Vest IKT, Norway (openEHR Editor)", "Lin Zhang, Freelancer, China", "Karsten Øvretveit, Helse Vest IKT, Norway (openEHR Editor)">
