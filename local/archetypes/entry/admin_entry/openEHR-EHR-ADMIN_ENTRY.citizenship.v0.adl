definition
	ADMIN_ENTRY[at0000] matches {    -- Citizenship
		data matches {
			ITEM_TREE[at0001] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0017] occurrences matches {0..1} matches {    -- Status
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0018,    -- Citizen
									at0019,    -- Stateless
									at0020]    -- Unknown
								}
							}
						}
					}
					CLUSTER[at0016] occurrences matches {0..*} matches {    -- Specific citizenship
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0003] matches {    -- Country
								value matches {
									DV_TEXT matches {*}
								}
							}
							ELEMENT[at0006] occurrences matches {0..1} matches {    -- Current?
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0008,    -- Current
											at0009]    -- Previous
										}
									}
								}
							}
							ELEMENT[at0007] occurrences matches {0..1} matches {    -- Information source
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0010,    -- Self-reported
											at0011,    -- Document-based
											at0012]    -- Registry-based
										}
									}
									DV_TEXT matches {*}
								}
							}
							allow_archetype CLUSTER[at0028] occurrences matches {0..*} matches {    -- Information source details
								include
									archetype_id/value matches {/openEHR-EHR-CLUSTER\.media_file(-[a-zA-Z0-9_]+)*\.v1|openEHR-EHR-CLUSTER\.knowledge_base_reference(-[a-zA-Z0-9_]+)*\.v1/}
							}
							ELEMENT[at0004] occurrences matches {0..1} matches {    -- Valid from
								value matches {
									DV_DATE matches {*}
								}
							}
							ELEMENT[at0005] occurrences matches {0..1} matches {    -- Valid to
								value matches {
									DV_DATE matches {*}
								}
							}
							ELEMENT[at0014] occurrences matches {0..1} matches {    -- Comment
								value matches {
									DV_TEXT matches {*}
								}
							}
						}
					}
					allow_archetype CLUSTER[at0022] occurrences matches {0..*} matches {    -- Additional details
						include
							archetype_id/value matches {/.*/}
					}
					ELEMENT[at0023] occurrences matches {0..1} matches {    -- Last updated
						value matches {
							DV_DATE_TIME matches {*}
						}
					}
					ELEMENT[at0029] occurrences matches {0..1} matches {    -- Overall comment
						value matches {
							DV_TEXT matches {*}
						}
					}
				}
			}
		}
	}


ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Citizenship">
					description = <"A record of the individual’s legal citizenship status, identifying the state or states of which the individual is a citizen.  ">
					comment = <"While \"citizenship\" and \"nationality\" can differ in some legal contexts, they are often used interchangeably in practice. In this archetype, the term \"citizenship\" is used.">
				>
				["at0001"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0003"] = <
					text = <"Country">
					description = <"The country of the citizenship.">
					comment = <"Coding with an external terminology is preferred, where possible, for example ISO 3166-1 alpha-2.">
				>
				["at0004"] = <
					text = <"Valid from">
					description = <"When the citizenship started.">
				>
				["at0005"] = <
					text = <"Valid to">
					description = <"When the citizenship ended.">
				>
				["at0006"] = <
					text = <"Current?">
					description = <"The status of the citizenship.">
				>
				["at0007"] = <
					text = <"Information source">
					description = <"The source of information of the citizenship.">
					comment = <"Use free text to describe other sources of information of the citizenship.">
				>
				["at0008"] = <
					text = <"Current">
					description = <"Current citizenship.">
				>
				["at0009"] = <
					text = <"Previous">
					description = <"Previous citizenship.">
				>
				["at0010"] = <
					text = <"Self-reported">
					description = <"">
				>
				["at0011"] = <
					text = <"Document-based">
					description = <"For example passport or other official documents.">
				>
				["at0012"] = <
					text = <"Registry-based">
					description = <"For example a national population register.">
				>
				["at0014"] = <
					text = <"Comment">
					description = <"Additional narrative about the specific citizenship, not captured in other fields.">
				>
				["at0016"] = <
					text = <"Specific citizenship">
					description = <"Details about a specific current or former citizenship held by the individual.">
					comment = <"Multiple citizenship can be recorded by repeating this cluster.">
				>
				["at0017"] = <
					text = <"Status">
					description = <"The status of the individual's citizenship.">
				>
				["at0018"] = <
					text = <"Citizen">
					description = <"The individual is legally recognized as a citizen by at least one state.">
				>
				["at0019"] = <
					text = <"Stateless">
					description = <"The individual is not legally recognized as a citizen by any state.">
				>
				["at0020"] = <
					text = <"Unknown">
					description = <"The individual’s citizenship is unknown.">
				>
				["at0022"] = <
					text = <"Additional details">
					description = <"Additional structured details about citizenship status.">
				>
				["at0023"] = <
					text = <"Last updated">
					description = <"The date the citizenship details were last updated.">
				>
				["at0028"] = <
					text = <"Information source details">
					description = <"Additional structured details about the source of the specific citizenship.">
				>
				["at0029"] = <
					text = <"Overall comment">
					description = <"Additional narrative about citizenship, not captured in other fields.">
				>
			>
		>
		["nb"] = <
			items = <
				["at0000"] = <
					text = <"Statsborgerskap">
					description = <"En registrering av personens juridiske statsborgerskap, som identifiserer hvilken stat eller hvilke stater personen er statsborger i. ">
				>
				["at0001"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0003"] = <
					text = <"Land">
					description = <"Landet for statsborgerskap.">
					comment = <"Koding med en ekstern terminologi bør brukes der det er mulig, for eksempel ISO 3166-1 alpha-2.">
				>
				["at0004"] = <
					text = <"Gyldig fra">
					description = <"Starten på statsborgerskap.">
				>
				["at0005"] = <
					text = <"Gyldig til">
					description = <"Slutten på statsborgerskap.">
				>
				["at0006"] = <
					text = <"Nåværende?">
					description = <"Tidsstatus for registrert statsborgerskap.">
				>
				["at0007"] = <
					text = <"Informasjonskilde">
					description = <"Opplysningskilde for statsborgerskap.">
					comment = <"Bruk fritekst til å beskrive andre opplysningskilder for statsborgerskap.">
				>
				["at0008"] = <
					text = <"Tidligere">
					description = <"Tidligere statsborger.">
				>
				["at0009"] = <
					text = <"Nåværende">
					description = <"Nåværende statsborger.">
				>
				["at0010"] = <
					text = <"Selvrapportert">
					description = <"">
				>
				["at0011"] = <
					text = <"Dokumentbasert">
					description = <"">
				>
				["at0012"] = <
					text = <"Registerbasert">
					description = <"">
				>
				["at0014"] = <
					text = <"Kommentar">
					description = <"Ytterligere fritekst om det spesifikke statsborgerskapet som ikke er registrert i andre felt.">
				>
				["at0016"] = <
					text = <"Spesifikt statsborgerskap">
					description = <"Detaljer om nåværende og/eller tidligere statsborgerskap som personen har hatt.">
				>
				["at0017"] = <
					text = <"Status">
					description = <"Juridisk statsborgerskapsstatus.">
				>
				["at0018"] = <
					text = <"Statsborger">
					description = <"Personen er juridisk anerkjent som statsborger av minst én stat.">
				>
				["at0019"] = <
					text = <"Statsløs">
					description = <"Personen er ikke anerkjent som statsborger av noen stat.">
				>
				["at0020"] = <
					text = <"Ukjent">
					description = <"Personens statsborgerskap er ukjent.">
				>
				["at0022"] = <
					text = <"Ytterligere detaljer">
					description = <"Ytterligere detaljer om statsborgerskapsstatus.">
				>
				["at0023"] = <
					text = <"Sist oppdatert">
					description = <"Datoen statsborgerskap sist ble oppdatert.">
				>
				["at0028"] = <
					text = <"Detaljer om Informasjonskilde">
					description = <"Ytterligere detaljer om kilde til det spesifikke statsborgerskapet.">
				>
				["at0029"] = <
					text = <"Generell kommentar">
					description = <"Ytterligere fritekst om statsborgerskap som ikke er registrert i andre felt.">
				>
			>
		>
	>
