archetype (adl_version=1.4; uid=5f5a2167-2595-4739-b8c0-ffd32fa35990)
	openEHR-EHR-ADMIN_ENTRY.citizenship.v0

concept
	[at0000]	-- Citizenship
language
	original_language = <[ISO_639-1::en]>
	translations = <
		["nb"] = <
			language = <[ISO_639-1::nb]>
			author = <
			>
		>
	>
description
	original_author = <
		["name"] = <"Karsten Ovretveit">
		["organisation"] = <"Helse Vest IKT">
		["email"] = <"karsten.ovretveit@helse-vest-ikt.no">
		["date"] = <"2026-02-04">
	>
	details = <
		["nb"] = <
			language = <[ISO_639-1::nb]>
			purpose = <"For å registrere personens juridiske statsborgerskapsstatus, ved å identifisere staten eller statene personen er statsborger i, eller ved å dokumentere at personen er statsløs eller at personens statsborgerskap ikke kan fastslås.">
			use = <"Brukes for å registrere personens juridiske statsborgerskapsstatus, ved å identifisere staten eller statene personen er statsborger i, eller ved å dokumentere at personen er statsløs eller at personens statsborgerskap ikke kan fastslås.">
			keywords = <"statsborgerskap, statsborger, nasjonalitet, nasjon, statsløs, juridisk status, land, stat", ...>
			misuse = <"Brukes ikke for å registrere fødeland, etnisitet, kulturell nasjonalitet, immigrasjonsstatus, oppholdstillatelse eller språk. Dette kan registreres i andre arketyper, som for eksempel EVALUATION.birth_details, EVALUATION.ethnicity og CLUSTER.language.">
			copyright = <"© openEHR Foundation">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record the individual’s legal citizenship status, identifying the state or states of which the individual is a citizen, or documenting that the individual is stateless or that their citizenship cannot be determined.">
			use = <"Use to record the individual’s legal citizenship status, identifying the state or states of which the individual is a citizen, or documenting that the individual is stateless or that their citizenship cannot be determined.">
			keywords = <"citizenship, citizen, nationality, nation, stateless, national, legal status, country, state", ...>
			misuse = <"Not to be used to record country of birth, ethnicity, cultural nationality, immigration status, residence permits, or language. This can be recorded in other archetypes, such as EVALUATION.birth_details, EVALUATION.ethnicity, and CLUSTER.language.">
		>
	>
	lifecycle_state = <"in_development">
	other_contributors = <>
	other_details = <
		["licence"] = <"This work is licensed under the Creative Commons Attribution-ShareAlike 4.0 International License. To view a copy of this license, visit http://creativecommons.org/licenses/by-sa/4.0/.">
		["custodian_organisation"] = <"openEHR Foundation">
		["original_namespace"] = <"org.openehr">
		["original_publisher"] = <"openEHR Foundation">
		["custodian_namespace"] = <"org.openehr">
		["MD5-CAM-1.0.1"] = <"25C9A8F8078780527997DB4BE76370CF">
		["build_uid"] = <"84b219c5-2833-46a4-8cd8-99ca6fdd06ae">
		["revision"] = <"0.0.1-alpha">
	>

definition
	ADMIN_ENTRY[at0000] matches {    -- Citizenship
		data matches {
			ITEM_TREE[at0001] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					ELEMENT[at0017] occurrences matches {0..1} matches {    -- Citizenship status
						value matches {
							DV_CODED_TEXT matches {
								defining_code matches {
									[local::
									at0018,    -- Citizen
									at0019,    -- Stateless
									at0020]    -- Unknown
								}
							}
						}
					}
					CLUSTER[at0016] occurrences matches {0..*} matches {    -- Citizenship details
						items cardinality matches {1..*; unordered} matches {
							ELEMENT[at0003] matches {    -- Country
								value matches {
									DV_TEXT matches {*}
								}
							}
							ELEMENT[at0006] occurrences matches {0..1} matches {    -- Status
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0008,    -- Previous
											at0009]    -- Current
										}
									}
								}
							}
							ELEMENT[at0007] occurrences matches {0..1} matches {    -- Source
								value matches {
									DV_CODED_TEXT matches {
										defining_code matches {
											[local::
											at0010,    -- Self-reported
											at0011,    -- Document-based
											at0012,    -- Registry-based
											at0013]    -- Other
										}
									}
								}
							}
							ELEMENT[at0004] occurrences matches {0..1} matches {    -- Valid from
								value matches {
									DV_DATE matches {*}
								}
							}
							ELEMENT[at0005] occurrences matches {0..1} matches {    -- Valid to
								value matches {
									DV_DATE matches {*}
								}
							}
							ELEMENT[at0014] occurrences matches {0..1} matches {    -- Comment
								value matches {
									DV_TEXT matches {*}
								}
							}
						}
					}
				}
			}
		}
	}


ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Citizenship">
					description = <"A record of the individual’s legal citizenship status, identifying the state or states of which the individual is a citizen. Stateless indicates absence of any current citizenship. Historical citizenships may still be documented.">
				>
				["at0001"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0003"] = <
					text = <"Country">
					description = <"The country of the citizenship.">
					comment = <"Coding with an external terminology is preferred, where possible, for example ISO 3166-1 alpha-2.">
				>
				["at0004"] = <
					text = <"Valid from">
					description = <"When the citizenship started.">
				>
				["at0005"] = <
					text = <"Valid to">
					description = <"When the citizenship ended.">
				>
				["at0006"] = <
					text = <"Status">
					description = <"The status of the citizenship.">
				>
				["at0007"] = <
					text = <"Source">
					description = <"The source of information of the citizenship.">
				>
				["at0008"] = <
					text = <"Previous">
					description = <"Previous citizenship.">
				>
				["at0009"] = <
					text = <"Current">
					description = <"Current citizenship.">
				>
				["at0010"] = <
					text = <"Self-reported">
					description = <"">
				>
				["at0011"] = <
					text = <"Document-based">
					description = <"">
				>
				["at0012"] = <
					text = <"Registry-based">
					description = <"">
				>
				["at0013"] = <
					text = <"Other">
					description = <"">
				>
				["at0014"] = <
					text = <"Comment">
					description = <"">
				>
				["at0016"] = <
					text = <"Citizenship details">
					description = <"Details of each active and inactive citizenship held by the individual.">
				>
				["at0017"] = <
					text = <"Citizenship status">
					description = <"The status of the individual's citizenship.">
				>
				["at0018"] = <
					text = <"Citizen">
					description = <"The individual is legally recognized as a citizen by at least one state.">
				>
				["at0019"] = <
					text = <"Stateless">
					description = <"The individual is not recognised as a national by any state under the operation of its laws.">
				>
				["at0020"] = <
					text = <"Unknown">
					description = <"The individual’s citizenship is unknown.">
				>
			>
		>
		["nb"] = <
			items = <
				["at0000"] = <
					text = <"Statsborgerskap">
					description = <"En registrering av personens juridiske statsborgerskap, som identifiserer hvilken stat eller hvilke stater personen er statsborger i. Statsløshet innebærer at personen ikke har noe nåværende statsborgerskap. Tidligere statsborgerskap kan fortsatt dokumenteres.">
				>
				["at0001"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0003"] = <
					text = <"Land">
					description = <"*The country of the citizenship. (en)">
					comment = <"Koding med en ekstern terminologi bør brukes der det er mulig, for eksempel ISO 3166-1 alpha-2.">
				>
				["at0004"] = <
					text = <"Gyldig fra">
					description = <"Startdato for statsborgerskap.">
				>
				["at0005"] = <
					text = <"Gyldig til">
					description = <"Sluttdato for statsborgerskap.">
				>
				["at0006"] = <
					text = <"Status">
					description = <"Status for statsborgerskap.">
				>
				["at0007"] = <
					text = <"Kilde">
					description = <"Opplysningskilde for statsborgerskap.">
				>
				["at0008"] = <
					text = <"Tidligere">
					description = <"*Previous citizenship. (en)">
				>
				["at0009"] = <
					text = <"Nåværende">
					description = <"*Current citizenship. (en)">
				>
				["at0010"] = <
					text = <"Selvrapportert">
					description = <"">
				>
				["at0011"] = <
					text = <"Dokumentbasert">
					description = <"">
				>
				["at0012"] = <
					text = <"Registerbasert">
					description = <"">
				>
				["at0013"] = <
					text = <"Annet">
					description = <"">
				>
				["at0014"] = <
					text = <"Kommentar">
					description = <"">
				>
				["at0016"] = <
					text = <"Detaljer om statsborgerskap">
					description = <"Detaljer om hvert aktivt og inaktivt statsborgerskap som personen har hatt.">
				>
				["at0017"] = <
					text = <"Statsborgerskapsstatus">
					description = <"Status for personens statsborgerskap.">
				>
				["at0018"] = <
					text = <"Statsborger">
					description = <"Personen er juridisk anerkjent som statsborger av minst én stat.">
				>
				["at0019"] = <
					text = <"Statsløs">
					description = <"Personen er ikke anerkjent som statsborger av noen stat etter dens lovgivning.">
				>
				["at0020"] = <
					text = <"Ukjent">
					description = <"Personens statsborgerskap er ukjent.">
				>
			>
		>
	>
