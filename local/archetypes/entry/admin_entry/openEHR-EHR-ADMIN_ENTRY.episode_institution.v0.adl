description
	original_author = <
		["name"] = <"Heather Leslie">
		["organisation"] = <"Atomica Informatics">
		["email"] = <"heather.leslie@atomicainformatics.com">
		["date"] = <"2020-03-14">
	>
	details = <
		["de"] = <
			language = <[ISO_639-1::de]>
			purpose = <"Zur Erfassung administrativer Details über den Zeitraum einer Patientenversorgung, zwischen einer formellen oder statistischen Aufnahme und einer formellen oder statistischen Entlassung, welche nur durch eine Versorgungsform der Gesundheitseinrichtung charakterisiert ist.
">
			use = <"Wird verwendet zur Erfassung administrativer Details über den Zeitraum einer Patientenversorgung, zwischen einer formellen oder statistischen Aufnahme und einer formellen oder statistischen Entlassung, welche nur durch eine Versorgungsform der Gesundheitseinrichtung charakterisiert ist.">
			keywords = <"Institutionsaufenthalt, Aufenthalt, Krankenhausaufenthalt, Institutioneller Aufenthalt", ...>
			misuse = <"">
		>
		["nb"] = <
			language = <[ISO_639-1::nb]>
			purpose = <"For å registrere administrative detaljer om en periode med pasientbehandling, som starter når en helseinstitusjon eller tjeneste tar medisinsk og/eller juridisk ansvar for pasienten, og som avsluttes ved en formell eller statistisk utskriving. Denne perioden er definert av kun én type helsehjelp fra helseinstitusjonen/tjenesten.">
			use = <"Brukes for å registrere administrative detaljer om en periode med pasientbehandling, som starter når en helseinstitusjon eller tjeneste tar medisinsk og/eller juridisk ansvar for pasienten, og som avsluttes ved en formell eller statistisk utskriving. Denne perioden er definert av kun én type helsehjelp fra helseinstitusjonen/tjenesten.

Innen konteksten av denne arketypen tolkes \"utskrivelse\" bredt, og inkluderer situasjoner som avhengig av lokalt regelverk ikke vanligvis regnes som utskrivelser, for eksempel dødsfall i institusjonen, eller nyfødte som sendes hjem.">
			keywords = <"Innleggelse, utskrivelse, besøk, opphold", ...>
			misuse = <"Brukes ikke for å registrere enkeltmøter med en pasient der institusjonen ikke tar formelt medisinsk og/eller juridisk ansvar for pasienten, som for eksempel ved polikliniske konsultasjoner. Ved tidspunktet da denne arketypen ble opprettet var det ikke avklart hvilken arketype som bør benyttes for dette formålet.

Brukes ikke for å registrere en planlagt innleggelse til en helseinstitusjon eller tjenestene. Ved tidspunktet da denne arketypen ble opprettet var det ikke avklart hvilken arketype som bør benyttes for dette formålet.
">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record administrative details about a period of admitted patient care between a formal or statistical admission and a discharge, characterised by only one type of care from a healthcare institution or service.">
			use = <"To record administrative details about a period of admitted patient care, beginning when a healthcare institution or service assumes medical and/or legal responsibility for the patient, and ending at formal or statistical discharge. This period is defined by a single type of care provided by the institution/service.

Within the context of this archetype, discharge is interpreted broadly, and includes situations that, depending on local rules, may not be considered a discharge, such as death in the institution, or newborns released from care.">
			keywords = <"Admission, discharge, separation, visit, stay, hospitalization", ...>
			misuse = <"Not to be used for a single meeting with a patient where the institution does not take formal medical and/or legal responsibility of the patient, such as outpatient visits. At the time of authoring it is not yet determined which archetype should be used for this purpose.

Not to be used for a planned admission to a healthcare institution or service. At the time of authoring it is not yet determined which archetype should be used for this purpose.">
			copyright = <"© openEHR Foundation">
		>
		["it"] = <
			language = <[ISO_639-1::it]>
			purpose = <"Registrare i dettagli amministrativi di un periodo di cura del paziente ricoverato tra un ricovero formale o statistico e una separazione formale o statistica, caratterizzata da un solo tipo di cura da un'istituzione sanitaria.">
			use = <"Utilizzare per registrare i dettagli amministrativi relativi a un periodo di cura del paziente ricoverato tra un ricovero formale o statistico e una separazione formale o statistica, caratterizzata da un solo tipo di cura di un'istituzione sanitaria.">
			misuse = <"">
		>
		["ca"] = <
			language = <[ISO_639-1::ca]>
			purpose = <"Registrar dades administratives sobre un període d’atenció als pacients ingressats entre un ingrés formal o estadístic i una alta formal o estadística, caracteritzats només per un tipus d’atenció d’un centre sanitari.">
			use = <"Utilitzar per a registrar dades administratives sobre un període d’atenció als pacients ingressats entre un ingrés formal o estadístic i una alta formal o estadística, caracteritzats només per un tipus d’atenció d’un centre sanitari.">
			misuse = <"">
		>
		["es"] = <
			language = <[ISO_639-1::es]>
			purpose = <"Registrar datos administrativos sobre un periodo de atención a los pacientes ingresados entre un ingreso formal o estadístico y una alta formal o estadística, caracterizados únicamente por un tipo de atención en una institución sanitaria.">
			use = <"Utilizar para registrar datos administrativos sobre un periodo de atención a los pacientes ingresados entre un ingreso formal o estadístico, y una alta formal o estadística, caracterizado únicamente por un tipo de atención en una institución sanitaria.">
			misuse = <"">
		>
	>
	lifecycle_state = <"in_development">
