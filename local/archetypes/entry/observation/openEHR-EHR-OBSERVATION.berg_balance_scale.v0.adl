archetype (adl_version=1.4; uid=ccea9207-e7e3-4ea3-aacb-4ab2cffdc469)
	openEHR-EHR-OBSERVATION.berg_balance_scale.v0

concept
	[at0000]	-- Berg Balance Scale (BBS)
language
	original_language = <[ISO_639-1::en]>
	translations = <
		["nb"] = <
			language = <[ISO_639-1::nb]>
			author = <
			>
		>
	>
description
	original_author = <
		["name"] = <"Karsten Øvretveit">
		["organisation"] = <"Helse Vest IKT">
		["email"] = <"karsten.ovretveit@helse-vest-ikt.no">
		["date"] = <"2026-05-28">
	>
	details = <
		["nb"] = <
			language = <[ISO_639-1::nb]>
			purpose = <"For å registrere resultatene for hver av de 14 deloppgavene og deres samlede sum for Bergs balanseskala.">
			use = <"Brukes for å registrere resultatene for hver av de 14 deloppgavene og deres samlede sum for Bergs balanseskala.">
			keywords = <"balanse, postural kontroll, fallrisiko, funksjonell balanse, mobilitet, balansevurdering", ...>
			misuse = <"Skal ikke brukes for å registrere vurdering av balanse ved hjelp av andre instrumenter eller skalaer. Bruk en spesifikk arketype for dette formålet.">
			copyright = <"© openEHR Norway, openEHR Foundation">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record the results for each of the 14 component tasks and their total sum for the Berg Balance Scale.">
			use = <"Use to record the results for each of the 14 component tasks and their total sum for the Berg Balance Scale.">
			keywords = <"balance, postural control, fall risk, functional balance, mobility, balance assessment", ...>
			misuse = <"Not to be used to record assessment of balance using other instruments or scales. Use a specific archetype for this purpose.">
			copyright = <"© openEHR Norway, openEHR Foundation">
		>
	>
	lifecycle_state = <"in_development">
	other_contributors = <>
	other_details = <
		["licence"] = <"This work is licensed under the Creative Commons Attribution-ShareAlike 4.0 International License. To view a copy of this license, visit http://creativecommons.org/licenses/by-sa/4.0/.">
		["custodian_organisation"] = <"openEHR Foundation">
		["references"] = <"Berg KO, Wood-Dauphinee SL, Williams JI, Gayton D. Measuring balance in the elderly: preliminary development of an instrument. Physiother Can. 1989;41(6):304-11.

Berg KO, Wood-Dauphinee SL, Williams JI, Maki B. Measuring balance in the elderly: validation of an instrument. Can J Public Health. 1992;83 Suppl 2:S7-11.">
		["original_namespace"] = <"org.openehr">
		["original_publisher"] = <"openEHR Foundation">
		["custodian_namespace"] = <"org.openehr">
		["MD5-CAM-1.0.1"] = <"8474948CD1C741D76615F4471083888D">
		["build_uid"] = <"8fb1c5a1-bce2-4a86-b9f5-e287cb3d111a">
		["revision"] = <"0.0.1-alpha">
	>

definition
	OBSERVATION[at0000] matches {    -- Berg Balance Scale (BBS)
		data matches {
			HISTORY[at0001] matches {    -- History
				events cardinality matches {1..*; unordered} matches {
					EVENT[at0002] occurrences matches {0..*} matches {    -- Any event
						data matches {
							ITEM_TREE[at0003] matches {    -- Tree
								items cardinality matches {0..*; ordered} matches {
									ELEMENT[at0004] occurrences matches {0..1} matches {    -- 1. Sitting to standing
										value matches {
											0|[local::at0005],
											1|[local::at0006],
											2|[local::at0007],
											3|[local::at0008],
											4|[local::at0009]
										}
									}
									ELEMENT[at0010] occurrences matches {0..1} matches {    -- 2. Standing unsupported
										value matches {
											0|[local::at0011],
											1|[local::at0012],
											2|[local::at0013],
											3|[local::at0014],
											4|[local::at0015]
										}
									}
									ELEMENT[at0016] occurrences matches {0..1} matches {    -- 3. Sitting with back unsupported but feet supported on floor or on a stool
										value matches {
											0|[local::at0017],
											1|[local::at0018],
											2|[local::at0019],
											3|[local::at0020],
											4|[local::at0021]
										}
									}
									ELEMENT[at0022] occurrences matches {0..1} matches {    -- 4. Standing to sitting
										value matches {
											0|[local::at0023],
											1|[local::at0024],
											2|[local::at0025],
											3|[local::at0026],
											4|[local::at0027]
										}
									}
									ELEMENT[at0028] occurrences matches {0..1} matches {    -- 5. Transfers
										value matches {
											0|[local::at0029],
											1|[local::at0030],
											2|[local::at0031],
											3|[local::at0032],
											4|[local::at0033]
										}
									}
									ELEMENT[at0034] occurrences matches {0..1} matches {    -- 6. Standing unsupported with eyes closed
										value matches {
											0|[local::at0035],
											1|[local::at0036],
											2|[local::at0037],
											3|[local::at0038],
											4|[local::at0039]
										}
									}
									ELEMENT[at0040] occurrences matches {0..1} matches {    -- 7. Standing unsupported with feet together
										value matches {
											0|[local::at0041],
											1|[local::at0042],
											2|[local::at0043],
											3|[local::at0044],
											4|[local::at0045]
										}
									}
									ELEMENT[at0046] occurrences matches {0..1} matches {    -- 8. Reaching forward with outstretched arm while standing
										value matches {
											0|[local::at0047],
											1|[local::at0048],
											2|[local::at0049],
											3|[local::at0050],
											4|[local::at0051]
										}
									}
									ELEMENT[at0052] occurrences matches {0..1} matches {    -- 9. Pick up object from the floor from a standing position
										value matches {
											0|[local::at0053],
											1|[local::at0054],
											2|[local::at0055],
											3|[local::at0056],
											4|[local::at0057]
										}
									}
									ELEMENT[at0058] occurrences matches {0..1} matches {    -- 10. Turning to look behind over left and right shoulders while standing
										value matches {
											0|[local::at0059],
											1|[local::at0060],
											2|[local::at0061],
											3|[local::at0062],
											4|[local::at0063]
										}
									}
									ELEMENT[at0064] occurrences matches {0..1} matches {    -- 11. Turn 360 degrees
										value matches {
											0|[local::at0065],
											1|[local::at0066],
											2|[local::at0067],
											3|[local::at0068],
											4|[local::at0069]
										}
									}
									ELEMENT[at0070] occurrences matches {0..1} matches {    -- 12. Place alternate foot on step or stool while standing unsupported
										value matches {
											0|[local::at0071],
											1|[local::at0072],
											2|[local::at0073],
											3|[local::at0074],
											4|[local::at0075]
										}
									}
									ELEMENT[at0076] occurrences matches {0..1} matches {    -- 13. Standing unsupported one foot in front
										value matches {
											0|[local::at0077],
											1|[local::at0078],
											2|[local::at0079],
											3|[local::at0080],
											4|[local::at0081]
										}
									}
									ELEMENT[at0082] occurrences matches {0..1} matches {    -- 14. Standing on one leg
										value matches {
											0|[local::at0083],
											1|[local::at0084],
											2|[local::at0085],
											3|[local::at0086],
											4|[local::at0087]
										}
									}
									ELEMENT[at0088] occurrences matches {0..1} matches {    -- Total score
										value matches {
											DV_COUNT matches {
												magnitude matches {|0..56|}
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0090] matches {    -- Tree
				items cardinality matches {0..*; unordered} matches {
					allow_archetype CLUSTER[at0091] occurrences matches {0..*} matches {    -- Extension
						include
							archetype_id/value matches {/.*/}
					}
				}
			}
		}
	}


ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Berg Balance Scale (BBS)">
					description = <"A performance-based assessment of static and dynamic balance ability, consisting of 14 tasks scored on a five-point ordinal scale.">
				>
				["at0001"] = <
					text = <"History">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Any event">
					description = <"Default, unspecified point in time or interval event which may be explicitly defined in a template or at run-time.">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"1. Sitting to standing">
					description = <"">
				>
				["at0005"] = <
					text = <"Needs moderate or maximal assist to stand">
					description = <"">
				>
				["at0006"] = <
					text = <"Needs minimal aid to stand or stabilize">
					description = <"">
				>
				["at0007"] = <
					text = <"Able to stand using hands after several tries">
					description = <"">
				>
				["at0008"] = <
					text = <"Able to stand independently using hands">
					description = <"">
				>
				["at0009"] = <
					text = <"Able to stand without using hands and stabilize independently">
					description = <"">
				>
				["at0010"] = <
					text = <"2. Standing unsupported">
					description = <"">
				>
				["at0011"] = <
					text = <"Unable to stand 30 seconds unsupported">
					description = <"">
				>
				["at0012"] = <
					text = <"Needs several tries to stand 30 seconds unsupported">
					description = <"">
				>
				["at0013"] = <
					text = <"Able to stand 30 seconds unsupported">
					description = <"">
				>
				["at0014"] = <
					text = <"Able to stand 2 minutes with supervision">
					description = <"">
				>
				["at0015"] = <
					text = <"Able to stand safely for 2 minutes">
					description = <"">
				>
				["at0016"] = <
					text = <"3. Sitting with back unsupported but feet supported on floor or on a stool">
					description = <"">
				>
				["at0017"] = <
					text = <"Unable to sit without support 10 seconds">
					description = <"">
				>
				["at0018"] = <
					text = <"Able to sit 10 seconds">
					description = <"">
				>
				["at0019"] = <
					text = <"Able to sit 30 seconds">
					description = <"">
				>
				["at0020"] = <
					text = <"Able to sit 2 minutes under supervision">
					description = <"">
				>
				["at0021"] = <
					text = <"Able to sit safely and securely for 2 minutes">
					description = <"">
				>
				["at0022"] = <
					text = <"4. Standing to sitting">
					description = <"">
				>
				["at0023"] = <
					text = <"Needs assist to sit">
					description = <"">
				>
				["at0024"] = <
					text = <"Sits independently but has uncontrolled descent">
					description = <"">
				>
				["at0025"] = <
					text = <"Uses back of legs against chair to control descent">
					description = <"">
				>
				["at0026"] = <
					text = <"Controls descent by using hands">
					description = <"">
				>
				["at0027"] = <
					text = <"Sits safely with minimal use of hands">
					description = <"">
				>
				["at0028"] = <
					text = <"5. Transfers">
					description = <"">
				>
				["at0029"] = <
					text = <"Needs two people to assist or supervise to be safe">
					description = <"">
				>
				["at0030"] = <
					text = <"Needs one person to assist">
					description = <"">
				>
				["at0031"] = <
					text = <"Able to transfer with verbal cuing and/or supervision">
					description = <"">
				>
				["at0032"] = <
					text = <"Able to transfer safely definite need of hands">
					description = <"">
				>
				["at0033"] = <
					text = <"Able to transfer safely with minor use of hands">
					description = <"">
				>
				["at0034"] = <
					text = <"6. Standing unsupported with eyes closed">
					description = <"">
				>
				["at0035"] = <
					text = <"Needs help to keep from falling">
					description = <"">
				>
				["at0036"] = <
					text = <"Unable to keep eyes closed 3 seconds but stays safely">
					description = <"">
				>
				["at0037"] = <
					text = <"Able to stand 3 seconds">
					description = <"">
				>
				["at0038"] = <
					text = <"Able to stand 10 seconds with supervision">
					description = <"">
				>
				["at0039"] = <
					text = <"Able to stand 10 seconds safely">
					description = <"">
				>
				["at0040"] = <
					text = <"7. Standing unsupported with feet together">
					description = <"">
				>
				["at0041"] = <
					text = <"Needs help to attain position and unable to hold for 15 seconds">
					description = <"">
				>
				["at0042"] = <
					text = <"Needs help to attain position but able to stand 15 seconds feet together">
					description = <"">
				>
				["at0043"] = <
					text = <"Able to place feet together independently but unable to hold for 30 seconds">
					description = <"">
				>
				["at0044"] = <
					text = <"Able to place feet together independently and stand 1 minute with supervision">
					description = <"">
				>
				["at0045"] = <
					text = <"Able to place feet together independently and stand 1 minute safely">
					description = <"">
				>
				["at0046"] = <
					text = <"8. Reaching forward with outstretched arm while standing">
					description = <"">
				>
				["at0047"] = <
					text = <"Loses balance while trying/requires external support">
					description = <"">
				>
				["at0048"] = <
					text = <"Reaches forward but needs supervision">
					description = <"">
				>
				["at0049"] = <
					text = <"Can reach forward 5 cm (2 inches)">
					description = <"">
				>
				["at0050"] = <
					text = <"Can reach forward 12 cm (5 inches)">
					description = <"">
				>
				["at0051"] = <
					text = <"Can reach forward confidently 25 cm (10 inches)">
					description = <"">
				>
				["at0052"] = <
					text = <"9. Pick up object from the floor from a standing position">
					description = <"">
				>
				["at0053"] = <
					text = <"Unable to try/needs assist to keep from losing balance or falling">
					description = <"">
				>
				["at0054"] = <
					text = <"Unable to pick up and needs supervision while trying">
					description = <"">
				>
				["at0055"] = <
					text = <"Unable to pick up but reaches 2-5 cm (1-2 inches) from slipper and keeps balance independently">
					description = <"">
				>
				["at0056"] = <
					text = <"Able to pick up slipper but needs supervision">
					description = <"">
				>
				["at0057"] = <
					text = <"Able to pick up slipper safely and easily">
					description = <"">
				>
				["at0058"] = <
					text = <"10. Turning to look behind over left and right shoulders while standing">
					description = <"">
				>
				["at0059"] = <
					text = <"Needs assist to keep from losing balance or falling">
					description = <"">
				>
				["at0060"] = <
					text = <"Needs supervision when turning">
					description = <"">
				>
				["at0061"] = <
					text = <"Turns sideways only but maintains balance">
					description = <"">
				>
				["at0062"] = <
					text = <"Looks behind one side only other side shows less weight shift">
					description = <"">
				>
				["at0063"] = <
					text = <"Looks behind from both sides and weight shifts well">
					description = <"">
				>
				["at0064"] = <
					text = <"11. Turn 360 degrees">
					description = <"">
				>
				["at0065"] = <
					text = <"Needs assistance while turning">
					description = <"">
				>
				["at0066"] = <
					text = <"Needs close supervision or verbal cuing">
					description = <"">
				>
				["at0067"] = <
					text = <"Able to turn 360 degrees safely but slowly">
					description = <"">
				>
				["at0068"] = <
					text = <"Able to turn 360 degrees safely one side only 4 seconds or less">
					description = <"">
				>
				["at0069"] = <
					text = <"Able to turn 360 degrees safely in 4 seconds or less">
					description = <"">
				>
				["at0070"] = <
					text = <"12. Place alternate foot on step or stool while standing unsupported">
					description = <"">
				>
				["at0071"] = <
					text = <"Needs assistance to keep from falling/unable to try">
					description = <"">
				>
				["at0072"] = <
					text = <"Able to complete > 2 steps needs minimal assist">
					description = <"">
				>
				["at0073"] = <
					text = <"Able to complete 4 steps without aid with supervision">
					description = <"">
				>
				["at0074"] = <
					text = <"Able to stand independently and complete 8 steps in > 20 seconds">
					description = <"">
				>
				["at0075"] = <
					text = <"Able to stand independently and safely and complete 8 steps in 20 seconds">
					description = <"">
				>
				["at0076"] = <
					text = <"13. Standing unsupported one foot in front">
					description = <"">
				>
				["at0077"] = <
					text = <"Loses balance while stepping or standing">
					description = <"">
				>
				["at0078"] = <
					text = <"Needs help to step but can hold 15 seconds">
					description = <"">
				>
				["at0079"] = <
					text = <"Able to take small step independently and hold 30 seconds">
					description = <"">
				>
				["at0080"] = <
					text = <"Able to place foot ahead independently and hold 30 seconds">
					description = <"">
				>
				["at0081"] = <
					text = <"Able to place foot tandem independently and hold 30 seconds">
					description = <"">
				>
				["at0082"] = <
					text = <"14. Standing on one leg">
					description = <"">
				>
				["at0083"] = <
					text = <"Unable to try or needs assist to prevent fall">
					description = <"">
				>
				["at0084"] = <
					text = <"Tries to lift leg unable to hold 3 seconds but remains standing independently">
					description = <"">
				>
				["at0085"] = <
					text = <"Able to lift leg independently and hold ≥ 3 seconds">
					description = <"">
				>
				["at0086"] = <
					text = <"Able to lift leg independently and hold 5-10 seconds">
					description = <"">
				>
				["at0087"] = <
					text = <"Able to lift leg independently and hold > 10 seconds">
					description = <"">
				>
				["at0088"] = <
					text = <"Total score">
					description = <"The sum of the 14 item scores, from 0 to 56, where higher scores indicate better balance.">
				>
				["at0090"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0091"] = <
					text = <"Extension">
					description = <"Additional information required to capture local content or to align with other reference models/formalisms.">
				>
			>
		>
		["nb"] = <
			items = <
				["at0000"] = <
					text = <"Berg balanseskala (BBS)">
					description = <"En prestasjonsbasert vurdering av statisk og dynamisk balanseevne, bestående av 14 oppgaver som skåres på en femdelt ordinal skala.">
				>
				["at0001"] = <
					text = <"History">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Uspesifisert hendelse">
					description = <"Standard, uspesifisert tidspunkt eller tidsintervall som kan defineres mer eksplisitt i en template eller i en applikasjon.">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"1. Sittende til stående">
					description = <"">
				>
				["at0005"] = <
					text = <"Trenger middels eller maksimal hjelp av en eller flere personer for å reise seg opp">
					description = <"">
				>
				["at0006"] = <
					text = <"Trenger minimal hjelp av en person for å reise seg opp eller for å finne balansen">
					description = <"">
				>
				["at0007"] = <
					text = <"Kan reise seg opp med hjelp av hendene etter flere forsøk">
					description = <"">
				>
				["at0008"] = <
					text = <"Kan reise seg opp på egen hånd med hjelp av hendene">
					description = <"">
				>
				["at0009"] = <
					text = <"Kan reise seg opp uten å bruke hendene og finner selv balansen">
					description = <"">
				>
				["at0010"] = <
					text = <"2. Stå uten støtte">
					description = <"">
				>
				["at0011"] = <
					text = <"Kan ikke stå i 30 sekunder uten støtte">
					description = <"">
				>
				["at0012"] = <
					text = <"Trenger flere forsøk for å stå i 30 sekunder uten støtte">
					description = <"">
				>
				["at0013"] = <
					text = <"Kan stå i 30 sekunder uten støtte">
					description = <"">
				>
				["at0014"] = <
					text = <"Kan stå i 2 minutter med tilsyn">
					description = <"">
				>
				["at0015"] = <
					text = <"Kan stå stødig i 2 minutter">
					description = <"">
				>
				["at0016"] = <
					text = <"3. Sitte uten ryggstøtte med føttene på golvet eller på en skammel">
					description = <"">
				>
				["at0017"] = <
					text = <"Kan ikke sitte i 10 sekunder uten støtte">
					description = <"">
				>
				["at0018"] = <
					text = <"Kan sitte i 10 sekunder">
					description = <"">
				>
				["at0019"] = <
					text = <"Kan sitte i 30 sekunder">
					description = <"">
				>
				["at0020"] = <
					text = <"Kan sitte i 2 minutter med tilsyn">
					description = <"">
				>
				["at0021"] = <
					text = <"Kan sitte trygt og sikkert i 2 minutter">
					description = <"">
				>
				["at0022"] = <
					text = <"4. Stående til sittende">
					description = <"">
				>
				["at0023"] = <
					text = <"Trenger hjelp av en person for å sette seg">
					description = <"">
				>
				["at0024"] = <
					text = <"Setter seg selvstendig men ukontrollert">
					description = <"">
				>
				["at0025"] = <
					text = <"Bruker baksiden av bena mot stolen for å kontrollere det å sette seg">
					description = <"">
				>
				["at0026"] = <
					text = <"Kontrollerer det å sette seg ved hjelp av hendene">
					description = <"">
				>
				["at0027"] = <
					text = <"Setter seg på en trygg måte med minimal hjelp av hendene">
					description = <"">
				>
				["at0028"] = <
					text = <"5. Fra sittende på en stol med armlene til en annen stol uten armlene og vice versa">
					description = <"">
				>
				["at0029"] = <
					text = <"Trenger hjelp av to personer (for å støtte eller veilede for å være trygg)">
					description = <"">
				>
				["at0030"] = <
					text = <"Trenger hjelp av en person">
					description = <"">
				>
				["at0031"] = <
					text = <"Kan forflytte seg ved hjelp av muntlige ledetråder og/eller tilsyn">
					description = <"">
				>
				["at0032"] = <
					text = <"Kan forflytte seg på en trygg måte med mye hjelp av hendene">
					description = <"">
				>
				["at0033"] = <
					text = <"Kan forflytte seg på en trygg måte med minimal hjelp av hendene">
					description = <"">
				>
				["at0034"] = <
					text = <"6. Stå uten støtte med lukkede øyne">
					description = <"">
				>
				["at0035"] = <
					text = <"Trenger hjelp for ikke å falle">
					description = <"">
				>
				["at0036"] = <
					text = <"Står stille, men må åpne øynene i løpet av 3 sekunder">
					description = <"">
				>
				["at0037"] = <
					text = <"Kan stå i 3 sekunder">
					description = <"">
				>
				["at0038"] = <
					text = <"Kan stå i 10 sekunder med tilsyn">
					description = <"">
				>
				["at0039"] = <
					text = <"Kan stå sikkert i 10 sekunder">
					description = <"">
				>
				["at0040"] = <
					text = <"7. Stå uten støtte med føttene inntil hverandre">
					description = <"">
				>
				["at0041"] = <
					text = <"Trenger hjelp for å innta stillingen og kan ikke stå i stillingen i 15 sekunder">
					description = <"">
				>
				["at0042"] = <
					text = <"Trenger hjelp for å innta stillingen, men kan stå i 15 sekunder med føttene inntil hverandre">
					description = <"">
				>
				["at0043"] = <
					text = <"Kan selv sette føttene inntil hverandre, men kan ikke stå slik i 1 minutt">
					description = <"">
				>
				["at0044"] = <
					text = <"Kan selv sette føttene inntil hverandre og stå i 1 minutt med tilsyn">
					description = <"">
				>
				["at0045"] = <
					text = <"Kan selv sette føttene inntil hverandre og stå sikkert i 1 minutt">
					description = <"">
				>
				["at0046"] = <
					text = <"8. Strekker seg framover med utstrakt arm i stående">
					description = <"">
				>
				["at0047"] = <
					text = <"Mister balansen ved forsøket/trenger ytre støtte">
					description = <"">
				>
				["at0048"] = <
					text = <"Strekker seg fremover men trenger tilsyn">
					description = <"">
				>
				["at0049"] = <
					text = <"Kan strekke seg fremover mer enn 5 centimeter på en sikker måte">
					description = <"">
				>
				["at0050"] = <
					text = <"Kan strekke seg fremover mer enn 12 centimeter på en sikker måte">
					description = <"">
				>
				["at0051"] = <
					text = <"Kan strekke seg fremover mer enn 25 centimeter på en sikker måte">
					description = <"">
				>
				["at0052"] = <
					text = <"9. Stå og ta opp en gjenstand fra gulvet">
					description = <"">
				>
				["at0053"] = <
					text = <"Mister balansen ved forsøket/trenger ytre støtte">
					description = <"">
				>
				["at0054"] = <
					text = <"Kan ikke ta opp skoen og trenger tilsyn under forsøket">
					description = <"">
				>
				["at0055"] = <
					text = <"Kan ikke ta opp skoen, men når 2,5-5 cm fra skoen og vedlikeholder balansen">
					description = <"">
				>
				["at0056"] = <
					text = <"Kan ta opp skoen men trenger tilsyn">
					description = <"">
				>
				["at0057"] = <
					text = <"Kan ta opp skoen på en enkelt og sikker måte">
					description = <"">
				>
				["at0058"] = <
					text = <"10. Vri seg og se bak over høyre og venstre skulder i stående">
					description = <"">
				>
				["at0059"] = <
					text = <"Trenger støtte for ikke å miste balansen eller falle">
					description = <"">
				>
				["at0060"] = <
					text = <"Trenger tilsyn under utførelsen">
					description = <"">
				>
				["at0061"] = <
					text = <"Vrir seg bare til siden, men opprettholder balansen">
					description = <"">
				>
				["at0062"] = <
					text = <"Ser bak seg til den ene siden, har mindre rotasjon til den andre siden">
					description = <"">
				>
				["at0063"] = <
					text = <"Ser bak seg til begge sider og roterer i hele kroppen og det foregår \"tyngdeoverføring\"">
					description = <"">
				>
				["at0064"] = <
					text = <"11. Snu seg 360 grader">
					description = <"">
				>
				["at0065"] = <
					text = <"Trenger støtte under vendingen">
					description = <"">
				>
				["at0066"] = <
					text = <"Trenger tilsyn eller muntlige ledetråder">
					description = <"">
				>
				["at0067"] = <
					text = <"Kan snu seg sikkert 360 grader, men trenger mer enn 4 sekunder">
					description = <"">
				>
				["at0068"] = <
					text = <"Kan snu seg sikkert 360 grader på 4 sekunder eller mindre kun en retning">
					description = <"">
				>
				["at0069"] = <
					text = <"Kan snu seg sikkert 360 grader på 4 sekunder eller mindre">
					description = <"">
				>
				["at0070"] = <
					text = <"12. Stå uten støtte og plasser vekselvis en og en fot på et trinn eller en skammel">
					description = <"">
				>
				["at0071"] = <
					text = <"Trenger hjelp for ikke å falle/er ikke i stand til å prøve">
					description = <"">
				>
				["at0072"] = <
					text = <"Kan klare mer enn 1 gang på hver fot med minimal hjelp">
					description = <"">
				>
				["at0073"] = <
					text = <"Kan klare å sette opp hver fot 2 ganger på trinnet uten hjelp men med tilsyn">
					description = <"">
				>
				["at0074"] = <
					text = <"Kan stå selvstendig og klarer å sette hver fot på trinnet på mer enn 20 sekunder">
					description = <"">
				>
				["at0075"] = <
					text = <"Kan stå selvstendig og trygt og greier (eller klarer) å sette hver fot 4 ganger på trinnet i løpet av 20 sekunder">
					description = <"">
				>
				["at0076"] = <
					text = <"13. Stå uten støtte med en fot foran den andre">
					description = <"">
				>
				["at0077"] = <
					text = <"Mister balansen under steget eller i stillingen">
					description = <"">
				>
				["at0078"] = <
					text = <"Trenger hjelp med å flytte en fot fram, men kan stå i stillingen i 15 sekunder">
					description = <"">
				>
				["at0079"] = <
					text = <"Kan selv flytte en fot et lite skritt fram og stå der i 30 sekunder">
					description = <"">
				>
				["at0080"] = <
					text = <"Kan selv sette en fot foran den andre og stå der i 30 sekunder">
					description = <"">
				>
				["at0081"] = <
					text = <"Kan selv plassere føttene i tandemstilling og stå der i 30 sekunder">
					description = <"">
				>
				["at0082"] = <
					text = <"14. Stå på ett ben">
					description = <"">
				>
				["at0083"] = <
					text = <"Kan ikke eller forsøker ikke å løfte benet, eller trenger hjelp for ikke å falle">
					description = <"">
				>
				["at0084"] = <
					text = <"Forsøker å løfte benet, men kan ikke stå på ett ben i 3 sekunder, men kan likevel stå på egen hånd">
					description = <"">
				>
				["at0085"] = <
					text = <"Kan selv løfte benet og stå der i 3 sekunder">
					description = <"">
				>
				["at0086"] = <
					text = <"Kan selv løfte benet og stå der i 5 sekunder">
					description = <"">
				>
				["at0087"] = <
					text = <"Kan selv løfte benet og stå der i 10 sekunder">
					description = <"">
				>
				["at0088"] = <
					text = <"Sumskår">
					description = <"Summen av de 14 oppgaveskårene, fra 0 til 56, der høyere skår indikerer bedre balanse.">
