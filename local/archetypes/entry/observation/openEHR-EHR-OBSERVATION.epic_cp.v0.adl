		["nb"] = <
			items = <
				["at0000"] = <
					text = <"Expanded Prostate Cancer Index Composite for Clinical Practice (EPIC CP)">
					description = <"Et helserelatert livskvalitetsspørreskjema (HRQoL) for pasienter med prostatakreft, og som brukes i rutinemessig klinisk behandling for å måle urininkontinens, urinveisirritasjon/-obstruksjon, avføringssymptomer, seksualfunksjon, vitalitet/hormonelle symptomer.">
				>
				["at0001"] = <
					text = <"History">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Uspesifisert hendelse">
					description = <"Standard, uspesifisert tidspunkt eller tidsintervall som kan defineres mer eksplisitt i en template eller i en applikasjon.">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"1. Alt i alt, hvor stort problem har blærefunksjonen din vært for deg i løpet av de siste 4 ukene?">
					description = <"">
				>
				["at0005"] = <
					text = <"2. Hvordan vil du beskrive din kontroll over vannlatingen i løpet av de siste 4 ukene?">
					description = <"">
				>
				["at0006"] = <
					text = <"3. Hvor mange truseinnlegg, bind eller bleier brukte du vanligvis per dag i løpet av de siste 4 ukene for å kontrollere urinlekkasjen?">
					description = <"">
				>
				["at0007"] = <
					text = <"4. Hvor stort problem, om noe, har drypping eller urinlekkasje vært for deg i løpet av de siste 4 ukene?">
					description = <"">
				>
				["at0008"] = <
					text = <"Urininkontinenssymptom">
					description = <"Sumskåren for domenet urininkontinens.">
					comment = <"Spørsmål 2 - 4.">
				>
				["at0009"] = <
					text = <"5a. Smerte eller svie ved vannlating">
					description = <"">
				>
				["at0010"] = <
					text = <"5b. Svak urinstråle eller ufullstendig tømming">
					description = <"">
				>
				["at0011"] = <
					text = <"5c. Hyppig trang til vannlating">
					description = <"">
				>
				["at0012"] = <
					text = <"Urinirritasjon/obstruksjonssymptom">
					description = <"Sumskåren for domenet urinveisirritasjon/ - obstruksjon.">
					comment = <"Spørsmål 5a-5c.">
				>
				["at0013"] = <
					text = <"6a. Smerter i endetarm eller sterk umiddelbar avføringstrang">
					description = <"">
				>
				["at0014"] = <
					text = <"6b. Økt antall avføringer">
					description = <"">
				>
				["at0015"] = <
					text = <"6c. Alt i alt, hvor stort problem har tarmfunksjonen vært for deg?">
					description = <"">
				>
				["at0016"] = <
					text = <"Tarmsymptom">
					description = <"Sumskåren for domenet tarmfunksjon.">
					comment = <"Spørsmål 6a‐6c.">
				>
				["at0017"] = <
					text = <"7. Hvordan vil du gradere din evne til å oppnå orgasme (klimaks) i løpet av de siste 4 ukene?">
					description = <"">
				>
				["at0018"] = <
					text = <"8. Hvordan vil du beskrive kvaliteten av ereksjonene dine i løpet av de siste 4 ukene?">
					description = <"">
				>
				["at0019"] = <
					text = <"9. Alt i alt, hvor stort problem har seksualfunksjonen, eller mangelen på slik funksjon, vært for deg i løpet av de siste 4 ukene?">
					description = <"">
				>
				["at0020"] = <
					text = <"Seksuell symptom">
					description = <"Sumskåren for domenet seksualfunksjon.">
					comment = <"Spørsmål 7‐9.">
				>
				["at0021"] = <
