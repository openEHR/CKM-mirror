	openEHR-EHR-OBSERVATION.epic_cp.v0

concept
	[at0000]	-- Expanded Prostate Cancer Index Composite for Clinical Practice (EPIC-CP)
language
	original_language = <[ISO_639-1::en]>
	translations = <
		["nb"] = <
			language = <[ISO_639-1::nb]>
			author = <
				["name"] = <"Mikkel Johan Gaup Grønmo, Vebjørn Arntzen">
				["organisation"] = <"Regional forvaltning EPJ, Helse Nord RHF, Oslo University Hospital">
