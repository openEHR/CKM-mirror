		["build_uid"] = <"2d1b0a73-8d5d-4115-ad03-97fcbd621e02">
		["revision"] = <"0.0.1-alpha">
	>

definition
	OBSERVATION[at0000] matches {    -- V_RISK_Y
		data matches {
			HISTORY[at0001] matches {    -- History
				events cardinality matches {1..*; unordered} matches {
					EVENT[at0002] occurrences matches {0..*} matches {    -- Any event
						data matches {
							ITEM_TREE[at0003] matches {    -- Tree
								items cardinality matches {0..*; unordered} matches {
									ELEMENT[at0004] occurrences matches {0..1} matches {    -- 1. Prior and/or current acts of violence
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0091,    -- No
													at0092,    -- Moderate
													at0093,    -- Yes
													at0094]    -- Don't know
												}
											}
										}
									}
									ELEMENT[at0005] occurrences matches {0..1} matches {    -- 2. Prior and/or current threats of violence
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0142,    -- No
													at0143,    -- Moderate
													at0144,    -- Yes
													at0145]    -- Don't know
												}
											}
										}
									}
									ELEMENT[at0006] occurrences matches {0..1} matches {    -- 3. Prior and/or current alcohol or substance abuse
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0146,    -- No
													at0147,    -- Moderate
													at0148,    -- Yes
													at0149]    -- Don't know
												}
											}
										}
									}
									ELEMENT[at0007] occurrences matches {0..1} matches {    -- 4. Prior and/or current severe symptoms of mental health disorders
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0150,    -- No
													at0151,    -- Maybe
													at0152,    -- Yes
													at0153]    -- Don't know
												}
											}
										}
									}
									ELEMENT[at0008] occurrences matches {0..1} matches {    -- 5. Disruptive, impulsive behaviour/behavioural disorder
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0154,    -- No
													at0155,    -- Moderate
													at0156,    -- Yes
													at0157]    -- Don't know
												}
											}
										}
									}
									ELEMENT[at0009] occurrences matches {0..1} matches {    -- 6. Has poor insight into the mental disorder and/or behaviour
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0158,    -- No
													at0159,    -- Moderate
													at0160,    -- Yes
													at0161]    -- Don't know
												}
											}
										}
									}
									ELEMENT[at0010] occurrences matches {0..1} matches {    -- 7. Suspicion
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0162,    -- No
													at0163,    -- Moderate
													at0164,    -- Yes
													at0165]    -- Don't know.
												}
											}
										}
									}
									ELEMENT[at0011] occurrences matches {0..1} matches {    -- 8. Demonstrates lack of empathy
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0166,    -- No
													at0167,    -- Moderate
													at0168,    -- Yes
													at0169]    -- Don't know.
												}
											}
										}
									}
									ELEMENT[at0012] occurrences matches {0..1} matches {    -- 9. Unrealistic planning
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0170,    -- No
													at0171,    -- Moderate
													at0172,    -- Yes
													at0173]    -- Don't know.
												}
											}
										}
									}
									ELEMENT[at0013] occurrences matches {0..1} matches {    -- 10. Future stressful situations
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0174,    -- No
													at0175,    -- Moderate
													at0176,    -- Yes.
													at0177]    -- Don't know
												}
											}
										}
									}
									ELEMENT[at0014] occurrences matches {0..1} matches {    -- 11. Prior and/or current severe trauma
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0178,    -- No
													at0179,    -- Maybe
													at0180,    -- Yes
													at0181]    -- Don't know
												}
											}
										}
									}
									ELEMENT[at0015] occurrences matches {0..1} matches {    -- 12. The youth’s and parents/guardians’ own perception of violence risk
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0182,    -- No
													at0183,    -- Maybe
													at0184,    -- Yes
													at0185]    -- Don't know
												}
											}
										}
									}
									ELEMENT[at0016] occurrences matches {0..1} matches {    -- How great do you believe the risk of violence is for this youth?
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0139,    -- Low
													at0140,    -- Moderate
													at0141]    -- High
												}
											}
										}
									}
									ELEMENT[at0083] occurrences matches {0..1} matches {    -- Immediate implementation of preventive measures
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0084,    -- No
													at0085]    -- Yes
												}
											}
										}
									}
									ELEMENT[at0081] occurrences matches {0..1} matches {    -- Description of preventive measures
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0086] occurrences matches {0..1} matches {    -- Suggestions for additional violence risk assessments
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0087,    -- No
													at0088]    -- Yes
												}
											}
										}
									}
									ELEMENT[at0082] occurrences matches {0..1} matches {    -- Description of additional violence risk assessments
										value matches {
											DV_TEXT matches {*}
										}
									}
								}
							}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0089] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					allow_archetype CLUSTER[at0090] occurrences matches {0..*} matches {    -- Extension
						include
							archetype_id/value matches {/.*/}
					}
				}
			}
		}
	}


ontology
	term_definitions = <
		["nb"] = <
			items = <
				["at0000"] = <
					text = <"V_RISK_Y">
					description = <"V-RISK-Y er et strukturert verktøy for vurdering av voldsrisiko blant ungdom i alderen 12–18 år. Verktøyet er utviklet for bruk ved første kontakt med ungdommen, og gir grunnlag for å vurdere behovet for umiddelbare tiltak og videre risikovurdering. ">
				>
				["at0001"] = <
					text = <"History">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Uspesifisert hendelse">
					description = <"Standard, uspesifisert tidspunkt eller tidsintervall som kan defineres mer eksplisitt i et templat eller i en applikasjon.">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"1. Tidligere og/eller aktuell vold">
					description = <"">
					comment = <"Alvorlig vold: Fysiske angrep (inkludert ulike våpen, brann) for å påføre alvorlig fysisk skade mot annen person.

Moderat: Aggresjonshandlinger som spark, slag og dytting som ikke forårsaker skade hos offeret.
Ja: Må ha gjort minst 3 moderate eller 1 alvorlig voldshandling. 

Definisjon av vold: Atferd innrettet på (intensjon) å påføre et annet menneske kroppslig smerte, skade eller krenkelse.">
				>
				["at0005"] = <
					text = <"2. Tidligere og/eller aktuelle trusler om vold">
					description = <"">
					comment = <"En verbal voldstrussel: Rop, utsagn eller skriftlig (inkludert sosiale medier) som truer med å utøve vold mot et annet menneske. 

En fysisk voldstrussel er å vise angrepsforberedende atferd f.eks. å true med knyttneve, eller annen fysisk atferd som signaliserer fysisk angrep. Å ødelegge gjenstander er ikke voldsatferd, men kan i noen situasjoner oppfattes som en trussel (fysisk trussel vil ofte gi høyere risiko enn verbal trussel).">
				>
				["at0006"] = <
					text = <"3. Tidligere og/eller aktuell rusbruk">
					description = <"">
					comment = <"Moderat: Ungdommen har en historie med misbruk av alkohol, medikamenter, narkotiske stoffer eller løsemidler.
Ja: Ungdommen har eller har hatt omfattende misbruk/ avhengighet, med nedsatt helse eller funksjon i skole-, arbeids- eller fritidsliv.">
				>
				["at0007"] = <
					text = <"4. Tidligere og/eller aktuelle alvorlige psykiske symptomer">
					description = <"">
					comment = <"Ungdommen har merkelig eller upassende atferd og/eller forestillinger som ikke samsvarer med utviklingsmessig alder, og hvor det kommer fram en sviktende realitetsforståelse. Dette kan være uttrykk for angstlidelser, depresjoner, autismespekter lidelser, lidelser/ symptomer med realitetsbrist, eller tilsvarende.

Kanskje: Atferd og forestillinger som gir mistanke om avvik, se over
Ja: Åpenbar og tydelig avvikende atferd og forestillinger som anført over.">
				>
				["at0008"] = <
					text = <"5. Forstyrrende, impulsiv atferd/atferdsforstyrrelser">
					description = <"">
					comment = <"Moderat: Impulsiv, forstyrrende atferd som ikke forårsaker alvorlig skade eller ubehag; ADHD, opposisjonell atferd eller dårlig emosjonell regulering (f.eks. selvskading).
Ja: Atferdsforstyrrelser (forårsaker alvorlig skade eller ubehag), antisosial atferd.">
				>
				["at0009"] = <
					text = <"6. Mangler innsikt i sykdom og/eller atferd">
					description = <"">
					comment = <"Her menes i hvilken grad ungdommen eller foresatte mangler innsikt i ungdommens psykiske lidelse.
Herunder behandling, sosiale konsekvenser, eller atferd knyttet til sykdom eller utviklings- / personlighetsforstyrrelser. For yngre ungdommer vil foresattes innsikt være viktigst, for eldre ungdommer vil ungdommens egen innsikt være viktigst.

Moderat: Enten ungdommen eller foresatte mangler innsikt.
Ja: Både ungdommen og foresatte, eller ungdom 16-18 år, mangler innsikt.">
				>
				["at0010"] = <
					text = <"7. Mistenksomhet">
					description = <"">
					comment = <"Ungdommen gir uttrykk for mistenksomhet overfor andre personer enten verbalt eller nonverbalt. Vedkommende ser ut til å være «på vakt» overfor omgivelsene.">
				>
				["at0011"] = <
					text = <"8. Viser manglende innlevelse (empati)">
					description = <"">
					comment = <"Ungdommen uttrykker følelseskald atferd uten innlevelse i andres tankemessige eller følelsesmessige situasjon.">
				>
				["at0012"] = <
					text = <"9. Urealistisk planlegging">
					description = <"">
					comment = <"Her måles i hvilken grad ungdommen selv eller foresatte har urealistiske behandlingsplaner / andre viktige planer for fremtiden. Er f.eks. ungdommen /foresatte realistiske i forhold til hva han/hun trenger av støtte, og hva som kan forventes av støtte fra familie og av profesjonelt og sosialt nettverk. Det er viktig å vurdere om foresatte og ungdommen er samarbeidsvillige og motiverte til å følge planene videre. For yngre ungdommer vil foresattes planer være viktigst, for eldre ungdommer vil egne planer være viktigst.

Moderat: Enten ungdommen eller foresatte mangler realistiske planer
Ja: Både ungdommen og foresatte, eller ungdom 16-18 år, mangler realistiske planer">
				>
				["at0013"] = <
					text = <"10. Framtidige stress-situasjoner">
					description = <"">
					comment = <"Her undersøkes muligheten for at ungdommen kan bli utsatt for påkjenninger og belastende situasjoner i fremtiden, og hans/hennes evne til stressmestring.

I dette leddet inngår om foresatte kan være en støtte for ungdommen mht stressmestring, om det foreligger konflikt mellom ungdommen og foresatte, om foresatte har antisosial livsstil / holdninger, og tiltrekning til voldelige miljø som ekstremistiske sympatisører, f.eks. radikale islamister eller høyreradikale.

Eksempler: Mestringssvikt overfor grensesetting, nærhet til mulige voldsofre, rusing, eksponering for voldelig miljø etc.">
				>
				["at0014"] = <
					text = <"11. Tidligere og/eller alvorlig pågående traume">
					description = <"">
					comment = <"Har ungdommen vært utsatt for / vært vitne til et alvorlig traume, vært utsatt for / vært vitne til gjentatte fysiske / seksuelle / psykiske overgrep, vært utsatt for omsorgssvikt.

Kanskje: Mistanke om alvorlig traume. 
Ja: Alvorlig traume.">
				>
				["at0015"] = <
					text = <"12. Ungdommens og foresattes oppfatning av risiko">
					description = <"">
					comment = <"I hvilken grad ungdommen eller de foresatte oppfatter at det er risiko for vold:

Kanskje: Ungdommen eller de foresatte oppfatter at det er litt forhøyet risiko for vold.
Ja: Ungdommen eller de foresatte oppfatter enten moderat / høy voldsrisiko eller vil ikke svare.">
				>
				["at0016"] = <
					text = <"Hvor stor tror du voldsrisikoen er for denne pasienten?">
					description = <"Samlet klinisk vurdering og iverksettelse av tiltak basert på V-RISK-Y, individuell klinisk vurdering, og annen tilgjengelig informasjon. ">
					comment = <"OBS: «Vet ikke» skåre indikerer signifikant høyere risiko enn «Nei» skåre.">
				>
				["at0081"] = <
					text = <"Beskrivelse av tiltak">
					description = <"f.eks skjerming, fast vakt, ekstra personale, hyppig tilsyn.">
				>
				["at0082"] = <
					text = <"Beskrivelse av tiltak">
					description = <"feks «kartlegging / utredning», «videre voldsrisiko-
utredning på institusjonen», «henvisning til second opinion», «bruk av instrumenter» (som BVC, SAVRY), etc.">
				>
				["at0083"] = <
					text = <"Umiddelbar iverksettelse av forebyggende tiltak">
					description = <"">
					comment = <"Hvis Ja: beskriv kort hvilke tiltak.">
				>
				["at0084"] = <
					text = <"Ingen">
					description = <"">
				>
				["at0085"] = <
					text = <"Ja">
					description = <"For eksempel skjerming, fast vakt, ekstra personale, hyppig tilsyn.">
				>
				["at0086"] = <
					text = <"Forslag til videre voldsrisikovurdering">
					description = <"">
				>
				["at0087"] = <
					text = <"Nei">
					description = <"">
				>
				["at0088"] = <
					text = <"Ja">
					description = <"For eksempel «kartlegging / utredning», «videre voldsrisiko-utredning på institusjonen», «henvisning til second opinion», «bruk av instrumenter» (som BVC, SAVRY), etc.">
				>
				["at0089"] = <
					text = <"*Item tree (en)">
					description = <"@ internal @">
				>
				["at0090"] = <
					text = <"Tilleggsinformasjon">
					description = <"Ytterligere informasjon som trengs for å kunne registrere lokalt definert innhold eller for å tilpasse til andre   referansemodeller eller formalismer.">
					comment = <"For eksempel lokale informasjonsbehov eller ytterligere metadata for å kunne tilpasse til tilsvarende konsepter i FHIR.">
				>
				["at0091"] = <
					text = <"Nei">
					description = <"Passer ikke.">
				>
				["at0092"] = <
					text = <"Moderat">
					description = <"Tilstede i middels alvorlig grad.">
				>
				["at0093"] = <
					text = <"Ja">
					description = <"Passer.">
				>
				["at0094"] = <
					text = <"Vet ikke">
					description = <"For lite informasjon, vil særlig være aktuelt ved første kontakt.">
				>
				["at0139"] = <
					text = <"Lav">
					description = <"">
				>
				["at0140"] = <
					text = <"Moderat">
					description = <"">
				>
				["at0141"] = <
