				["at0041"] = <
					text = <"Moderate">
					description = <"Impulsive, disruptive behaviour that does not cause serious harm or distress; such as ADHD, oppositional behaviour or poor emotional regulation (e.g. self-harm).">
				>
				["at0042"] = <
					text = <"Yes">
					description = <"Behavioural disorders causing serious harm or distress, antisocial behaviour.">
				>
