					description = <"Passer.">
				>
				["at0153"] = <
					text = <"Vet ikke">
					description = <"For lite informasjon, vil særlig være aktuelt ved første kontakt.">
				>
				["at0154"] = <
					text = <"Nei">
					description = <"Passer ikke.">
				>
				["at0155"] = <
					text = <"Moderat">
					description = <"Tilstede i middels alvorlig grad.">
				>
				["at0156"] = <
					text = <"Ja">
					description = <"Passer.">
				>
				["at0157"] = <
