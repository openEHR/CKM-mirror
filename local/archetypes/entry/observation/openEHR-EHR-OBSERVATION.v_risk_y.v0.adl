				["at0025"] = <
					text = <"Moderate">
					description = <"Acts of aggression including kicking, hitting and pushing that do not inflict harm on the victim.">
				>
				["at0026"] = <
					text = <"Yes">
					description = <"Must have performed 3 moderate or 1 serious act of violence.">
				>
