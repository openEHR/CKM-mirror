archetype (adl_version=1.4; uid=d851c3fa-8de6-49f0-80fb-353c6a1852fa)
	openEHR-EHR-OBSERVATION.v_risk_y.v0

concept
	[at0000]	-- V_RISK_Y
language
	original_language = <[ISO_639-1::en]>
	translations = <
		["nb"] = <
			language = <[ISO_639-1::nb]>
			author = <
			>
		>
	>
description
	original_author = <
		["date"] = <"2026-04-01">
	>
	details = <
		["nb"] = <
			language = <[ISO_639-1::nb]>
			purpose = <"For å registrere strukturert vurdering av korttids voldsrisiko hos ungdom i alderen 12–18 år basert på V-RISK-Y sjekkliste, inkludert skåring av individuelle risikofaktorer og samlet klinisk vurdering.">
			use = <"Brukes for å registrere skår for hvert av de 12 leddene i V-RISK-Y samt en samlet klinisk vurdering av voldsrisiko.">
			keywords = <"voldsrisiko, ungdom, risikovurdering, psykisk helsevern, sikkerhetspsykiatri, sjekkliste, skåringsverktøy, risikofaktorer, forebyggende tiltak", ...>
			misuse = <"Brukes ikke for å registrere langsiktig eller prediktiv voldsrisiko utover korttidsvinduet som er definert for V-RISK-Y.">
			copyright = <"© openEHR Foundation">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record a structured assessment of short-term violence risk in adolescents aged 12–18 years based on the V-RISK-Y checklist, including scoring of individual risk factors and an overall clinical assessment.">
			use = <"Used to record scores for each of the 12 items in the V-RISK-Y, as well as an overall clinical assessment of violence risk.

Reference for translation: V-RISK-Y © Revised 21.06.2024. Regional Research and Education Centre for Security, Prisons and Forensic Psychiatry, Oslo University
Hospital, South-Eastern Norway Regional Health Authority.

While openEHR archetypes are all freely available under an open license, the specific content of this V-RISK-Y archetype is copyright protected. Any use of this archetype within implementations must be in compliance with the terms established by the copyright owners. 

Copyright statement: V-RISK-Y © The checklist can be downloaded and used free of charge (no fees). It is not permitted to use V-RISK-Y in a commercial context or to charge someone for using it. The layout can be adapted, for example to fit an electronic hospital record, but the text cannot be changed.

Copyright information: https://www.sifer.no/verktoy/#v-risk-y">
			keywords = <"violence risk, adolescents, risk assessment, mental health services, forensic psychiatry, checklist, scoring tool, risk factors, preventive measures", ...>
			misuse = <"Not to be used to record long-term or predictive violence risk beyond the short-term time frame defined for the V-RISK-Y.">
			copyright = <"© openEHR Foundation">
		>
	>
	lifecycle_state = <"in_development">
	other_contributors = <>
	other_details = <
		["licence"] = <"This work is licensed under the Creative Commons Attribution-ShareAlike 4.0 International License. To view a copy of this license, visit http://creativecommons.org/licenses/by-sa/4.0/.">
		["custodian_organisation"] = <"openEHR Foundation">
		["references"] = <"V-RISK-Y © Revidert 11.01.2024 Regionalt kompetansesenter for sikkerhets-, fengsels- og rettspsykiatri Oslo universitetssykehus, Helse Sør-Øst.">
		["original_namespace"] = <"org.openehr">
		["original_publisher"] = <"openEHR Foundation">
		["custodian_namespace"] = <"org.openehr">
		["MD5-CAM-1.0.1"] = <"16F91F88E8DCD85589C0AB4C876DBFBF">
		["build_uid"] = <"af7dd4f6-e128-4c1f-80c5-1db3c36d1a86">
		["revision"] = <"0.0.1-alpha">
	>

definition
	OBSERVATION[at0000] matches {    -- V_RISK_Y
		data matches {
			HISTORY[at0001] matches {    -- History
				events cardinality matches {1..*; unordered} matches {
					EVENT[at0002] occurrences matches {0..*} matches {    -- Any event
						data matches {
							ITEM_TREE[at0003] matches {    -- Tree
								items cardinality matches {0..*; unordered} matches {
									ELEMENT[at0004] occurrences matches {0..1} matches {    -- 1. Prior and/or current acts of violence
										value matches {
											1|[local::at0024],
											2|[local::at0025],
											3|[local::at0026],
											4|[local::at0027]
										}
									}
									ELEMENT[at0005] occurrences matches {0..1} matches {    -- 2. Prior and/or current threats of violence
										value matches {
											1|[local::at0028],
											2|[local::at0029],
											3|[local::at0030],
											4|[local::at0031]
										}
									}
									ELEMENT[at0006] occurrences matches {0..1} matches {    -- 3. Prior and/or current alcohol or substance abuse
										value matches {
											1|[local::at0032],
											2|[local::at0033],
											3|[local::at0034],
											4|[local::at0035]
										}
									}
									ELEMENT[at0007] occurrences matches {0..1} matches {    -- 4. Prior and/or current severe symptoms of mental health disorders
										value matches {
											1|[local::at0036],
											2|[local::at0037],
											3|[local::at0038],
											4|[local::at0039]
										}
									}
									ELEMENT[at0008] occurrences matches {0..1} matches {    -- 5. Disruptive, impulsive behaviour/behavioural disorder
										value matches {
											1|[local::at0040],
											2|[local::at0041],
											3|[local::at0042],
											4|[local::at0043]
										}
									}
									ELEMENT[at0009] occurrences matches {0..1} matches {    -- 6. Has poor insight into the mental disorder and/or behaviour
										value matches {
											1|[local::at0044],
											2|[local::at0045],
											3|[local::at0046],
											4|[local::at0047]
										}
									}
									ELEMENT[at0010] occurrences matches {0..1} matches {    -- 7. Suspicion
										value matches {
											1|[local::at0048],
											2|[local::at0049],
											3|[local::at0050],
											4|[local::at0051]
										}
									}
									ELEMENT[at0011] occurrences matches {0..1} matches {    -- 8. Demonstrates lack of empathy
										value matches {
											1|[local::at0052],
											2|[local::at0053],
											3|[local::at0054],
											4|[local::at0055]
										}
									}
									ELEMENT[at0012] occurrences matches {0..1} matches {    -- 9. Unrealistic planning
										value matches {
											1|[local::at0056],
											2|[local::at0057],
											3|[local::at0058],
											4|[local::at0059]
										}
									}
									ELEMENT[at0013] occurrences matches {0..1} matches {    -- 10. Future stressful situations
										value matches {
											1|[local::at0060],
											2|[local::at0061],
											3|[local::at0062],
											4|[local::at0063]
										}
									}
									ELEMENT[at0014] occurrences matches {0..1} matches {    -- 11. Prior and/or current severe trauma
										value matches {
											1|[local::at0064],
											2|[local::at0065],
											3|[local::at0066],
											4|[local::at0067]
										}
									}
									ELEMENT[at0015] occurrences matches {0..1} matches {    -- 12. The youth’s and parents/guardians’ own perception of violence risk
										value matches {
											1|[local::at0068],
											2|[local::at0069],
											3|[local::at0070],
											4|[local::at0071]
										}
									}
									ELEMENT[at0016] occurrences matches {0..1} matches {    -- How great do you believe the risk of violence is for this youth?
										value matches {
											1|[local::at0019],
											2|[local::at0020],
											3|[local::at0021]
										}
									}
									CLUSTER[at0078] occurrences matches {0..1} matches {    -- Immediate implementation of preventive measures
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0083] occurrences matches {0..1} matches {    -- Immediate implementation of preventive measures
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0084,    -- No
															at0085]    -- Yes
														}
													}
												}
											}
											ELEMENT[at0081] occurrences matches {0..1} matches {    -- Description of measures
												value matches {
													DV_TEXT matches {*}
												}
											}
										}
									}
									CLUSTER[at0080] occurrences matches {0..1} matches {    -- Suggestions for additional violence risk assessments
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0086] occurrences matches {0..1} matches {    -- Suggestions for additional violence risk assessments
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0087,    -- No
															at0088]    -- Yes
														}
													}
												}
											}
											ELEMENT[at0082] occurrences matches {0..1} matches {    -- Description of measures
												value matches {
													DV_TEXT matches {*}
												}
											}
										}
									}
								}
							}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0089] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					allow_archetype CLUSTER[at0090] occurrences matches {0..*} matches {    -- Extension
						include
							archetype_id/value matches {/.*/}
					}
				}
			}
		}
	}


ontology
	term_definitions = <
		["nb"] = <
			items = <
				["at0000"] = <
					text = <"V_RISK_Y">
					description = <"V-RISK-Y er et strukturert verktøy for vurdering av voldsrisiko blant ungdom i alderen 12–18 år. Verktøyet er utviklet for bruk ved første kontakt med ungdommen, og gir grunnlag for å vurdere behovet for umiddelbare tiltak og videre risikovurdering. ">
				>
				["at0001"] = <
					text = <"History">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Uspesifisert hendelse">
					description = <"@ internal @">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"1. Tidligere og/eller aktuell vold">
					description = <"Alvorlig vold: Fysiske angrep (inkludert ulike våpen, brann) for å påføre alvorlig fysisk skade mot annen person.

Definisjon av vold: Atferd innrettet på (intensjon) å påføre et annet menneske kroppslig smerte, skade eller krenkelse.">
				>
				["at0005"] = <
					text = <"2. Tidligere og/eller aktuelle trusler om vold">
					description = <"En verbal voldstrussel: Rop, utsagn eller skriftlig (inkludert sosiale medier) som truer med å utøve vold mot et annet menneske. 

En fysisk voldstrussel er å vise angrepsforberedende atferd f.eks. å true med knyttneve, eller annen fysisk atferd som signaliserer fysisk angrep. Å ødelegge gjenstander er ikke voldsatferd, men kan i noen situasjoner oppfattes som en trussel (fysisk trussel vil ofte gi høyere risiko enn verbal trussel).">
				>
				["at0006"] = <
					text = <"3. Tidligere og/eller aktuell rusbruk">
					description = <"">
				>
				["at0007"] = <
					text = <"4. Tidligere og/eller aktuelle alvorlige psykiske symptomer">
					description = <"Ungdommen har merkelig eller upassende atferd og/eller forestillinger som ikke samsvarer med utviklingsmessig alder, og hvor det kommer fram en sviktende realitetsforståelse. Dette kan være uttrykk for angstlidelser, depresjoner, autismespekter lidelser, lidelser/ symptomer med realitetsbrist, eller tilsvarende.">
				>
				["at0008"] = <
					text = <"5. Forstyrrende, impulsiv atferd/atferdsforstyrrelser">
					description = <"">
				>
				["at0009"] = <
					text = <"6. Mangler innsikt i sykdom og/eller atferd">
					description = <"Her menes i hvilken grad ungdommen eller foresatte mangler innsikt i ungdommens psykiske lidelse. Herunder behandling, sosiale konsekvenser, eller atferd knyttet til sykdom eller utviklings- / personlighetsforstyrrelser. For yngre ungdommer vil foresattes innsikt være viktigst, for eldre ungdommer vil ungdommens egen innsikt være viktigst.">
				>
				["at0010"] = <
					text = <"7. Mistenksomhet">
					description = <"Ungdommen gir uttrykk for mistenksomhet overfor andre personer enten verbalt eller nonverbalt. Vedkommende ser ut til å være «på vakt» overfor omgivelsene.">
				>
				["at0011"] = <
					text = <"8. Viser manglende innlevelse (empati)">
					description = <"Ungdommen uttrykker følelseskald atferd uten innlevelse i andres tankemessige eller følelsesmessige situasjon.">
				>
				["at0012"] = <
					text = <"9. Urealistisk planlegging">
					description = <"Her måles i hvilken grad ungdommen selv eller foresatte har urealistiske behandlingsplaner / andre viktige planer for fremtiden. Er f.eks. ungdommen /foresatte realistiske i forhold til hva han/hun trenger av støtte, og hva som kan forventes av støtte fra familie og av profesjonelt og sosialt nettverk. Det er viktig å vurdere om foresatte og ungdommen er samarbeidsvillige og motiverte til å følge planene videre. For yngre ungdommer vil foresattes planer være viktigst, for eldre ungdommer vil egne planer være viktigst.">
				>
				["at0013"] = <
					text = <"10. Framtidige stress-situasjoner">
					description = <"Her undersøkes muligheten for at ungdommen kan bli utsatt for påkjenninger og belastende situasjoner i fremtiden, og hans/hennes evne til stressmestring.

I dette leddet inngår om foresatte kan være en støtte for ungdommen mht stressmestring, om det foreligger konflikt mellom ungdommen og foresatte, om foresatte har antisosial livsstil / holdninger, og tiltrekning til voldelige miljø som ekstremistiske sympatisører, f.eks. radikale islamister eller høyreradikale.

Eksempler: Mestringssvikt overfor grensesetting, nærhet til mulige voldsofre, rusing, eksponering for voldelig miljø etc.">
				>
				["at0014"] = <
					text = <"11. Tidligere og/eller alvorlig pågående traume">
					description = <"Har ungdommen vært utsatt for / vært vitne til et alvorlig traume, vært utsatt for / vært vitne til gjentatte fysiske / seksuelle / psykiske overgrep, vært utsatt for omsorgssvikt.">
				>
				["at0015"] = <
					text = <"12. Ungdommens og foresattes oppfatning av risiko">
					description = <"I hvilken grad ungdommen eller de foresatte oppfatter at det er risiko for vold.">
				>
				["at0016"] = <
					text = <"Hvor stor tror du voldsrisikoen er for denne pasienten?">
					description = <"Samlet klinisk vurdering og iverksettelse av tiltak basert på V-RISK-Y, individuell klinisk vurdering, og annen tilgjengelig informasjon. ">
					comment = <"OBS: «Vet ikke» skåre indikerer signifikant høyere risiko enn «Nei» skåre.">
				>
				["at0019"] = <
					text = <"Lav">
					description = <"">
				>
				["at0020"] = <
					text = <"Moderat">
					description = <"">
				>
				["at0021"] = <
					text = <"Høy">
					description = <"">
				>
				["at0024"] = <
					text = <"Nei">
					description = <"">
				>
				["at0025"] = <
					text = <"Moderat">
					description = <"Aggresjonshandlinger som spark, slag og dytting som ikke forårsaker skade hos offeret.">
				>
				["at0026"] = <
					text = <"Ja">
					description = <"Må ha gjort minst 3 moderate eller 1 alvorlig voldshandling.">
				>
				["at0027"] = <
					text = <"Vet ikke">
					description = <"">
				>
				["at0028"] = <
					text = <"Nei">
					description = <"">
				>
				["at0029"] = <
					text = <"Moderat">
					description = <"">
				>
				["at0030"] = <
					text = <"Ja">
					description = <"">
				>
				["at0031"] = <
					text = <"Vet ikke">
					description = <"">
				>
				["at0032"] = <
					text = <"Nei">
					description = <"">
				>
				["at0033"] = <
					text = <"Moderat">
					description = <"Ungdommen har en historie med misbruk av alkohol, medikamenter, narkotiske stoffer eller løsemidler.">
				>
				["at0034"] = <
					text = <"Ja">
					description = <"Ungdommen har eller har hatt omfattende misbruk/ avhengighet, med nedsatt helse eller funksjon i skole-, arbeids- eller fritidsliv.">
				>
				["at0035"] = <
					text = <"Vet ikke">
					description = <"">
				>
				["at0036"] = <
					text = <"Nei">
					description = <"">
				>
				["at0037"] = <
					text = <"Kanskje">
					description = <"Atferd og forestillinger som gir mistanke om avvik, se beskrivelse.">
				>
				["at0038"] = <
					text = <"Ja">
					description = <"Åpenbar og tydelig avvikende atferd og forestillinger som anført i beskrivelse.">
				>
				["at0039"] = <
					text = <"Vet ikke">
					description = <"">
				>
				["at0040"] = <
					text = <"Nei">
					description = <"">
				>
				["at0041"] = <
					text = <"Moderat">
					description = <"Impulsiv, forstyrrende atferd som ikke forårsaker alvorlig skade eller ubehag; ADHD, opposisjonell atferd eller dårlig emosjonell regulering (f.eks. selvskading).">
				>
				["at0042"] = <
					text = <"Ja">
					description = <"Atferdsforstyrrelser (forårsaker alvorlig skade eller ubehag), antisosial atferd.">
				>
				["at0043"] = <
					text = <"Vet ikke">
					description = <"">
				>
				["at0044"] = <
					text = <"Nei">
					description = <"">
				>
				["at0045"] = <
					text = <"Moderat">
					description = <"Enten ungdommen eller foresatte mangler innsikt.">
				>
				["at0046"] = <
					text = <"Ja">
					description = <"Både ungdommen og foresatte, eller ungdom 16-18 år, mangler innsikt.">
				>
				["at0047"] = <
					text = <"Vet ikke">
					description = <"">
				>
				["at0048"] = <
					text = <"Nei">
					description = <"">
				>
				["at0049"] = <
					text = <"Moderat">
					description = <"">
				>
				["at0050"] = <
					text = <"Ja">
					description = <"">
				>
				["at0051"] = <
					text = <"Vet ikke">
					description = <"">
				>
				["at0052"] = <
					text = <"Nei">
					description = <"">
				>
				["at0053"] = <
					text = <"Moderat">
					description = <"">
				>
				["at0054"] = <
					text = <"Ja">
					description = <"">
				>
				["at0055"] = <
					text = <"Vet ikke">
					description = <"">
				>
				["at0056"] = <
					text = <"Nei">
					description = <"">
				>
				["at0057"] = <
					text = <"Moderat">
					description = <"Enten ungdommen eller foresatte mangler realistiske planer.">
				>
				["at0058"] = <
					text = <"Ja">
					description = <"Både ungdommen og foresatte, eller ungdom 16-18 år, mangler realistiske planer.">
				>
				["at0059"] = <
					text = <"Vet ikke">
					description = <"">
				>
				["at0060"] = <
					text = <"Nei">
					description = <"">
				>
				["at0061"] = <
					text = <"Moderat">
					description = <"">
				>
				["at0062"] = <
					text = <"Ja">
					description = <"">
				>
				["at0063"] = <
					text = <"Vet ikke">
					description = <"">
				>
				["at0064"] = <
					text = <"Nei">
					description = <"">
				>
				["at0065"] = <
					text = <"Kanskje">
					description = <"">
				>
				["at0066"] = <
					text = <"Ja">
					description = <"">
				>
				["at0067"] = <
					text = <"Vet ikke">
					description = <"">
				>
				["at0068"] = <
					text = <"Nei">
					description = <"">
				>
				["at0069"] = <
					text = <"Kanskje">
					description = <"Ungdommen eller de foresatte oppfatter at det er litt forhøyet risiko for vold.">
				>
				["at0070"] = <
					text = <"Ja">
					description = <"Ungdommen eller de foresatte oppfatter enten moderat / høy voldsrisiko eller vil ikke svare.">
				>
				["at0071"] = <
					text = <"Vet ikke">
					description = <"">
				>
				["at0078"] = <
					text = <"Umiddelbar iverksettelse av forebyggende tiltak">
					description = <"">
				>
				["at0080"] = <
					text = <"Forslag til videre voldsrisikovurdering">
					description = <"Hvis Ja: beskriv kort hvilke tiltak, for eksempel ved mange «Vet ikke» skåringer, uklar situasjon, ukjent ungdom, tydelig behov for voldsrisikovurdering, etc.">
				>
				["at0081"] = <
					text = <"Beskrivelse av tiltak">
					description = <"">
				>
				["at0082"] = <
					text = <"Beskrivelse av tiltak">
					description = <"">
				>
				["at0083"] = <
					text = <"Umiddelbar iverksettelse av forebyggende tiltak">
					description = <"">
					comment = <"Hvis Ja: beskriv kort hvilke tiltak.">
				>
				["at0084"] = <
					text = <"Ingen">
					description = <"">
				>
				["at0085"] = <
					text = <"Ja">
					description = <"For eksempel skjerming, fast vakt, ekstra personale, hyppig tilsyn.">
				>
				["at0086"] = <
					text = <"Forslag til videre voldsrisikovurdering">
					description = <"">
				>
				["at0087"] = <
					text = <"Nei">
					description = <"">
				>
				["at0088"] = <
					text = <"Ja">
					description = <"For eksempel «kartlegging / utredning», «videre voldsrisiko-utredning på institusjonen», «henvisning til second opinion», «bruk av instrumenter» (som BVC, SAVRY), etc.">
				>
				["at0089"] = <
					text = <"*Item tree (en)">
					description = <"@ internal @">
				>
				["at0090"] = <
					text = <"Tilleggsinformasjon">
					description = <"Ytterligere informasjon som trengs for å kunne registrere lokalt definert innhold eller for å tilpasse til andre   referansemodeller eller formalismer.">
					comment = <"For eksempel lokale informasjonsbehov eller ytterligere metadata for å kunne tilpasse til tilsvarende konsepter i FHIR.">
				>
			>
		>
		["en"] = <
			items = <
				["at0000"] = <
					text = <"V_RISK_Y">
					description = <"V-RISK-Y is a structured tool for assessing the risk of violence among adolescents aged 12–18 years. The tool is designed for use at first contact with the youth and provides a basis for evaluating the need for immediate measures and further risk assessment.">
				>
				["at0001"] = <
					text = <"History">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Any event">
					description = <"@ internal @">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"1. Prior and/or current acts of violence">
					description = <"*Alvorlig vold: Fysiske angrep (inkludert ulike våpen, brann) for å påføre alvorlig fysisk skade mot annen person.

Definisjon av vold: Atferd innrettet på (intensjon) å påføre et annet menneske kroppslig smerte, skade eller krenkelse. (nb)">
				>
				["at0005"] = <
					text = <"2. Prior and/or current threats of violence">
					description = <"*En verbal voldstrussel: Rop, utsagn eller skriftlig (inkludert sosiale medier) som truer med å utøve vold mot et annet menneske. 

En fysisk voldstrussel er å vise angrepsforberedende atferd f.eks. å true med knyttneve, eller annen fysisk atferd som signaliserer fysisk angrep. Å ødelegge gjenstander er ikke voldsatferd, men kan i noen situasjoner oppfattes som en trussel (fysisk trussel vil ofte gi høyere risiko enn verbal trussel). (nb)">
				>
				["at0006"] = <
					text = <"3. Prior and/or current alcohol or substance abuse">
					description = <"">
				>
				["at0007"] = <
					text = <"4. Prior and/or current severe symptoms of mental health disorders">
					description = <"*Ungdommen har merkelig eller upassende atferd og/eller forestillinger som ikke samsvarer med utviklingsmessig alder, og hvor det kommer fram en sviktende realitetsforståelse. Dette kan være uttrykk for angstlidelser, depresjoner, autismespekter lidelser, lidelser/ symptomer med realitetsbrist, eller tilsvarende. (nb)">
				>
				["at0008"] = <
					text = <"5. Disruptive, impulsive behaviour/behavioural disorder">
					description = <"">
				>
				["at0009"] = <
					text = <"6. Has poor insight into the mental disorder and/or behaviour">
					description = <"*Her menes i hvilken grad ungdommen eller foresatte mangler innsikt i ungdommens psykiske lidelse. Herunder behandling, sosiale konsekvenser, eller atferd knyttet til sykdom eller utviklings- / personlighetsforstyrrelser. For yngre ungdommer vil foresattes innsikt være viktigst, for eldre ungdommer vil ungdommens egen innsikt være viktigst. (nb)">
				>
				["at0010"] = <
					text = <"7. Suspicion">
					description = <"*Ungdommen gir uttrykk for mistenksomhet overfor andre personer enten verbalt eller nonverbalt. Vedkommende ser ut til å være «på vakt» overfor omgivelsene. (nb)">
				>
				["at0011"] = <
					text = <"8. Demonstrates lack of empathy">
					description = <"*Ungdommen uttrykker følelseskald atferd uten innlevelse i andres tankemessige eller følelsesmessige situasjon. (nb)">
				>
				["at0012"] = <
					text = <"9. Unrealistic planning">
					description = <"*Her måles i hvilken grad ungdommen selv eller foresatte har urealistiske behandlingsplaner / andre viktige planer for fremtiden. Er f.eks. ungdommen /foresatte realistiske i forhold til hva han/hun trenger av støtte, og hva som kan forventes av støtte fra familie og av profesjonelt og sosialt nettverk. Det er viktig å vurdere om foresatte og ungdommen er samarbeidsvillige og motiverte til å følge planene videre. For yngre ungdommer vil foresattes planer være viktigst, for eldre ungdommer vil egne planer være viktigst. (nb)">
				>
				["at0013"] = <
					text = <"10. Future stressful situations">
					description = <"*Her undersøkes muligheten for at ungdommen kan bli utsatt for påkjenninger og belastende situasjoner i fremtiden, og hans/hennes evne til stressmestring.

I dette leddet inngår om foresatte kan være en støtte for ungdommen mht stressmestring, om det foreligger konflikt mellom ungdommen og foresatte, om foresatte har antisosial livsstil / holdninger, og tiltrekning til voldelige miljø som ekstremistiske sympatisører, f.eks. radikale islamister eller høyreradikale.

Eksempler: Mestringssvikt overfor grensesetting, nærhet til mulige voldsofre, rusing, eksponering for voldelig miljø etc. (nb)">
				>
				["at0014"] = <
					text = <"11. Prior and/or current severe trauma">
					description = <"*Har ungdommen vært utsatt for / vært vitne til et alvorlig traume, vært utsatt for / vært vitne til gjentatte fysiske / seksuelle / psykiske overgrep, vært utsatt for omsorgssvikt. (nb)">
				>
				["at0015"] = <
					text = <"12. The youth’s and parents/guardians’ own perception of violence risk">
					description = <"*I hvilken grad ungdommen eller de foresatte oppfatter at det er risiko for vold. (nb)">
				>
				["at0016"] = <
					text = <"How great do you believe the risk of violence is for this youth?">
					description = <"*Samlet klinisk vurdering og iverksettelse av tiltak basert på V-RISK-Y, individuell klinisk vurdering, og annen tilgjengelig informasjon.  (nb)">
					comment = <"*OBS: «Vet ikke» skåre indikerer signifikant høyere risiko enn «Nei» skåre. (nb)">
				>
				["at0019"] = <
					text = <"Low">
					description = <"">
				>
				["at0020"] = <
					text = <"Moderate">
					description = <"">
				>
