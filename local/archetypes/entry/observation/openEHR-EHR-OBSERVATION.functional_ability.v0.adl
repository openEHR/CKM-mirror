definition
	OBSERVATION[at0000] matches {    -- Functional ability
		data matches {
			HISTORY[at0001] matches {    -- History
				events cardinality matches {1..*; unordered} matches {
					EVENT[at0002] occurrences matches {0..*} matches {    -- Any event
						data matches {
							ITEM_TREE[at0003] matches {    -- Tree
								items cardinality matches {0..*; unordered} matches {
									ELEMENT[at0004] matches {    -- Activity name
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0005] occurrences matches {0..1} matches {    -- Ability
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0017,    -- Able
													at0018,    -- Partially able
													at0019]    -- Unable
												}
											}
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0006] occurrences matches {0..1} matches {    -- Clinical description
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0007] occurrences matches {0..1} matches {    -- Difficulty
										value matches {
											DV_TEXT matches {*}
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0022,    -- No difficulty
													at0023,    -- Mild difficulty
													at0024,    -- Moderate difficulty
													at0025]    -- Severe difficulty
												}
											}
										}
									}
									ELEMENT[at0008] occurrences matches {0..1} matches {    -- Reason for difficulty
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0010] occurrences matches {0..1} matches {    -- Comment
										value matches {
											DV_TEXT matches {*}
										}
									}
								}
							}
						}
						state matches {
							ITEM_TREE[at0013] matches {    -- Item tree
								items cardinality matches {0..*; unordered} matches {
									ELEMENT[at0014] occurrences matches {0..1} matches {    -- Assessment conditions description
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0029] occurrences matches {0..1} matches {    -- Assistive devices description
										value matches {
											DV_TEXT matches {*}
										}
									}
									allow_archetype CLUSTER[at0015] occurrences matches {0..*} matches {    -- Assistive device
										include
											archetype_id/value matches {/openEHR-EHR-CLUSTER\.device(-[a-zA-Z0-9_]+)*\.v1/}
									}
									ELEMENT[at0030] occurrences matches {0..*} matches {    -- Confounding factors
										value matches {
											DV_TEXT matches {*}
										}
									}
								}
							}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0012] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					allow_archetype CLUSTER[at0016] occurrences matches {0..*} matches {    -- Extension
						include
							archetype_id/value matches {/.*/}
					}
				}
			}
		}
	}


ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Functional ability">
					description = <"An assessment of an individual’s ability to perform an activity safely and consistently without human assistance.">
					comment = <"Throughout this archetype, the phrase ‘perform an activity’, or similar, refers to carrying out a single activity or a grouping of related activities, or participating in an everyday life situation.
">
				>
				["at0001"] = <
					text = <"History">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Any event">
					description = <"Default, unspecified point-in-time or interval event which may be explicitly defined in a template or at run-time.">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"Activity name">
					description = <"The name of the activity being assessed.">
					comment = <"Coding with an external terminology is recommended. Free text entry should only be permitted where no appropriate coded value is available. For example: rolling over in bed, transferring from bed to chair, walking; climbing stairs; brushing teeth, putting on shoes, menstrual care; reading, speaking, writing; preparing meals, doing housework; using public transport, seeking a job withdraw money from an ATM; attending school, play sport, join a club, attend the theatre.">
				>
				["at0005"] = <
					text = <"Ability">
					description = <"The assessed ability to perform the identified activity independently.">
					comment = <"Coding with a terminology is recommended.  Free text entry should only be permitted if no appropriate coded value is available.
An individual may be able to independently perform the activity and still experience difficulty. The degree of difficulty is recorded separately using the ‘Difficulty’ data element. 
‘Ability’ and ‘Difficulty’ represent complementary components of the functional ability assessment. Recording a value for ‘Difficulty’ is not applicable where ‘Ability’ has been recorded as ‘Unable’.">
				>
				["at0006"] = <
					text = <"Clinical description">
					description = <"Narrative description of the individual's assessed ability to independently perform the identified activity.">
					comment = <"For example: problems completing the activity, safety concerns, or consistency issues.">
				>
				["at0007"] = <
					text = <"Difficulty">
					description = <"The degree of difficulty experienced by the individual when performing the activity independently.">
					comment = <"Coding with a terminology is recommended.  Free text entry should only be permitted if no appropriate coded value is available.
Difficulty may be self-reported and/or clinically observed during the assessment.
Increased time or effort beyond that typically required to independently perform the activity may indicate difficulty, even where assistive devices are used.
Any degree of difficulty may affect the completeness, safety, or consistency of performance of the activity.
Recording the degree of difficulty may support assessment of functional support or adaptation requirements.
‘Ability’ and ‘Difficulty’ represent complementary components of the functional ability assessment. Recording a value for ‘Difficulty’ is not applicable where ‘Ability’ has previously been recorded as ‘Unable’.
">
				>
				["at0008"] = <
					text = <"Reason for difficulty">
					description = <"Narrative description of the factors contributing to difficulty performing the activity.">
					comment = <"For example: impairment, symptoms, environmental or contextual barriers, equipment availability, communication issues, training, or other relevant circumstances.">
				>
				["at0010"] = <
					text = <"Comment">
					description = <"Additional narrative about the performance of the activity, not captured in other fields.">
				>
				["at0012"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0013"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0014"] = <
					text = <"Assessment conditions description">
					description = <"Narrative description of the circumstances under which an assessment is performed, to support interpretation of the observed assessment results.">
					comment = <"For example: describing the environment, method, or situation in which the assessment was carried out. This may include whether the assessment occurred in a clinic, hospital, or home setting; whether the individual was in their usual or an unfamiliar environment; any specific conditions that may influence performance, such as noise, lighting, and time of day; use of an unfamiliar assistive device for the assessment; and adherence to or deviation from a defined assessment protocol.">
				>
				["at0015"] = <
					text = <"Assistive device">
					description = <"Structured detail about one or more tools, aids, or technologies used by an individual while performing the activity.">
					comment = <"For example: smartphone reminders, modified cutlery, reading glasses, hearing aids, mobility aids, prostheses, self-care aids, communication aids, or an assistance animal.">
				>
				["at0016"] = <
					text = <"Extension">
					description = <"Additional information required to extend the model with local content or to align with other reference models or formalisms.">
					comment = <"For example: local information requirements; or additional metadata to align with FHIR.">
				>
				["at0017"] = <
					text = <"Able">
					description = <"The individual can independently perform the entire activity at the time of assessment.">
				>
				["at0018"] = <
					text = <"Partially able">
					description = <"The individual can independently perform part, but not all, of the activity at the time of assessment.">
				>
				["at0019"] = <
					text = <"Unable">
					description = <"The individual cannot independently perform any part of the activity at the time of assessment.">
				>
				["at0022"] = <
					text = <"No difficulty">
					description = <"The individual experiences no difficulty when performing the activity.">
				>
				["at0023"] = <
					text = <"Mild difficulty">
					description = <"The individual experiences a low degree of difficulty when performing the activity.">
				>
				["at0024"] = <
					text = <"Moderate difficulty">
					description = <"The individual experiences a significant degree of difficulty when performing the activity.">
				>
				["at0025"] = <
					text = <"Severe difficulty">
					description = <"The individual experiences a high degree of difficulty when performing the activity.">
				>
				["at0029"] = <
					text = <"Assistive devices description">
					description = <"Narrative description about any tools, aids, or technologies used by the individual while performing the activity.">
					comment = <"For example: smartphone reminders, modified cutlery, reading glasses, hearing aids, mobility aids, prostheses, self-care aids, communication aids, or an assistance animal.">
				>
				["at0030"] = <
					text = <"Confounding factors">
					description = <"Issues or contextual factors that may impact on functional ability, not captured in other fields.">
					comment = <"For example: fatigue, diurnal variation, recent exertion, medication effect, sleep status, mood, situational anxiety.">
				>
			>
		>
	>
