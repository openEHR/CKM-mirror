	>

definition
	OBSERVATION[at0000] matches {    -- Functional ability
		data matches {
			HISTORY[at0001] matches {    -- History
				events cardinality matches {1..*; unordered} matches {
					EVENT[at0002] occurrences matches {0..*} matches {    -- Any event
						data matches {
							ITEM_TREE[at0003] matches {    -- Tree
								items cardinality matches {0..*; unordered} matches {
									ELEMENT[at0004] matches {    -- Activity name
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0005] occurrences matches {0..1} matches {    -- Ability level
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0017,    -- Able
													at0018,    -- Partially able
													at0019]    -- Unable
												}
											}
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0006] occurrences matches {0..1} matches {    -- Clinical description
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0007] occurrences matches {0..1} matches {    -- Difficulty level
										value matches {
											DV_TEXT matches {*}
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0022,    -- No difficulty
													at0023,    -- Mild difficulty
													at0024,    -- Moderate difficulty
													at0025]    -- Severe difficulty
												}
											}
										}
									}
									ELEMENT[at0008] occurrences matches {0..1} matches {    -- Reason for difficulty
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0010] occurrences matches {0..1} matches {    -- Comment
										value matches {
											DV_TEXT matches {*}
										}
									}
								}
							}
						}
						state matches {
							ITEM_TREE[at0013] matches {    -- Item tree
								items cardinality matches {0..*; unordered} matches {
									ELEMENT[at0014] occurrences matches {0..1} matches {    -- Assessment conditions
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0029] occurrences matches {0..1} matches {    -- Assistive devices description
										value matches {
											DV_TEXT matches {*}
										}
									}
									allow_archetype CLUSTER[at0015] occurrences matches {0..*} matches {    -- Assistive device details
										include
											archetype_id/value matches {/openEHR-EHR-CLUSTER\.device(-[a-zA-Z0-9_]+)*\.v1/}
									}
								}
							}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0012] matches {    -- Item tree
				items cardinality matches {0..*; unordered} matches {
					allow_archetype CLUSTER[at0016] occurrences matches {0..*} matches {    -- Extension
						include
							archetype_id/value matches {/.*/}
					}
				}
			}
		}
	}


ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Functional ability">
					description = <"An assessment of an individual’s ability to perform an activity independently at a specific point in time.">
					comment = <"Throughout this archetype, the phrase ‘perform an activity’, or similar, refers to carrying out a single activity or a grouping of related activities, or participating in an everyday life situation.
">
				>
				["at0001"] = <
					text = <"History">
					description = <"@ internal @">
				>
				["at0002"] = <
					text = <"Any event">
					description = <"Default, unspecified point-in-time or interval event which may be explicitly defined in a template or at run-time.">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0004"] = <
					text = <"Activity name">
					description = <"The activity being assessed.">
					comment = <"Coding with an external terminology is recommended. Free text entry should only be permitted where no appropriate coded value is available. For example: Mobility – roll over in bed, transfer from bed to chair, walk upstairs; Self-care – brush teeth, put on footwear, menstrual care; Communication – read, speak, write; Domestic life – shop for food, clean the kitchen, wash clothes; Attending work or school – use public transport, seek a job; Community participation – play sport, join a club, attend the theatre.">
				>
				["at0005"] = <
					text = <"Ability level">
					description = <"The assessed level at which the individual can perform the activity without supervision or assistance from another person.">
					comment = <"An individual may be able to perform the activity independently while still experiencing substantial difficulty. The degree of difficulty experienced when performing the activity independently is recorded separately using the 'Difficulty level'. Coding with an external terminology is recommended.  Free text entry should only be permitted if no appropriate coded value is available. Note: Ability and difficulty represent complementary assessments of the individual's performance of the activity.">
				>
				["at0006"] = <
					text = <"Clinical description">
					description = <"Narrative description of the individual's ability to perform the activity.">
				>
				["at0007"] = <
					text = <"Difficulty level">
					description = <"The degree of difficulty experienced by the individual when performing the activity independently.">
					comment = <"Difficulty may be present even when the individual is able to perform the activity completely independently and may indicate a need for increased functional support or adaptation. Coding with an external terminology is recommended.  Free text entry should only be permitted if no appropriate coded value is available.">
				>
				["at0008"] = <
					text = <"Reason for difficulty">
					description = <"Narrative description of the factors contributing to the difficulty experienced when performing the activity.">
				>
				["at0010"] = <
					text = <"Comment">
					description = <"Additional narrative about the individual's performance of the activity not captured in other fields..">
				>
				["at0012"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0013"] = <
					text = <"Item tree">
					description = <"@ internal @">
				>
				["at0014"] = <
					text = <"Assessment conditions">
					description = <"Narrative description of the circumstances under which an assessment is performed, to support interpretation of the observed assessment results.">
					comment = <"For example: describing the environment, method, or situation in which the assessment was carried out.">
				>
				["at0015"] = <
					text = <"Assistive device details">
					description = <"Structured detail about one or more assistive devices used by the individual while performing the activity.">
					comment = <"For example: modified cutlery, a motorised wheelchair or a support animal.">
				>
				["at0016"] = <
					text = <"Extension">
					description = <"Additional information required to extend the model with local content or to align with other reference models or formalisms.">
					comment = <"For example: local information requirements; or additional metadata to align with FHIR.">
				>
				["at0017"] = <
					text = <"Able">
					description = <"The individual can perform the activity.">
				>
				["at0018"] = <
					text = <"Partially able">
					description = <"The individual can perform the activity to a limited extent.">
				>
				["at0019"] = <
					text = <"Unable">
					description = <"The individual cannot perform the activity.">
				>
				["at0022"] = <
					text = <"No difficulty">
					description = <"The individual experiences no difficulty when performing the activity.">
				>
				["at0023"] = <
					text = <"Mild difficulty">
					description = <"The individual experiences a low degree of difficulty when performing the activity.">
				>
				["at0024"] = <
					text = <"Moderate difficulty">
					description = <"The individual experiences a significant degree of difficulty when performing the activity.">
				>
				["at0025"] = <
					text = <"Severe difficulty">
					description = <"The individual experiences a high degree of difficulty when performing the activity.">
				>
				["at0029"] = <
					text = <"Assistive devices description">
					description = <"Narrative description about the assistive devices in use.">
					comment = <"For example: modified cutlery, a motorised wheelchair or a support animal.">
				>
			>
		>
	>
