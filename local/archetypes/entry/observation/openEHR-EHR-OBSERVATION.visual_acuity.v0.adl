				["at0585"] = <
					text = <"J20">
					description = <"Jaeger font size 20.">
				>
				["at0586"] = <
					text = <"Perceptual task">
					description = <"The type of perceptual task endpoint that the result represents.">
					comment = <"Reading visual acuity expressed LogMAR is sometimes referred to as LogRAD. 
Supplementary results of reading visual acuity tests can be recorded via the 'supplementary results' slot. ">
				>
				["at0587"] = <
					text = <"Minimum resolvable visual acuity">
					description = <"A measurement of the ability to distinguish two separate objects as distinct.">
				>
				["at0588"] = <
					text = <"Reading visual acuity">
					description = <"A measurement of the smallest visual angle at which text can be read.">
				>
				["at0589"] = <
					text = <"Light adaptation state">
					description = <"The presumed adaptation state of the visual system during testing.">
					comment = <"This is a categorical description of the individual's presumed retinal adaptation state, not a measurement of the ambient lighting.">
				>
				["at0590"] = <
					text = <"Photopic">
					description = <"The individual is adapted to high luminance conditions.">
				>
				["at0591"] = <
					text = <"Mesopic">
					description = <"The individual is in a transitional adaptation state between photopic and scotopic.">
				>
				["at0592"] = <
					text = <"Scotopic">
					description = <"The individual is adapted to low luminance conditions.">
				>
				["at0593"] = <
					text = <"N 7">
					description = <"N font size 7.">
				>
				["at0594"] = <
					text = <"No light perception">
					description = <"The individual was unable to identify the absence or presence of light.">
				>
				["at0595"] = <
					text = <"Light perception">
					description = <"The individual correctly identified the absence or presence of light.">
				>
				["at0596"] = <
					text = <"Hand Movement">
					description = <"The individual perceived hand movements.">
				>
				["at0597"] = <
					text = <"Count Fingers">
					description = <"The individual correctly counted fingers.">
				>
			>
		>
		["es-cl"] = <
			items = <
				["at0000"] = <
					text = <"*Visual acuity test (en)">
					description = <"*A test to quantify an individual's visual acuity, as a measure of the ability to discern small visual differences. (en)">
				>
				["at0001"] = <
					text = <"Event Series">
					description = <"@ internal @">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0007"] = <
					text = <"*Eye examined (en)">
					description = <"*The eye which is being examined, or both eyes in case of a binocular test. (en)">
					comment = <"*'Both eyes' may only be used for test of binocular visual acuity. (en)">
				>
				["at0012"] = <
					text = <"*Left eye(en)">
					description = <"*The left eye was examined. (en)">
				>
				["at0013"] = <
					text = <"*Right eye(en)">
					description = <"*The right eye was examined. (en)">
				>
				["at0014"] = <
					text = <"*Both eyes (en)">
					description = <"*Both eyes were examined simultaneously. (en)">
				>
				["at0020"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0021"] = <
					text = <"*Optotype (en)">
					description = <"*The type of symbol used to assess visual acuity. (en)">
					comment = <"*Coding with a terminology is recommended. Free text entry should only be permitted if no appropriate coded value is available. (en)">
				>
				["at0023"] = <
					text = <"*Chart or card type (en)">
					description = <"*The type of chart or card used to measure visual acuity. (en)">
					comment = <"*Coding with a terminology is recommended. Free text entry should only be permitted if no appropriate coded value is available. (en)">
				>
				["at0025"] = <
					text = <"*Chart or stimulus device details (en)">
					description = <"*Details of the devices used provide a stimulus to be resolved by the eye being tested, such as a chart, projector or digital display. (en)">
				>
				["at0040"] = <
					text = <"*Comment(en)">
					description = <"*Narrative comment about the visual acuity test. (en)">
					comment = <"*It is a common but controversial practice to comment \"partial\" where the last line was not read entirely even in line-based scoring. This is covered by the \"Letters missed or read in addition to scored line\" element. (en)">
				>
				["at0041"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0081"] = <
					text = <"*Testing distance category (en)">
					description = <"*A categorisation of the testing distance. (en)">
					comment = <"*Boundary definitions may vary, therefore population of the  'Testing distance' element is encouraged, especially for intermediate or near distances. (en)">
				>
				["at0082"] = <
					text = <"*logMAR chart (en)">
					description = <"*A logMAR chart was used. (en)">
				>
				["at0083"] = <
					text = <"*Snellen chart(en)">
					description = <"*A Snellen chart was used. (en)">
				>
				["at0084"] = <
					text = <"*ETDRS chart (en)">
					description = <"*An ETDRS chart was used. (en)">
				>
				["at0106"] = <
					text = <"*Letters (en)">
					description = <"*Letter optotypes were used (en)">
				>
				["at0107"] = <
					text = <"*Orientation-Type Optotypes (en)">
					description = <"*Orientation-Type optotypes were used (en)">
				>
				["at0108"] = <
					text = <"*Pictograms (en)">
					description = <"*Pictogram optotypes were used. (en)">
				>
				["at0112"] = <
					text = <"*Confounding factors (en)">
					description = <"*Description of any incidental factors related to the state of the subject which may affect clinical interpretation of the measurement. (en)">
					comment = <"*Examples: 'Patient was confused', \"Lid held open by hand\" \"Eccentric Fixation\". (en)">
				>
				["at0134"] = <
					text = <"*Any event(en)">
					description = <"*Default, unspecified point in time or interval event which may be explicitly defined in a template or at run-time.(en)">
				>
				["at0141"] = <
					text = <"*Test not done(en)">
					description = <"*Details to explicitly record that this test was not performed.(en)">
				>
				["at0143"] = <
					text = <"*Extension(en)">
					description = <"*Additional information required to capture local content or to align with other reference models/formalisms.(en)">
					comment = <"*For example: local information requirements or additional metadata to align with FHIR or CIMI equivalents.(en)">
				>
				["at0151"] = <
					text = <"*Best qualitative result (en)">
					description = <"*Measures of visual acuity that are qualitative, rather than quantitative. (en)">
					comment = <"*Not to be used for light projection testing. Use OBSERVATION.light_projection_test archetype for this purpose.
Higher ordinal values represent better visual function.  (en)">
				>
				["at0193"] = <
					text = <"*Derived result (en)">
					description = <"*A grouping of calculated or estimated visual acuity result values derived by conversion from the primary recorded result. (en)">
				>
				["at0206"] = <
					text = <"*Lea Symbols (en)">
					description = <"*Lea symbol optotypes were used. (en)">
				>
				["at0207"] = <
					text = <"*Kay pictures (en)">
					description = <"*Kay picture optotypes were used. (en)">
				>
				["at0208"] = <
					text = <"*Allen pictures (en)">
					description = <"*Allen picture optotypes were used. (en)">
				>
				["at0209"] = <
					text = <"*Auckland Optotypes (en)">
					description = <"*Auckland  optotypes were used (en)">
				>
				["at0210"] = <
					text = <"*Amsterdam pictures (en)">
					description = <"*Amsterdam picture optotypes were used. (en)">
				>
				["at0211"] = <
					text = <"*Landolt C (en)">
					description = <"*Landolt C optotypes were used (en)">
				>
				["at0212"] = <
					text = <"*Tumbling E (en)">
					description = <"*Tumbling E optotypes were used (en)">
				>
				["at0213"] = <
					text = <"*Numbers (en)">
					description = <"*Number optotypes were used (en)">
				>
				["at0215"] = <
					text = <"*Lea numbers (en)">
					description = <"*Lea number optotypes were used. (en)">
				>
				["at0216"] = <
					text = <"*Sloan letters (en)">
					description = <"*Sloan letter optotypes were used. (en)">
				>
				["at0217"] = <
					text = <"*Cyrillic letters (en)">
					description = <"*Cyrillic letter optotypes were used. (en)">
				>
				["at0218"] = <
					text = <"*Snellen letters (en)">
					description = <"*Snellen letter optotypes were used. (en)">
				>
				["at0219"] = <
					text = <"*HOTV letters (en)">
					description = <"*HOTV letter optotypes were used. (en)">
				>
				["at0220"] = <
					text = <"*LRVC letters (en)">
					description = <"*LRVC letter optotypes were used. (en)">
				>
				["at0221"] = <
					text = <"*British letters (2003) (en)">
					description = <"*British letter (2003) optotypes were used. (en)">
				>
				["at0222"] = <
					text = <"*European-wide letters (en)">
					description = <"*European-wide letter optotypes were used. (en)">
				>
				["at0223"] = <
					text = <"*Near (en)">
					description = <"*The test was performed at near distance. (en)">
				>
				["at0224"] = <
					text = <"*Intermediate (en)">
					description = <"*The test was performed at intermediate distance. (en)">
				>
				["at0225"] = <
					text = <"*Far (en)">
					description = <"*The test was performed at far distance. (en)">
				>
				["at0226"] = <
					text = <"*Stimulus method (en)">
					description = <"*Information on the way the visual stimulus is displayed. (en)">
					comment = <"*Allows for the capture of basic information where additional detail about the type or device name of the stimulus are unknown. (en)">
				>
				["at0227"] = <
					text = <"*Electronic chart display (en)">
					description = <"*An electronic display. (en)">
				>
				["at0231"] = <
					text = <"*Printed chart or card (en)">
					description = <"*A printed chart or card. (en)">
				>
				["at0239"] = <
					text = <"*Golovin-Sitsev table (en)">
					description = <"*A Golovin-Sitsev table was used. (en)">
				>
				["at0240"] = <
					text = <"*Monoyer chart (en)">
					description = <"*A monoyer visual acuity chart was used. (en)">
				>
				["at0241"] = <
					text = <"*Cardiff acuity cards (en)">
					description = <"*Cardiff acuity cards were used. (en)">
				>
				["at0242"] = <
					text = <"*Keeler acuity cards (en)">
					description = <"*Keeler acuity cards were used. (en)">
				>
				["at0244"] = <
					text = <"*Background luminance (en)">
					description = <"*Background luminance of the visual stimulus, such as the white background on a chart. (en)">
					comment = <"*Candela per square meter is equivalent the non-SI unit 'nit'. (en)">
				>
				["at0245"] = <
					text = <"*Weber contrast (en)">
					description = <"">
				>
				["at0248"] = <
					text = <"*Michelson contrast (en)">
					description = <"">
				>
				["at0249"] = <
					text = <"*RMS contrast (en)">
					description = <"">
				>
				["at0256"] = <
					text = <"*Ambient illuminance (en)">
					description = <"*The ambient illuminance in the room where the visual acuity testing is taking place. (en)">
				>
				["at0262"] = <
					text = <"*Visual aid per eye (en)">
					description = <"*A cluster describing what type of visual aid was used during the test, and which eye it was positioned in front of. 
 (en)">
					comment = <"*Where multiple devices are positioned in front of the same eye, this cluster is expected to be used once for each. (en)">
				>
				["at0294"] = <
					text = <"*Decimal notation result (en)">
					description = <"*The visual acuity measured and expressed as a decimal notation. (en)">
				>
				["at0295"] = <
					text = <"*Metre ratio result (en)">
					description = <"*The visual acuity measured and expressed as a metre Snellen ratio or M-Scale ratio. (en)">
					comment = <"*For Snellen ratio notation, the numerator is typically a reference distance of six meters, regardless of the real testing distance. 
For M-Scale notation, the numerator should be equal to to the real testing distance. 
To avoid ambiguity, populate the 'Testing distance' element, especially if the M-Scale notation is used.
 (en)">
				>
				["at0296"] = <
					text = <"*Feet ratio result (en)">
					description = <"*The visual acuity measured and expressed as a feet Snellen ratio.
 (en)">
					comment = <"*A reference distance of 20 feet is often used as the default numerator.
Usethe 'Testing distance' element to avoid ambiguity. 
  (en)">
				>
				["at0297"] = <
					text = <"*logMAR result (en)">
					description = <"*The visual acuity measured and expressed as the base-10 logarithm of the minimum angle of resolution (MAR). (en)">
					comment = <"*Sometimes referred to as 'logRAD' in reading acuity tests.  (en)">
				>
				["at0299"] = <
					text = <"*N point font size notation result (en)">
					description = <"*The N point font size of the smallest recognized line or text. (en)">
					comment = <"*Strictly not a unit of visual acuity but a measure of stimulus size. (en)">
				>
				["at0302"] = <
					text = <"*Jaeger font size notation result (en)">
					description = <"*The Jaeger font size of the smallest recognized line of text. (en)">
					comment = <"*Strictly not a unit of visual acuity but a measure of stimulus size. (en)">
				>
				["at0319"] = <
					text = <"*Derived decimal notation result (en)">
					description = <"*Visual acuity in decimal notation, derived from the primary recording. (en)">
				>
				["at0320"] = <
					text = <"*Derived meter ratio result (en)">
					description = <"*Visual acuity in metre ratio (Snellen or M-Score) notation, derived from the primary recording. (en)">
				>
				["at0321"] = <
					text = <"*Derived feet ratio result (en)">
					description = <"*Visual acuity in feet (Snellen) ratio notation, derived from the primary recording. (en)">
				>
				["at0322"] = <
					text = <"*Derived logMAR result (en)">
					description = <"*Visual acuity in logMAR notation, derived from the primary recording. (en)">
				>
				["at0333"] = <
					text = <"*Interpretation (en)">
					description = <"*Interpretation of the results. (en)">
					comment = <"*Not to be used for information about how the test was performed or patient circumstances affecting result. (en)">
				>
				["at0355"] = <
					text = <"*5-Score notation result (en)">
					description = <"*The visual acuity measured and expressed using the 5 mark record method. (en)">
					comment = <"*Defined as 5 minus the LogMAR result, part of the Chinese national standard GB11533-1989. (en)">
				>
				["at0356"] = <
					text = <"*ETDRS letter score (en)">
					description = <"*The visual acuity measured and expressed as the ETDRS letter score. (en)">
					comment = <"*Caution: The ETDRS score is inclusive of the 30 letters that may be presented at 1m distance, which are added to the results of testing at 4m distance. 
See ETDRS report number 7 in References. 
A letter score of 85 is equivalent to 20/20, 1.0 decimal, 0.0 logMAR. 
 (en)">
				>
				["at0357"] = <
					text = <"*Derived ETDRS letter score result (en)">
					description = <"*Visual acuity as ETDRS notation, derived from the primary recording. (en)">
					comment = <"*Caution: The ETDRS score is inclusive of the 30 letters that may be presented at 1m distance, which are added to the results of testing at 4m distance. 
See ETDRS report number 7 in References. 
A letter score of 85 is equivalent to 20/20, 1.0 decimal, 0.0 logMAR.  (en)">
				>
				["at0370"] = <
					text = <"*Comparative label (en)">
					description = <"*Classification of the test and its result as 'best corrected', 'best recorded' visual acuity, or similar statements. (en)">
					comment = <"*These classifiers do not contain information on the actual correction used.
It is encouraged to record the specific aids used within 'Visual aid per eye' clusters.
 (en)">
				>
				["at0371"] = <
					text = <"*BCVA (en)">
					description = <"*This result is classified as a Best Corrected Visual Acuity. (en)">
				>
				["at0372"] = <
					text = <"*BRVA (en)">
					description = <"*This result is classified as a Best Recorded Visual Acuity. (en)">
				>
				["at0373"] = <
					text = <"*Visual aid type (en)">
					description = <"*Information specifying the type of device, or lack of a device positioned in front of one of the eyes. (en)">
					comment = <"*Avoid using the generic value \"Corrected\" where the device or provenance of corrective values are known. 

Coding with a terminology is recommended. Free text entry should only be permitted if no appropriate coded value is available.
 (en)">
				>
				["at0374"] = <
					text = <"*Autorefraction-based correction (en)">
					description = <"*A correction with powers based on an autorefraction test. (en)">
				>
				["at0375"] = <
					text = <"*Subjective refraction-based correction (en)">
					description = <"*A correction with powers based on a subjective refraction. (en)">
				>
				["at0376"] = <
					text = <"*Glasses (en)">
					description = <"*Eyeglasses. (en)">
				>
				["at0377"] = <
					text = <"*Rigid contact lens (en)">
					description = <"*A contact lens with a rigid optical center, including hybrid lenses. (en)">
				>
				["at0378"] = <
					text = <"*Soft contact lens (en)">
					description = <"*A soft contact lens with a soft optical center. (en)">
				>
				["at0381"] = <
					text = <"*Retinoscopy based correction (en)">
					description = <"*A correction with powers based on a retinoscopy test. (en)">
				>
				["at0382"] = <
					text = <"*Corrected (en)">
					description = <"*Lenses without a known provenance or source of the powers. (en)">
				>
				["at0383"] = <
					text = <"Fogging lens">
					description = <"*A lens used to intentionally blur the vision in that eye while the other eye ist tested. (en)">
				>
				["at0384"] = <
					text = <"*Pinhole occluder (en)">
					description = <"*A device with one or multiple small holes that acting apertures. (en)">
				>
				["at0385"] = <
					text = <"*Subjective overrefraction-based correction (en)">
					description = <"*A correction with values based on subjective overrefraction was used. (en)">
				>
				["at0386"] = <
					text = <"*Unaided (en)">
					description = <"*There is explicitly nothing in front of the eye during the visual acuity testing, also referred to as \"uncorrected\". (en)">
				>
				["at0395"] = <
					text = <"*Ancillary lighting details (en)">
					description = <"*Details on the use of ancillary lighting sources, including brightness acuity testing and glare lights. (en)">
				>
				["at0404"] = <
					text = <"*Projected chart (en)">
					description = <"*A chart projector. (en)">
				>
				["at0405"] = <
					text = <"*Aided eye (en)">
					description = <"*The eye in front of which the visual aid was positioned. (en)">
					comment = <"*For monocular tests where the partner eye is fully occluded, the assumption is that the visual aid is positioned in front of the eye being tested. 
In these circumstances automated population from the 'Eye examined' element is possible.
 (en)">
				>
				["at0410"] = <
					text = <"*Missed or additional optotypes (en)">
					description = <"*Information on single optotypes where the main score was based on the whole line. 
Positive: Number of scored optotypes in largest line that was not scored.  
Negative: Number missed optotypes in smallest scored line.
\"Partial\" code refers to indicates some unspecified number of optotypes were missed in the smallest scored line. (en)">
				>
				["at0411"] = <
					text = <"*partial (en)">
					description = <"*Some symbols were not read correctly in the smallest line that was scored as being successfully read. (en)">
				>
				["at0412"] = <
					text = <"*Testing distance (en)">
					description = <"*The distance between the tested eye and the (apparent) location of the stimulus. (en)">
					comment = <"*The stimulus may be a virtual image. (en)">
				>
				["at0415"] = <
					text = <"*No improvement note (en)">
					description = <"*A note indicating that the addition or use of another type of aid did not result in a better test result. (en)">
					comment = <"*Used where a determination of the exact visual acuity with the additional correction (in another event) was not performed, typically because it was deemed irrelevant for lack of improvement.
Coding with a terminology is recommended. Free text entry should only be permitted if no appropriate coded value is available. (en)">
				>
				["at0416"] = <
					text = <"*NI with additional pinhole (en)">
					description = <"*No improvement with an additional pinhole placed in front of the tested eye. (en)">
				>
				["at0417"] = <
					text = <"*NI with subjective refraction-based correction (en)">
					description = <"*No improvement with corrective lenses based on subjective refraction. (en)">
				>
				["at0418"] = <
					text = <"Pupil state">
					description = <"*Statement describing the condition of the individual's pupils during the test. (en)">
					comment = <"*The physical examination of the eye will be recorded using the CLUSTER.exam-eye family of archetypes. 
Coding with a terminology is recommended. Free text entry should only be permitted if no appropriate coded value is available. (en)">
				>
				["at0419"] = <
					text = <"Normal">
					description = <"The pupil is in its natural physiological state without pharmacological intervention or pathological changes.">
				>
				["at0420"] = <
					text = <"Medically induced mydriasis">
					description = <"The pupil was dilated due to prior administration of mydriatic agents.">
				>
				["at0421"] = <
					text = <"Medically induced miosis">
					description = <"The pupil was constricted due to prior administration of miotic agents.">
				>
				["at0422"] = <
					text = <"Pathological pupil state">
					description = <"The pupil was in an unphysiological state due to disease, trauma, or structural abnormalities.">
				>
				["at0461"] = <
					text = <"*Result (en)">
					description = <"*A grouping of data elements to represent the primary notation of the visual acuity assessment result.
 (en)">
					comment = <"*Typically, only one result should be populated.  
Converted or derived values should be stored in the appropriate element in the 'Derived result' cluster. (en)">
				>
				["at0464"] = <
					text = <"*Power of sphere (en)">
					description = <"*The refractive power that is equal in all meridians. (en)">
					comment = <"*Used as the base correction upon which cylinder and axis are applied. (en)">
				>
				["at0465"] = <
					text = <"*Visual aid details (en)">
					description = <"">
				>
				["at0466"] = <
					text = <"*Power of cylinder (en)">
					description = <"*The refractive power added to the spherical correction at the meridian 90° from the cylinder axis to compensate for astigmatism. (en)">
				>
				["at0467"] = <
					text = <"*Axis of cylinder (en)">
					description = <"*The orientation of the cylinder in degrees. (en)">
					comment = <"*By convention, the axis of the cylinder is defined by its medirian of zero power. (en)">
				>
				["at0468"] = <
					text = <"*Near addition (en)">
					description = <"*The additional spherical lens power for near vision. (en)">
				>
				["at0471"] = <
					text = <"*Physical object (en)">
					description = <"*Physical objects other than charts or cards. (en)">
				>
				["at0472"] = <
					text = <"*Berkeley rudimentary vision test (en)">
					description = <"*Berkeley rudimentary vision test was used. (en)">
				>
				["at0473"] = <
					text = <"*Near reading card (en)">
					description = <"*A near card with segments of text that are read by the individual was used. (en)">
				>
				["at0474"] = <
					text = <"*LEA grating acuity test (en)">
					description = <"*LEA gratings, a type of preferential looking test was used. (en)">
				>
				["at0475"] = <
					text = <"*Teller acuity cards (en)">
					description = <"*Teller acuity cards were used. (en)">
				>
				["at0476"] = <
					text = <"*Cardiff acuity test (en)">
					description = <"*A Cardiff acuity test was used. (en)">
				>
				["at0483"] = <
					text = <"*Allen picture test. (en)">
					description = <"*An Allen picture test was used. (en)">
				>
				["at0484"] = <
					text = <"*Sheridan letter test. (en)">
					description = <"*A Sheridan letter test was used. (en)">
				>
				["at0485"] = <
					text = <"*Cambridge crowding cards (en)">
					description = <"*A Cambridge crowding card test was used. (en)">
				>
				["at0486"] = <
					text = <"*MNREAD chart (en)">
					description = <"*A MNREAD acuity chart was used. (en)">
				>
				["at0487"] = <
					text = <"*Radner Reading chart (en)">
					description = <"*A Radner reading chart was used. (en)">
				>
				["at0488"] = <
					text = <"*Freiburg visual acuity test (en)">
					description = <"*A Freiburg visual acuity test was used. (en)">
				>
				["at0489"] = <
					text = <"*Sheridan Gardiner test (en)">
					description = <"*A Sheridan Gardiner test was used. (en)">
				>
				["at0490"] = <
					text = <"*Integrated virtual chart display (en)">
					description = <"*A chart presented as a virtual image inside a device, such as an autorefractor. (en)">
				>
				["at0491"] = <
					text = <"*Cycles per centimetre result (en)">
					description = <"*The number of cycles (line pairs) per centimetre of the finest grating pattern recognized by the individual. (en)">
					comment = <"*Strictly not a unit of visual acuity but a measure of stimulus size. (en)">
				>
				["at0492"] = <
					text = <"*Cycles per degree result (en)">
					description = <"*The visual acuity measured and expressed as the number of pairs of black and white lines (cycles) that subtend an angle of one degree at the tested eye. (en)">
					comment = <"*Used in grating based tests such as Teller acuity cards.  (en)">
				>
				["at0493"] = <
					text = <"*Derived cycles per degree (en)">
					description = <"*Visual acuity as cycles per degree, derived by conversion from the primary recording. (en)">
				>
				["at0494"] = <
					text = <"*NI with autorefraction-based correction (en)">
					description = <"*No improvement withf corrective lenses based on an autorefraction test. (en)">
				>
				["at0495"] = <
					text = <"*NI with glasses (en)">
					description = <"*No improvement with eyeglasses. (en)">
				>
				["at0496"] = <
					text = <"*NI with soft contact lens (en)">
					description = <"*No improvement with a soft contact lens. (en)">
				>
				["at0497"] = <
					text = <"*NI with retinoscopy-based correction (en)">
					description = <"*No improvement with corrective lenses based on retinoscopy. (en)">
				>
				["at0498"] = <
					text = <"*NI with rigid contact lens (en)">
					description = <"*No improvement with a hard contact lens (en)">
				>
				["at0499"] = <
					text = <"*Sonksen Silver test (en)">
					description = <"*A Sonksen Silver test was used. (en)">
				>
				["at0500"] = <
					text = <"*Cycloplegia during refraction (en)">
					description = <"*Information on whether the correction used was based on a measurement of the refractive error in a cycloplegic state. (en)">
				>
				["at0501"] = <
					text = <"*Cycloplegic refraction (en)">
					description = <"*The correction used was based on a measurement of refractive error in a cycloplegic state. (en)">
				>
				["at0502"] = <
					text = <"*Non-cycloplegic refraction (en)">
					description = <"*The correction used was based on a measurement of refractive error in a non-cycloplegic state. (en)">
				>
				["at0510"] = <
					text = <"*NI with further correction (en)">
					description = <"*No improvement with an unspecified further correction. (en)">
				>
				["at0512"] = <
					text = <"*Supplementary results (en)">
					description = <"*Additional structured details on visual acuity test result not captured in other data elements. (en)">
					comment = <"*Examples include specifying the card scored in a Cardiff acuity test, or supplementary results on reading visual acuity tests.  (en)">
				>
				["at0513"] = <
					text = <"*Contrast category (en)">
					description = <"*A statement on the contrast level of the test. (en)">
					comment = <"*Note that the majority of visual acuity tests are performed under high contrast conditions.
Where possible, population of quantitative elements on contrast is encouraged. (en)">
				>
