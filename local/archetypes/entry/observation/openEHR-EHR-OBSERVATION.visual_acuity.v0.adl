definition
	OBSERVATION[at0000] matches {    -- Visual acuity test
		data matches {
			HISTORY[at0001] matches {    -- Event Series
				events cardinality matches {1..*; unordered} matches {
					POINT_EVENT[at0134] occurrences matches {0..*} matches {    -- Any event
						data matches {
							ITEM_TREE[at0003] matches {    -- Tree
								items cardinality matches {0..*; unordered} matches {
									ELEMENT[at0007] matches {    -- Eye examined
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0012,    -- Left eye
													at0013,    -- Right eye
													at0014]    -- Both eyes
												}
											}
										}
									}
									CLUSTER[at0461] occurrences matches {0..1} matches {    -- Result
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0297] occurrences matches {0..1} matches {    -- logMAR result
												value matches {
													C_DV_QUANTITY <
														
														list = <
															["1"] = <
																units = <"1{logMAR}">
															>
														>
													>
												}
											}
											ELEMENT[at0295] occurrences matches {0..1} matches {    -- Metre ratio result
												value matches {
													DV_PROPORTION matches {
														numerator matches {|>0.0..99.0|}
														denominator matches {|>0.0..99999.0|}
														type matches {3}
														precision matches {|2|}
													}
												}
											}
											ELEMENT[at0296] occurrences matches {0..1} matches {    -- Feet ratio result
												value matches {
													DV_PROPORTION matches {
														numerator matches {|>0.0..99.0|}
														denominator matches {|>0.0..99999.0|}
														type matches {3}
														precision matches {|2|}
													}
												}
											}
											ELEMENT[at0294] occurrences matches {0..1} matches {    -- Decimal notation result
												value matches {
													C_DV_QUANTITY <
														
														list = <
															["1"] = <
																units = <"1{decimal VA}">
																magnitude = <|>0.0..999.0|>
																precision = <|3|>
															>
														>
													>
												}
											}
											ELEMENT[at0356] occurrences matches {0..1} matches {    -- ETDRS letter score
												value matches {
													DV_COUNT matches {
														magnitude matches {|0..999|}
													}
												}
											}
											ELEMENT[at0355] occurrences matches {0..1} matches {    -- 5-Score notation result
												value matches {
													C_DV_QUANTITY <
														
														list = <
															["1"] = <
																units = <"1{5PointVA}">
															>
														>
													>
												}
											}
											ELEMENT[at0299] occurrences matches {0..1} matches {    -- N point font size notation result
												value matches {
													1.0|[local::at0518],
													1.5|[local::at0519],
													2.0|[local::at0520],
													2.5|[local::at0521],
													3.0|[local::at0522],
													3.5|[local::at0523],
													4.0|[local::at0524],
													4.5|[local::at0525],
													5.0|[local::at0526],
													5.5|[local::at0527],
													6.0|[local::at0528],
													6.5|[local::at0529],
													7.0|[local::at0593],
													7.5|[local::at0530],
													8.0|[local::at0531],
													9.0|[local::at0532],
													10.0|[local::at0533],
													11.0|[local::at0534],
													12.0|[local::at0535],
													13.0|[local::at0536],
													14.0|[local::at0537],
													15.0|[local::at0538],
													16.0|[local::at0539],
													18.0|[local::at0540],
													20.0|[local::at0541],
													22.0|[local::at0542],
													24.0|[local::at0543],
													26.0|[local::at0544],
													28.0|[local::at0545],
													30.0|[local::at0546],
													32.0|[local::at0547],
													36.0|[local::at0548],
													40.0|[local::at0549],
													42.0|[local::at0550],
													44.0|[local::at0551],
													48.0|[local::at0552],
													54.0|[local::at0553],
													56.0|[local::at0554],
													60.0|[local::at0555],
													66.0|[local::at0556],
													72.0|[local::at0557]
												}
											}
											ELEMENT[at0302] occurrences matches {0..1} matches {    -- Jaeger font size notation result
												value matches {
													1.0|[local::at0566],
													2.0|[local::at0567],
													3.0|[local::at0568],
													4.0|[local::at0569],
													5.0|[local::at0570],
													6.0|[local::at0571],
													7.0|[local::at0572],
													8.0|[local::at0573],
													9.0|[local::at0574],
													10.0|[local::at0575],
													11.0|[local::at0576],
													12.0|[local::at0577],
													13.0|[local::at0578],
													14.0|[local::at0579],
													15.0|[local::at0580],
													16.0|[local::at0581],
													17.0|[local::at0582],
													18.0|[local::at0583],
													19.0|[local::at0584],
													20.0|[local::at0585]
												}
											}
											ELEMENT[at0491] occurrences matches {0..1} matches {    -- Cycles per centimetre result
												value matches {
													C_DV_QUANTITY <
														
														list = <
															["1"] = <
																units = <"1/cm">
																magnitude = <|>0.0..9999.0|>
															>
														>
													>
												}
											}
											ELEMENT[at0492] occurrences matches {0..1} matches {    -- Cycles per degree result
												value matches {
													C_DV_QUANTITY <
														
														list = <
															["1"] = <
																units = <"1/deg">
																magnitude = <|>0.0..9999.0|>
															>
														>
													>
												}
											}
											ELEMENT[at0151] occurrences matches {0..1} matches {    -- Best qualitative result
												value matches {
													1|[local::at0594],
													2|[local::at0595],
													3|[local::at0596],
													4|[local::at0597]
												}
											}
											ELEMENT[at0410] occurrences matches {0..*} matches {    -- Missed or additional optotypes
												value matches {
													DV_COUNT matches {
														magnitude matches {|-9..9|}
													}
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::at0411]    -- Partial
														}
													}
												}
											}
											CLUSTER[at0193] occurrences matches {0..1} matches {    -- Derived result
												items cardinality matches {1..*; unordered} matches {
													ELEMENT[at0322] occurrences matches {0..1} matches {    -- Derived logMAR result
														value matches {
															DV_QUANTITY matches {*}
														}
													}
													ELEMENT[at0320] occurrences matches {0..1} matches {    -- Derived meter ratio result
														value matches {
															DV_PROPORTION matches {
																type matches {0,3}
															}
														}
													}
													ELEMENT[at0321] occurrences matches {0..1} matches {    -- Derived feet ratio result
														value matches {
															DV_PROPORTION matches {
																type matches {0,3}
															}
														}
													}
													ELEMENT[at0319] occurrences matches {0..1} matches {    -- Derived decimal notation result
														value matches {
															DV_QUANTITY matches {*}
														}
													}
													ELEMENT[at0357] occurrences matches {0..1} matches {    -- Derived ETDRS letter score result
														value matches {
															DV_COUNT matches {*}
														}
													}
													ELEMENT[at0493] occurrences matches {0..1} matches {    -- Derived cycles per degree
														value matches {
															C_DV_QUANTITY <
																property = <[openehr::755]>
																list = <
																	["1"] = <
																		units = <"[arb'U]">
																	>
																>
															>
														}
													}
												}
											}
										}
									}
									allow_archetype CLUSTER[at0512] occurrences matches {0..*} matches {    -- Supplementary results
										include
											archetype_id/value matches {/openEHR-EHR-CLUSTER\.cardiff_acuity_card_test_result\.v0|openEHR-EHR-CLUSTER\.reading_visual_acuity_supplementary_results\.v0/}
									}
									ELEMENT[at0081] occurrences matches {0..1} matches {    -- Testing distance category
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0223,    -- Near
													at0224,    -- Intermediate
													at0225]    -- Far
												}
											}
										}
									}
									ELEMENT[at0412] occurrences matches {0..1} matches {    -- Testing distance
										value matches {
											C_DV_QUANTITY <
												property = <[openehr::122]>
												list = <
													["1"] = <
														units = <"m">
														magnitude = <|>0.0..999.0|>
														precision = <|3|>
													>
													["2"] = <
														units = <"cm">
														magnitude = <|0.0..9999.0|>
														precision = <|1|>
													>
													["3"] = <
														units = <"[in_i]">
														magnitude = <|>0.0..9999.0|>
														precision = <|2|>
													>
													["4"] = <
														units = <"[ft_i]">
														magnitude = <|>0.0..9999.0|>
														precision = <|2|>
													>
												>
											>
										}
									}
									ELEMENT[at0586] occurrences matches {0..1} matches {    -- Perceptual task
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0587,    -- Minimum resolvable visual acuity
													at0588]    -- Reading visual acuity
												}
											}
										}
									}
									ELEMENT[at0226] occurrences matches {0..1} matches {    -- Stimulus method
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0231,    -- Printed chart or card
													at0227,    -- Electronic chart display
													at0404,    -- Projected chart
													at0471,    -- Physical object
													at0490]    -- Integrated virtual chart display
												}
											}
										}
									}
									ELEMENT[at0023] occurrences matches {0..1} matches {    -- Chart or card type
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0082,    -- logMAR chart
													at0083,    -- Snellen chart
													at0084,    -- ETDRS chart
													at0239,    -- Golovin-Sitsev table
													at0240,    -- Monoyer chart
													at0241,    -- Cardiff acuity cards
													at0242,    -- Keeler acuity cards
													at0472,    -- Berkeley rudimentary vision test
													at0473,    -- Near reading card
													at0474,    -- LEA grating acuity test
													at0475,    -- Teller acuity cards
													at0476,    -- Cardiff acuity test
													at0483,    -- Allen picture test
													at0484,    -- Sheridan letter test
													at0485,    -- Cambridge crowding cards
													at0486,    -- MNREAD chart
													at0487,    -- Radner Reading chart
													at0488,    -- Freiburg visual acuity test
													at0489,    -- Sheridan Gardiner test
													at0499]    -- Sonksen Silver test
												}
											}
											DV_TEXT matches {*}
										}
									}
									allow_archetype CLUSTER[at0025] occurrences matches {0..*} matches {    -- Chart or stimulus device details
										include
											archetype_id/value matches {/openEHR-EHR-CLUSTER\.device(-[a-zA-Z0-9_]+)*\.v1/}
									}
									ELEMENT[at0021] occurrences matches {0..1} matches {    -- Optotype
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0108,    -- Pictograms
													at0107,    -- Orientation-Type Optotypes
													at0106,    -- Letters
													at0213,    -- Numbers
													at0206,    -- Lea Symbols
													at0207,    -- Kay pictures
													at0208,    -- Allen pictures
													at0209,    -- Auckland Optotypes
													at0210,    -- Amsterdam pictures
													at0211,    -- Landolt C
													at0212,    -- Tumbling E
													at0215,    -- Lea numbers
													at0216,    -- Sloan letters
													at0217,    -- Cyrillic letters
													at0218,    -- Snellen letters
													at0219,    -- HOTV letters
													at0220,    -- LRVC letters
													at0221,    -- British letters (2003)
													at0222]    -- European-wide letters
												}
											}
										}
									}
									ELEMENT[at0558] occurrences matches {0..1} matches {    -- Crowdedness
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0560,    -- Crowded
													at0561]    -- Not Crowded
												}
											}
										}
									}
									allow_archetype CLUSTER[at0516] occurrences matches {0..*} matches {    -- Optotype presentation details
										include
											archetype_id/value matches {/openEHR-EHR-CLUSTER\.optotype_presentation_details\.v0/}
									}
									ELEMENT[at0513] occurrences matches {0..1} matches {    -- Contrast category
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0514,    -- High-contrast
													at0515]    -- Low-contrast
												}
											}
										}
									}
									ELEMENT[at0245] occurrences matches {0..1} matches {    -- Weber contrast
										value matches {
											DV_PROPORTION matches {
												precision matches {|3|}
											}
										}
									}
									ELEMENT[at0248] occurrences matches {0..1} matches {    -- Michelson contrast
										value matches {
											DV_PROPORTION matches {
												precision matches {|3|}
											}
										}
									}
									ELEMENT[at0249] occurrences matches {0..1} matches {    -- RMS contrast
										value matches {
											DV_PROPORTION matches {
												precision matches {|3|}
											}
										}
									}
									ELEMENT[at0415] occurrences matches {0..1} matches {    -- No improvement note
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0416,    -- NI with additional pinhole
													at0417,    -- NI with subjective refraction-based correction
													at0494,    -- NI with autorefraction-based correction
													at0497,    -- NI with retinoscopy-based correction
													at0495,    -- NI with glasses
													at0496,    -- NI with soft contact lens
													at0498,    -- NI with rigid contact lens
													at0510]    -- NI with further correction
												}
											}
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0040] occurrences matches {0..1} matches {    -- Comment
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0333] occurrences matches {0..1} matches {    -- Interpretation
										value matches {
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0370] occurrences matches {0..1} matches {    -- Comparative label
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0371,    -- BCVA
													at0372]    -- BRVA
												}
											}
											DV_TEXT matches {*}
										}
									}
									allow_archetype CLUSTER[at0141] occurrences matches {0..*} matches {    -- Test not done
										include
											archetype_id/value matches {/openEHR-EHR-CLUSTER\.exclusion_exam(-[a-zA-Z0-9_]+)*\.v1/}
									}
								}
							}
						}
						state matches {
							ITEM_TREE[at0041] matches {    -- Tree
								items cardinality matches {0..*; unordered} matches {
									CLUSTER[at0262] occurrences matches {0..*} matches {    -- Visual aid per eye
										items cardinality matches {1..*; unordered} matches {
											ELEMENT[at0405] matches {    -- Aided eye
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0012,    -- Left eye
															at0013]    -- Right eye
														}
													}
												}
											}
											ELEMENT[at0373] occurrences matches {0..1} matches {    -- Visual aid type
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0374,    -- Autorefraction-based correction
															at0375,    -- Subjective refraction-based correction
															at0376,    -- Glasses
															at0377,    -- Rigid contact lens
															at0378,    -- Soft contact lens
															at0381,    -- Retinoscopy based correction
															at0382,    -- Corrected
															at0383,    -- Fogging lens
															at0384,    -- Pinhole occluder
															at0385,    -- Subjective overrefraction-based correction
															at0386,    -- Unaided
															at0517]    -- Defocus lens
														}
													}
													DV_TEXT matches {*}
												}
											}
											ELEMENT[at0500] occurrences matches {0..1} matches {    -- Cycloplegia during refraction
												value matches {
													DV_CODED_TEXT matches {
														defining_code matches {
															[local::
															at0501,    -- Cycloplegic refraction
															at0502]    -- Non-cycloplegic refraction
														}
													}
												}
											}
											ELEMENT[at0464] occurrences matches {0..1} matches {    -- Power of sphere
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::685]>
														list = <
															["1"] = <
																units = <"[diop]">
															>
														>
													>
												}
											}
											ELEMENT[at0466] occurrences matches {0..1} matches {    -- Power of cylinder
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::685]>
														list = <
															["1"] = <
																units = <"[diop]">
															>
														>
													>
												}
											}
											ELEMENT[at0467] occurrences matches {0..1} matches {    -- Axis of cylinder
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::497]>
														list = <
															["1"] = <
																units = <"deg">
															>
														>
													>
												}
											}
											ELEMENT[at0468] occurrences matches {0..1} matches {    -- Near addition
												value matches {
													C_DV_QUANTITY <
														property = <[openehr::685]>
														list = <
															["1"] = <
																units = <"[diop]">
															>
														>
													>
												}
											}
											allow_archetype CLUSTER[at0465] occurrences matches {0..1} matches {    -- Visual aid details
												include
													archetype_id/value matches {/openEHR-EHR-CLUSTER\.device(-[a-zA-Z0-9_]+)*\.v1/}
											}
											ELEMENT[at0565] occurrences matches {0..1} matches {    -- Comment
												value matches {
													DV_TEXT matches {*}
												}
											}
										}
									}
									ELEMENT[at0418] occurrences matches {0..1} matches {    -- Pupil state
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0419,    -- Normal
													at0420,    -- Medically induced mydriasis
													at0421,    -- Medically induced miosis
													at0422]    -- Pathological pupil state
												}
											}
											DV_TEXT matches {*}
										}
									}
									ELEMENT[at0562] occurrences matches {0..1} matches {    -- Type of ancillary lighting used
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0563,    -- Glare light
													at0564]    -- Brightness Acuity Test
												}
											}
										}
									}
									allow_archetype CLUSTER[at0395] occurrences matches {0..1} matches {    -- Ancillary lighting details
										include
											archetype_id/value matches {/openEHR-EHR-CLUSTER\.vision_test_ancillary_lighting_details\.v0/}
									}
									ELEMENT[at0589] occurrences matches {0..1} matches {    -- Light adaptation state
										value matches {
											DV_CODED_TEXT matches {
												defining_code matches {
													[local::
													at0590,    -- Photopic
													at0591,    -- Mesopic
													at0592]    -- Scotopic
												}
											}
										}
									}
									ELEMENT[at0256] occurrences matches {0..1} matches {    -- Ambient illuminance
										value matches {
											C_DV_QUANTITY <
												property = <[openehr::505]>
												list = <
													["1"] = <
														units = <"lx">
													>
												>
											>
										}
									}
									ELEMENT[at0244] occurrences matches {0..1} matches {    -- Background luminance
										value matches {
											C_DV_QUANTITY <
												
												list = <
													["1"] = <
														units = <"cd/m2">
													>
												>
											>
										}
									}
									ELEMENT[at0112] occurrences matches {0..*} matches {    -- Confounding factors
										value matches {
											DV_TEXT matches {*}
										}
									}
								}
							}
						}
					}
				}
			}
		}
		protocol matches {
			ITEM_TREE[at0020] matches {    -- Tree
				items cardinality matches {0..*; unordered} matches {
					allow_archetype CLUSTER[at0143] occurrences matches {0..*} matches {    -- Extension
						include
							archetype_id/value matches {/.*/}
					}
				}
			}
		}
	}


ontology
	terminologies_available = <"SNOMED-CT", ...>
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Visual acuity test">
					description = <"A test to quantify an individual's visual acuity, as a measure of the ability to discern small visual differences.">
				>
				["at0001"] = <
					text = <"Event Series">
					description = <"@ internal @">
				>
				["at0003"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0007"] = <
					text = <"Eye examined">
					description = <"The eye which was examined, or both eyes in case of a binocular test.">
					comment = <"'Both eyes' may only be used for test of binocular visual acuity.">
				>
				["at0012"] = <
					text = <"Left eye">
					description = <"The left eye was examined.">
				>
				["at0013"] = <
					text = <"Right eye">
					description = <"The right eye was examined.">
				>
				["at0014"] = <
					text = <"Both eyes">
					description = <"Both eyes were examined simultaneously.">
				>
				["at0020"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0021"] = <
					text = <"Optotype">
					description = <"The type of symbol used to assess visual acuity.">
					comment = <"Coding with a terminology is recommended. Free text entry should only be permitted if no appropriate coded value is available.">
				>
				["at0023"] = <
					text = <"Chart or card type">
					description = <"The type of chart or card used to measure visual acuity.">
					comment = <"Coding with a terminology is recommended. Free text entry should only be permitted if no appropriate coded value is available.">
				>
				["at0025"] = <
					text = <"Chart or stimulus device details">
					description = <"Details of the devices used provide a stimulus to be resolved by the eye being tested, such as a chart, projector or digital display.">
				>
				["at0040"] = <
					text = <"Comment">
					description = <"Narrative comment about the visual acuity test.">
					comment = <"It is a common but controversial practice to comment \"partial\" where the last line was not read entirely even in line-based scoring. This is covered by the \"Letters missed or read in addition to scored line\" element.">
				>
				["at0041"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0081"] = <
					text = <"Testing distance category">
					description = <"A categorisation of the testing distance.">
					comment = <"Boundary definitions may vary, therefore population of the  'Testing distance' element is encouraged, especially for intermediate or near distances.">
				>
				["at0082"] = <
					text = <"logMAR chart">
					description = <"A logMAR chart was used.">
				>
				["at0083"] = <
					text = <"Snellen chart">
					description = <"A Snellen chart was used.">
				>
				["at0084"] = <
					text = <"ETDRS chart">
					description = <"An ETDRS chart was used.">
				>
				["at0106"] = <
					text = <"Letters">
					description = <"Letter optotypes were used.">
				>
				["at0107"] = <
					text = <"Orientation-Type Optotypes">
					description = <"Orientation-Type optotypes were used.">
				>
				["at0108"] = <
					text = <"Pictograms">
					description = <"Pictogram optotypes were used.">
				>
				["at0112"] = <
					text = <"Confounding factors">
					description = <"Description of any incidental factors related to the state of the subject which may affect clinical interpretation of the measurement.">
					comment = <"Examples: 'Patient was confused', \"Lid held open by hand\" \"Eccentric Fixation\".">
				>
				["at0134"] = <
					text = <"Any event">
					description = <"Default, unspecified point in time or interval event which may be explicitly defined in a template or at run-time.">
				>
				["at0141"] = <
					text = <"Test not done">
					description = <"Details to explicitly record that this test was not performed.">
				>
				["at0143"] = <
					text = <"Extension">
					description = <"Additional information required to capture local content or to align with other reference models/formalisms.">
					comment = <"For example: local information requirements or additional metadata to align with FHIR or CIMI equivalents.">
				>
				["at0151"] = <
					text = <"Best qualitative result">
					description = <"The highest level of visual function demonstrated by the individual during qualitative assessment.">
					comment = <"Not to be used for light projection testing. Use OBSERVATION.light_projection_test archetype for this purpose.
Higher ordinal values represent better visual function. ">
				>
				["at0193"] = <
					text = <"Derived result">
					description = <"A grouping of calculated or estimated visual acuity result values derived by conversion from the primary recorded result.">
				>
				["at0206"] = <
					text = <"Lea Symbols">
					description = <"Lea symbol optotypes were used.">
				>
				["at0207"] = <
					text = <"Kay pictures">
					description = <"Kay picture optotypes were used.">
				>
				["at0208"] = <
					text = <"Allen pictures">
					description = <"Allen picture optotypes were used.">
				>
				["at0209"] = <
					text = <"Auckland Optotypes">
					description = <"Auckland optotypes were used.">
				>
				["at0210"] = <
					text = <"Amsterdam pictures">
					description = <"Amsterdam picture optotypes were used.">
				>
				["at0211"] = <
					text = <"Landolt C">
					description = <"Landolt C optotypes were used.">
				>
				["at0212"] = <
					text = <"Tumbling E">
					description = <"Tumbling E optotypes were used.">
				>
				["at0213"] = <
					text = <"Numbers">
					description = <"Number optotypes were used.">
				>
				["at0215"] = <
					text = <"Lea numbers">
					description = <"Lea number optotypes were used.">
				>
				["at0216"] = <
					text = <"Sloan letters">
					description = <"Sloan letter optotypes were used.">
				>
				["at0217"] = <
					text = <"Cyrillic letters">
					description = <"Cyrillic letter optotypes were used.">
				>
				["at0218"] = <
					text = <"Snellen letters">
					description = <"Snellen letter optotypes were used.">
				>
				["at0219"] = <
					text = <"HOTV letters">
					description = <"HOTV letter optotypes were used.">
				>
				["at0220"] = <
					text = <"LRVC letters">
					description = <"LRVC letter optotypes were used.">
				>
				["at0221"] = <
					text = <"British letters (2003)">
					description = <"British letter (2003) optotypes were used.">
				>
				["at0222"] = <
					text = <"European-wide letters">
					description = <"European-wide letter optotypes were used.">
				>
				["at0223"] = <
					text = <"Near">
					description = <"The test was performed at near distance.">
				>
				["at0224"] = <
					text = <"Intermediate">
					description = <"The test was performed at intermediate distance.">
				>
				["at0225"] = <
					text = <"Far">
					description = <"The test was performed at far distance.">
				>
				["at0226"] = <
					text = <"Stimulus method">
					description = <"Information on the way the visual stimulus is displayed.">
					comment = <"Allows for the capture of basic information where additional detail about the type or device name of the stimulus are unknown.">
				>
				["at0227"] = <
					text = <"Electronic chart display">
					description = <"An electronic display.">
				>
				["at0231"] = <
					text = <"Printed chart or card">
					description = <"A printed chart or card.">
				>
				["at0239"] = <
					text = <"Golovin-Sitsev table">
					description = <"A Golovin-Sitsev table was used.">
				>
				["at0240"] = <
					text = <"Monoyer chart">
					description = <"A monoyer visual acuity chart was used.">
				>
				["at0241"] = <
					text = <"Cardiff acuity cards">
					description = <"Cardiff acuity cards were used.">
				>
				["at0242"] = <
					text = <"Keeler acuity cards">
					description = <"Keeler acuity cards were used.">
				>
				["at0244"] = <
					text = <"Background luminance">
					description = <"Background luminance of the visual stimulus, such as the white background on a chart.">
					comment = <"Candela per square meter is equivalent to the non-SI unit 'nit'.">
				>
				["at0245"] = <
					text = <"Weber contrast">
					description = <"The difference between stimulus and background luminance divided by background luminance.">
				>
				["at0248"] = <
					text = <"Michelson contrast">
					description = <"The difference between maximum and minimum luminance of the stimulus divided by their sum.">
				>
				["at0249"] = <
					text = <"RMS contrast">
					description = <"The standard deviation of the pixel intensity values of the stimulus.">
				>
				["at0256"] = <
					text = <"Ambient illuminance">
					description = <"The ambient illuminance in the room where the visual acuity testing is taking place.">
				>
				["at0262"] = <
					text = <"Visual aid per eye">
					description = <"A cluster describing what type of visual aid was used during the test, and which eye it was positioned in front of.">
					comment = <"Where multiple devices are positioned in front of the same eye, this cluster is expected to be used once for each.">
				>
				["at0294"] = <
					text = <"Decimal notation result">
					description = <"The visual acuity measured and expressed as a decimal notation.">
				>
				["at0295"] = <
					text = <"Metre ratio result">
					description = <"The visual acuity measured and expressed as a metre Snellen ratio or M-Scale ratio.">
					comment = <"For Snellen ratio notation, the numerator is typically a reference distance of six meters, regardless of the real testing distance. 
For M-Scale notation, the numerator should be equal to to the real testing distance. 
To avoid ambiguity, populate the 'Testing distance' element, especially if the M-Scale notation is used.
">
				>
				["at0296"] = <
					text = <"Feet ratio result">
					description = <"The visual acuity measured and expressed as a feet Snellen ratio.
">
					comment = <"A reference distance of 20 feet is often used as the default numerator.
Usethe 'Testing distance' element to avoid ambiguity. 
 ">
				>
				["at0297"] = <
					text = <"logMAR result">
					description = <"The visual acuity measured and expressed as the base-10 logarithm of the minimum angle of resolution (MAR).">
					comment = <"Sometimes referred to as 'logRAD' in reading acuity tests. ">
				>
				["at0299"] = <
					text = <"N point font size notation result">
					description = <"The N point font size of the smallest recognized line or text.">
					comment = <"Strictly not a unit of visual acuity but a measure of stimulus size.">
				>
				["at0302"] = <
					text = <"Jaeger font size notation result">
					description = <"The Jaeger font size of the smallest recognized line of text.">
					comment = <"Strictly not a unit of visual acuity but a measure of stimulus size.">
				>
				["at0319"] = <
					text = <"Derived decimal notation result">
					description = <"Visual acuity in decimal notation, derived from the primary recording.">
				>
				["at0320"] = <
					text = <"Derived meter ratio result">
					description = <"Visual acuity in metre ratio (Snellen or M-Score) notation, derived from the primary recording.">
				>
				["at0321"] = <
					text = <"Derived feet ratio result">
					description = <"Visual acuity in feet (Snellen) ratio notation, derived from the primary recording.">
				>
				["at0322"] = <
					text = <"Derived logMAR result">
					description = <"Visual acuity in logMAR notation, derived from the primary recording.">
				>
				["at0333"] = <
					text = <"Interpretation">
					description = <"Interpretation of the results.">
					comment = <"Not to be used for information about how the test was performed or patient circumstances affecting result.">
				>
				["at0355"] = <
					text = <"5-Score notation result">
					description = <"The visual acuity measured and expressed using the 5 mark record method.">
					comment = <"Defined as 5 minus the LogMAR result, part of the Chinese national standard GB11533-1989.">
				>
				["at0356"] = <
					text = <"ETDRS letter score">
					description = <"The visual acuity measured and expressed as the ETDRS letter score.">
					comment = <"Caution: The ETDRS score is inclusive of the 30 letters that may be presented at 1m distance, which are added to the results of testing at 4m distance. 
See ETDRS report number 7 in References. 
A letter score of 85 is equivalent to 20/20, 1.0 decimal, 0.0 logMAR. 
">
				>
				["at0357"] = <
					text = <"Derived ETDRS letter score result">
					description = <"Visual acuity as ETDRS notation, derived from the primary recording.">
					comment = <"Caution: The ETDRS score is inclusive of the 30 letters that may be presented at 1m distance, which are added to the results of testing at 4m distance. 
See ETDRS report number 7 in References. 
A letter score of 85 is equivalent to 20/20, 1.0 decimal, 0.0 logMAR. ">
				>
				["at0370"] = <
					text = <"Comparative label">
					description = <"Classification of the test and its result as 'best corrected', 'best recorded' visual acuity, or similar statements.">
					comment = <"These classifiers do not contain information on the actual correction used.
It is encouraged to record the specific aids used within 'Visual aid per eye' clusters.
">
				>
				["at0371"] = <
					text = <"BCVA">
					description = <"This result is classified as a Best Corrected Visual Acuity.">
				>
				["at0372"] = <
					text = <"BRVA">
					description = <"This result is classified as a Best Recorded Visual Acuity.">
				>
				["at0373"] = <
					text = <"Visual aid type">
					description = <"Information specifying the type of device, or lack of a device positioned in front of one of the eyes.">
					comment = <"Avoid using the generic value \"Corrected\" where the device or provenance of corrective values are known. 

Coding with a terminology is recommended. Free text entry should only be permitted if no appropriate coded value is available.
">
				>
				["at0374"] = <
					text = <"Autorefraction-based correction">
					description = <"A correction with powers based on an autorefraction test.">
				>
				["at0375"] = <
					text = <"Subjective refraction-based correction">
					description = <"A correction with powers based on a subjective refraction.">
				>
				["at0376"] = <
					text = <"Glasses">
					description = <"Eyeglasses.">
				>
				["at0377"] = <
					text = <"Rigid contact lens">
					description = <"A contact lens with a rigid optical center, including hybrid lenses.">
				>
				["at0378"] = <
					text = <"Soft contact lens">
					description = <"A soft contact lens with a soft optical center.">
				>
				["at0381"] = <
					text = <"Retinoscopy based correction">
					description = <"A correction with powers based on a retinoscopy test.">
				>
				["at0382"] = <
					text = <"Corrected">
					description = <"Lenses without a known provenance or source of the powers.">
				>
				["at0383"] = <
					text = <"Fogging lens">
					description = <"A lens used to intentionally blur the vision in that eye while the other eye is tested.">
				>
				["at0384"] = <
					text = <"Pinhole occluder">
					description = <"A device with one or multiple small holes acting as apertures.">
				>
				["at0385"] = <
					text = <"Subjective overrefraction-based correction">
					description = <"A correction with values based on subjective overrefraction was used.">
				>
				["at0386"] = <
					text = <"Unaided">
					description = <"There is explicitly nothing in front of the eye during the visual acuity testing, also referred to as \"uncorrected\".">
				>
				["at0395"] = <
					text = <"Ancillary lighting details">
					description = <"Details on the use of ancillary lighting sources, including brightness acuity testing and glare lights.">
				>
				["at0404"] = <
					text = <"Projected chart">
					description = <"A chart projector.">
				>
				["at0405"] = <
					text = <"Aided eye">
					description = <"The eye in front of which the visual aid was positioned.">
					comment = <"For monocular tests where the partner eye is fully occluded, the assumption is that the visual aid is positioned in front of the eye being tested. 
In these circumstances automated population from the 'Eye examined' element is possible.
">
				>
				["at0410"] = <
					text = <"Missed or additional optotypes">
					description = <"Information on single optotypes where the main score was based on the whole line. 
Positive: Number of scored optotypes in largest line that was not scored.  
Negative: Number missed optotypes in smallest scored line.
\"Partial\" code refers to indicates some unspecified number of optotypes were missed in the smallest scored line.">
				>
				["at0411"] = <
					text = <"Partial">
					description = <"Some symbols were not read correctly in the smallest line that was scored as being successfully read.">
				>
				["at0412"] = <
					text = <"Testing distance">
					description = <"The distance between the tested eye and the (apparent) location of the stimulus.">
					comment = <"The stimulus may be a virtual image.">
				>
				["at0415"] = <
					text = <"No improvement note">
					description = <"A note indicating that the addition or use of another type of aid did not result in a better test result.">
					comment = <"Used where a determination of the exact visual acuity with the additional correction (in another event) was not performed, typically because it was deemed irrelevant for lack of improvement.
Coding with a terminology is recommended. Free text entry should only be permitted if no appropriate coded value is available.">
				>
				["at0416"] = <
					text = <"NI with additional pinhole">
					description = <"No improvement with an additional pinhole placed in front of the tested eye.">
				>
				["at0417"] = <
					text = <"NI with subjective refraction-based correction">
					description = <"No improvement with corrective lenses based on subjective refraction.">
				>
				["at0418"] = <
					text = <"Pupil state">
					description = <"Statement describing the condition of the individual's pupils during the test.">
					comment = <"The physical examination of the eye will be recorded using the CLUSTER.exam-eye family of archetypes. 
Coding with a terminology is recommended. Free text entry should only be permitted if no appropriate coded value is available.">
				>
				["at0419"] = <
					text = <"Normal">
					description = <"The pupil is in its natural physiological state without pharmacological intervention or pathological changes.">
				>
				["at0420"] = <
					text = <"Medically induced mydriasis">
					description = <"The pupil was dilated due to prior administration of mydriatic agents.">
				>
				["at0421"] = <
					text = <"Medically induced miosis">
					description = <"The pupil was constricted due to prior administration of miotic agents.">
				>
				["at0422"] = <
					text = <"Pathological pupil state">
					description = <"The pupil was in an unphysiological state due to disease, trauma, or structural abnormalities.">
				>
				["at0461"] = <
					text = <"Result">
					description = <"A grouping of data elements to represent the primary notation of the visual acuity assessment result.
">
					comment = <"Typically, only one result should be populated.  
Converted or derived values should be stored in the appropriate element in the 'Derived result' cluster.">
				>
				["at0464"] = <
					text = <"Power of sphere">
					description = <"The refractive power that is equal in all meridians.">
					comment = <"Used as the base correction upon which cylinder and axis are applied.">
				>
				["at0465"] = <
					text = <"Visual aid details">
					description = <"Structured details about the device used as a visual aid during testing, such as a phoropter, trial frame, glasses, or contact lenses.">
				>
				["at0466"] = <
					text = <"Power of cylinder">
					description = <"The refractive power added to the spherical correction at the meridian 90° from the cylinder axis to compensate for astigmatism.">
				>
				["at0467"] = <
					text = <"Axis of cylinder">
					description = <"The orientation of the cylinder in degrees.">
					comment = <"By convention, the axis of the cylinder is defined by its meridian of zero power.">
				>
				["at0468"] = <
					text = <"Near addition">
					description = <"The additional spherical lens power for near vision.">
				>
				["at0471"] = <
					text = <"Physical object">
					description = <"Physical objects other than charts or cards.">
				>
				["at0472"] = <
					text = <"Berkeley rudimentary vision test">
					description = <"Berkeley rudimentary vision test was used.">
				>
				["at0473"] = <
					text = <"Near reading card">
					description = <"A near card with segments of text that are read by the individual was used.">
				>
				["at0474"] = <
					text = <"LEA grating acuity test">
					description = <"LEA gratings, a type of preferential looking test, was used.">
				>
				["at0475"] = <
					text = <"Teller acuity cards">
					description = <"Teller acuity cards were used.">
				>
				["at0476"] = <
					text = <"Cardiff acuity test">
					description = <"A Cardiff acuity test was used.">
				>
				["at0483"] = <
					text = <"Allen picture test">
					description = <"An Allen picture test was used.">
				>
				["at0484"] = <
					text = <"Sheridan letter test">
					description = <"A Sheridan letter test was used.">
				>
				["at0485"] = <
					text = <"Cambridge crowding cards">
					description = <"A Cambridge crowding card test was used.">
				>
				["at0486"] = <
					text = <"MNREAD chart">
					description = <"A MNREAD acuity chart was used.">
				>
				["at0487"] = <
					text = <"Radner Reading chart">
					description = <"A Radner reading chart was used.">
				>
				["at0488"] = <
					text = <"Freiburg visual acuity test">
					description = <"A Freiburg visual acuity test was used.">
				>
				["at0489"] = <
					text = <"Sheridan Gardiner test">
					description = <"A Sheridan Gardiner test was used.">
				>
				["at0490"] = <
					text = <"Integrated virtual chart display">
					description = <"A chart presented as a virtual image inside a device, such as an autorefractor.">
				>
				["at0491"] = <
					text = <"Cycles per centimetre result">
					description = <"The number of cycles (line pairs) per centimetre of the finest grating pattern recognized by the individual.">
					comment = <"Strictly not a unit of visual acuity but a measure of stimulus size.">
				>
				["at0492"] = <
					text = <"Cycles per degree result">
					description = <"The visual acuity measured and expressed as the number of pairs of black and white lines (cycles) that subtend an angle of one degree at the tested eye.">
					comment = <"Used in grating based tests such as Teller acuity cards. ">
				>
				["at0493"] = <
					text = <"Derived cycles per degree">
					description = <"Visual acuity as cycles per degree, derived by conversion from the primary recording.">
				>
				["at0494"] = <
					text = <"NI with autorefraction-based correction">
					description = <"No improvement with corrective lenses based on an autorefraction test.">
				>
				["at0495"] = <
					text = <"NI with glasses">
					description = <"No improvement with eyeglasses.">
				>
				["at0496"] = <
					text = <"NI with soft contact lens">
					description = <"No improvement with a soft contact lens.">
				>
				["at0497"] = <
					text = <"NI with retinoscopy-based correction">
					description = <"No improvement with corrective lenses based on retinoscopy.">
				>
				["at0498"] = <
					text = <"NI with rigid contact lens">
					description = <"No improvement with a hard contact lens.">
				>
				["at0499"] = <
					text = <"Sonksen Silver test">
					description = <"A Sonksen Silver test was used.">
				>
				["at0500"] = <
					text = <"Cycloplegia during refraction">
					description = <"Information on whether the correction used was based on a measurement of the refractive error in a cycloplegic state.">
				>
				["at0501"] = <
					text = <"Cycloplegic refraction">
					description = <"The correction used was based on a measurement of refractive error in a cycloplegic state.">
				>
				["at0502"] = <
					text = <"Non-cycloplegic refraction">
					description = <"The correction used was based on a measurement of refractive error in a non-cycloplegic state.">
				>
				["at0510"] = <
					text = <"NI with further correction">
					description = <"No improvement with an unspecified further correction.">
				>
				["at0512"] = <
					text = <"Supplementary results">
					description = <"Additional structured details on visual acuity test result not captured in other data elements.">
					comment = <"Examples include specifying the card scored in a Cardiff acuity test, or supplementary results on reading visual acuity tests. ">
				>
				["at0513"] = <
					text = <"Contrast category">
					description = <"A statement on the contrast level of the test.">
					comment = <"Note that the majority of visual acuity tests are performed under high contrast conditions.
Where possible, population of quantitative elements on contrast is encouraged.">
				>
				["at0514"] = <
					text = <"High-contrast">
					description = <"The test was performed with high contrast.">
				>
				["at0515"] = <
					text = <"Low-contrast">
					description = <"The test was performed with low contrast.">
				>
				["at0516"] = <
					text = <"Optotype presentation details">
					description = <"Details on how the optotypes were presented, including statements on crowding.">
				>
				["at0517"] = <
					text = <"Defocus lens">
					description = <"A lens used with the intention of adding refractive error.">
				>
				["at0518"] = <
					text = <"N 1">
					description = <"N font size 1.">
				>
