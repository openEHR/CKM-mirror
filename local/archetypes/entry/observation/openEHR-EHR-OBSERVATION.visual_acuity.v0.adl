				>
				["at0558"] = <
					text = <"Crowdedness">
					description = <"A categorical statement on whether a crowding effect is expected to be induced by the visual stimulus.">
					comment = <"Additional detail on the degree of crowding, and presence of crowding bars can be recorded using the 'Optotype presentation details' SLOT.">
				>
				["at0560"] = <
					text = <"Crowded">
					description = <"The stimulus was presented in a manner thought to induce a crowding effect.">
				>
				["at0561"] = <
					text = <"Not Crowded">
					description = <"The stimulus was presented in a manner thought to induce no crowding effect.">
				>
				["at0562"] = <
					text = <"Type of ancillary lighting used">
					description = <"Type of light sources used in addition to the typical room, stimulus or chart lighting.">
					comment = <"Coding with a terminology is recommended. Free text entry should only be permitted if no appropriate coded value is available.">
				>
				["at0563"] = <
					text = <"Glare light">
					description = <"A light source, or multiple light sources were directed at the eye to induce glare.">
				>
				["at0564"] = <
					text = <"Brightness Acuity Test">
					description = <"A handheld ganzfeld illumination device was used to simulate environmental brightness.">
				>
				["at0565"] = <
					text = <"Comment">
					description = <"Narrative comment about the specific visual aid used.">
				>
				["at0566"] = <
					text = <"J1">
					description = <"Jaeger font size 1.">
				>
				["at0567"] = <
