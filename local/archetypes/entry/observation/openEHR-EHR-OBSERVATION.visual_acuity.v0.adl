					text = <"*Light adaptation state (en)">
					description = <"*The presumed adaptation state of the visual system during testing. (en)">
					comment = <"*This is a categorical description of the individual's presumed retinal adaptation state, not a measurement of the ambient lighting. (en)">
				>
				["at0590"] = <
					text = <"*Photopic (en)">
					description = <"*The individual is adapted to high luminance conditions. (en)">
				>
				["at0591"] = <
					text = <"*Mesopic (en)">
					description = <"*The individual is in a transitional adaptation state between photopic and scotopic. (en)">
