				["at0558"] = <
					text = <"*Crowdedness (en)">
					description = <"*A categorical statement on whether a crowding effect is expected to be induced by the visual stimulus. (en)">
					comment = <"*Additional detail on the degree of crowding, and presence of crowding bars can be recorded using the 'Optotype presentation details' SLOT. (en)">
				>
