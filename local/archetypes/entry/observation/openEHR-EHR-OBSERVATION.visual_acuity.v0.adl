					text = <"*Type of ancillary lighting used (en)">
					description = <"*Type of light sources used in addition to the typical room, stimulus or chart lighting. (en)">
					comment = <"*Coding with a terminology is recommended. Free text entry should only be permitted if no appropriate coded value is available. (en)">
				>
				["at0563"] = <
					text = <"*Glare light (en)">
					description = <"*A light source, or multiple light sources were directed at the eye to induce glare. (en)">
				>
				["at0564"] = <
					text = <"*Brightness Acuity Test (en)">
					description = <"*A handheld ganzfeld illumination device was used to simulate environmental brightness. (en)">
				>
				["at0565"] = <
					text = <"*Comment (en)">
					description = <"*Narrative comment about the specific visual aid used. (en)">
