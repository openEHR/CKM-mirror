	openEHR-EHR-OBSERVATION.physical_activity_screening.v0

concept
	[at0000]	-- Physical activity screening questionnaire
language
	original_language = <[ISO_639-1::en]>
	translations = <
		["nb"] = <
			language = <[ISO_639-1::nb]>
