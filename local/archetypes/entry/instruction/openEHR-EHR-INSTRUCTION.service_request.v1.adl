				["at0011"] = <
					text = <"Identificador do recetor do pedido">
					description = <"O identificador local atribuído ao pedido pelo médico ou organização que recebe o pedido de serviço.">
					comment = <"Geralmente equivalente ao HL7 Filler Order Identifier.">
				>
				["at0040"] = <
					text = <"Momento do serviço">
					description = <"A data/hora ou descrição sobre o momento da prestação do(s) serviço(s) solicitado(s).">
					comment = <"Este elemento de dados permite o registo do momento do(s) serviço(s), seja como data e hora, um intervalo de data e hora ou um descritor de texto. Na prática, os médicos pensarão muitas vezes em termos de pedidos de serviços como um momento relativo ou aproximado, por exemplo: ‘próximo disponível’, ou em ‘3 meses’. Uma vez que os sistemas clínicos necessitam de parâmetros mais exatos para funcionar, estes “3 meses” serão geralmente convertidos para uma data exata de 3 meses a partir da data do registo e armazenados utilizando este elemento de dados. Se forem necessárias temporizações complexas ou sequências de temporizações, utilize o arquétipo CLUSTER.service_direction dentro do SLOT 'Temporização complexa' e este elemento de dados tornar-se-á redundante.">
				>
				["at0062"] = <
					text = <"Motivo do pedido">
					description = <"O problema específico que requer atenção ou a questão clínica que requer investigação.">
					comment = <"É desejável a codificação do 'Motivo do pedido' com uma terminologia externa, se disponível. Este elemento de dados permite múltiplas ocorrências para permitir ao utilizador registar múltiplas respostas, se necessário.">
				>
				["at0064"] = <
					text = <"Descrição do motivo">
					description = <"Descrição narrativa sobre o problema ou dúvida clínica que necessita de ser resolvida.">
				>
				["at0065"] = <
					text = <"Intenção">
					description = <"Descrição do resultado pretendido do pedido.">
					comment = <"Recomenda-se a codificação da 'Intenção' com uma terminologia externa, se disponível. Este elemento de dados permite múltiplas ocorrências para permitir ao utilizador registar múltiplas respostas, se necessário.">
				>
				["at0068"] = <
					text = <"Urgência">
					description = <"Urgência da solicitação de atendimento.">
					comment = <"As definições específicas de emergência e urgência variam entre contextos clínicos, sistemas clínicos e a natureza do pedido em si, pelo que não foram definidas neste arquétipo. Os requisitos de temporização mais precisos devem ser especificados utilizando o elemento de dados 'Serviço até' ou o arquétipo CLUSTER.service_direction dentro do SLOT 'Tempo complexo'.">
				>
				["at0076"] = <
					text = <"Informação suplementar">
					description = <"Informações complementares estarão disponíveis mediante pedido.">
					comment = <"Registe como VERDADEIRO se foram identificadas informações adicionais e serão encaminhadas quando disponíveis. Por exemplo: resultados de testes pendentes.">
				>
				["at0078"] = <
					text = <"Descrição da informação">
					description = <"Descrição das informações complementares.">
				>
				["at0112"] = <
					text = <"Extensão">
					description = <"Informação adicional necessária para ampliar o modelo com conteúdo local ou para o alinhar com outros modelos de referência ou formalismos.">
					comment = <"Por exemplo: requisitos de informação local; ou metadados adicionais para alinhar com o FHIR.">
				>
				["at0116"] = <
					text = <"Requisitos do paciente">
					description = <"Língua, transporte ou outros requisitos pessoais para apoiar a comparência ou participação do doente na prestação do serviço.">
				>
				["at0121"] = <
					text = <"Nome do serviço">
					description = <"O(s) nome(s) do(s) serviço(s) solicitado(s).">
					comment = <"É altamente recomendável codificar o 'Nome do serviço' com uma terminologia externa, se disponível. Este elemento de dados permite múltiplas ocorrências para permitir ao utilizador registar vários serviços como parte de um único pedido, se necessário.">
				>
				["at0127"] = <
					text = <"Estado do pedido">
					description = <"O estado do pedido de serviço conforme indicado pelo requerente.">
					comment = <"O estado é utilizado para indicar se esta é a solicitação inicial ou uma solicitação de acompanhamento para alterar ou fornecer informações complementares. É preferível codificar com uma terminologia, sempre que possível.">
				>
				["at0128"] = <
					text = <"Lista de distribuição">
					description = <"Detalhes de médicos, organizações ou agências adicionais que exijam cópias de qualquer comunicação.">
				>
				["at0132"] = <
					text = <"Detalhes específicos">
					description = <"Detalhes adicionais sobre o serviço solicitado.">
				>
				["at0135"] = <
					text = <"Descrição">
					description = <"Descrição narrativa sobre o serviço solicitado.">
					comment = <"Este ponto de dados deve ser utilizado para descrever o serviço nomeado com mais detalhe, incluindo a forma como deve ser prestado, as preocupações do doente e os problemas que podem ser encontrados na prestação do serviço.">
				>
				["at0136"] = <
					text = <"Emergência">
					description = <"O pedido requer atenção imediata.">
				>
				["at0137"] = <
					text = <"O pedido requer atenção imediata.">
					description = <"O pedido requer atenção prioritária.">
				>
				["at0138"] = <
					text = <"Rotina">
					description = <"O pedido não requer agendamento prioritário.">
				>
				["at0141"] = <
					text = <"Requerente">
					description = <"Detalhes sobre o médico ou organização que solicita o serviço.">
				>
				["at0142"] = <
					text = <"Recetor">
					description = <"Detalhes sobre o médico ou organização que recebe o pedido de serviço.">
				>
				["at0148"] = <
					text = <"Tipo de serviço">
					description = <"Categoria do serviço solicitado.">
					comment = <"É desejável a codificação do 'Tipo de serviço' com uma terminologia externa, se disponível. Se o 'Nome do serviço' tiver sido codificado, é possível que este ponto de dados seja derivado do código.">
				>
				["at0149"] = <
					text = <"Informações de apoio">
					description = <"Documento digital, imagem, vídeo ou diagrama fornecido como informação adicional para apoiar ou informar o pedido.">
				>
				["at0150"] = <
					text = <"Comentário">
					description = <"Narrativa adicional sobre o pedido de serviço não capturada noutros campos.">
				>
				["at0151"] = <
					text = <"Tempo complexo">
					description = <"Detalhes sobre um pedido de serviço complexo que exige uma sequência de horários.">
					comment = <"Por exemplo: 'observações dos sinais vitais de hora a hora durante 4 horas, depois de 4 em 4 horas durante 20 horas' ou 'todas quartas-feiras de três em três semanas até completar 3 consultas' ou 'Dia 14-16 do ciclo menstrual'. Se forem necessárias temporizações complexas ou sequências de temporizações utilizando o arquétipo CLUSTER.service_direction neste SLOT, o elemento de dados 'Momento do serviço' tornar-se-á redundante.">
				>
				["at0152"] = <
					text = <"Indicação clínica">
					description = <"O sintoma, sinal ou diagnóstico que necessita do serviço solicitado.">
					comment = <"Recomenda-se a codificação da 'Indicação clínica' com uma terminologia externa, se disponível. Este elemento de dados permite múltiplas ocorrências para permitir ao utilizador registar múltiplas respostas, se necessário.">
				>
				["at0153"] = <
					text = <"Detalhe do pedido">
					description = <"Detalhes e instruções adicionais sobre como os serviços serão prestados.">
					comment = <"É desejável a codificação dos “Detalhes da encomenda” com uma terminologia externa, se disponível. Este elemento de dados permite múltiplas ocorrências para permitir ao utilizador registar múltiplas respostas, se necessário.">
				>
				["at0154"] = <
					text = <"Contexto clínico">
					description = <"Informação narrativa sobre o indivíduo e a sua situação, fornecendo contexto relevante para a solicitação.">
				>
				["at0155"] = <
					text = <"Contacto urgente">
					description = <"Detalhes sobre a pessoa ou organização de contacto designada e modo de contacto preferencial para notificações urgentes ou de emergência relacionadas com este pedido.">
					comment = <"Por exemplo: se o resultado do pedido exigir uma resposta urgente ou de emergência por parte do requerente.">
				>
				["at0156"] = <
					text = <"Orientação de faturação">
					description = <"Uma recomendação do requerente ao destinatário sobre a forma de pagamento do serviço.">
					comment = <"Por exemplo: 'Privado'; 'Regime de seguro governamental'; ou 'Seguro privado'.">
				>
				["at0157"] = <
					text = <"Responsável pelo pagamento">
					description = <"Detalhes sobre o indivíduo ou organização que assumirá a responsabilidade pelo pagamento do serviço.">
					comment = <"Este elemento de dados só será utilizado se tiver sido identificado um ordenante conhecido. Por exemplo: um indivíduo, como um progenitor, em nome de uma criança; ou uma organização, como um local de trabalho ou um plano de seguro governamental.">
				>
				["at0158"] = <
					text = <"Orientação de elegibilidade">
					description = <"Aconselhamento do requerente ao destinatário sobre a elegibilidade do indivíduo para o serviço solicitado.">
				>
			>
		>
		["el"] = <
			items = <
				["at0000"] = <
					text = <"Αίτημα παροχής υπηρεσίας">
					description = <"Αίτημα παροχής υπηρεσίας ή δραστηριότητας που σχετίζεται με την υγεία από κλινικό ιατρό, οργανισμό ή οργανισμό.">
				>
				["at0001"] = <
					text = <"Τρέχων δραστηριότητα">
					description = <"*Current Activity.(en)">
				>
				["at0008"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0009"] = <
					text = <"Tree">
					description = <"@ internal @">
				>
				["at0010"] = <
					text = <"Αναγνωριστικό αίτησης αιτούντος">
					description = <"Το τοπικό αναγνωριστικό που εκχωρείται από το αιτούν κλινικό σύστημα.">
					comment = <"Συνήθως ισοδυναμεί με το αναγνωριστικό παραγγελίας τοποθέτησης HL7.">
				>
				["at0011"] = <
					text = <"Αναγνωριστικό εντολής παραλήπτη">
					description = <"Το τοπικό αναγνωριστικό που αποδίδεται στο αίτημα από τον κλινικό ιατρό ή τον οργανισμό που λαμβάνει το αίτημα για υπηρεσία.">
					comment = <"Συνήθως ισοδύναμο με το αναγνωριστικό παραγγελίας πλήρωσης HL7.">
				>
				["at0040"] = <
					text = <"Οφειλόμενη υπηρεσία">
					description = <"Η ημερομηνία/ώρα ή η περιγραφή σχετικά με το χρονοδιάγραμμα παροχής της/των ζητούμενης/-ων υπηρεσίας/υπηρεσιών.">
					comment = <"Αυτό το στοιχείο δεδομένων επιτρέπει την καταγραφή του χρονοδιαγράμματος για την/τις υπηρεσία/-ες, είτε ως ημερομηνία και ώρα, είτε ως χρονικό διάστημα ημερομηνίας και ώρας, είτε ως περιγραφέας κειμένου. Στην πράξη, οι κλινικοί ιατροί συχνά σκέφτονται από την άποψη της παραγγελίας υπηρεσιών ως σχετικό ή κατά προσέγγιση χρονοδιάγραμμα, για παράδειγμα: «επόμενο διαθέσιμο» ή σε «3 μήνες». Καθώς τα κλινικά συστήματα χρειάζονται ακριβέστερες παραμέτρους για να λειτουργήσουν, αυτοί οι «3 μήνες» συνήθως μετατρέπονται σε ακριβή ημερομηνία 3 μηνών από την ημερομηνία καταγραφής και αποθηκεύονται χρησιμοποιώντας αυτό το στοιχείο δεδομένων. Εάν απαιτείται σύνθετος χρονισμός ή ακολουθίες χρονισμών, χρησιμοποιήστε το αρχέτυπο CLUSTER. service_direction εντός της υποδοχής «Σύνθετος χρονισμός» και αυτό το στοιχείο δεδομένων καθίσταται περιττό.">
				>
				["at0062"] = <
					text = <"Λόγος αιτήματος">
					description = <"Το συγκεκριμένο πρόβλημα που χρειάζεται προσοχή ή το κλινικό ερώτημα που απαιτεί διερεύνηση">
					comment = <"Είναι επιθυμητή η κωδικοποίηση του «Λόγου αίτησης» με εξωτερική ορολογία, εφόσον υπάρχει. Αυτό το στοιχείο δεδομένων επιτρέπει πολλαπλές εμφανίσεις για να επιτρέψει στο χρήστη να καταγράψει πολλαπλές αποκρίσεις, εάν απαιτείται.">
				>
				["at0064"] = <
					text = <"Περιγραφή λόγου">
					description = <"Αφηγηματική περιγραφή σχετικά με το ζήτημα ή το κλινικό ερώτημα που χρειάζεται επίλυση.">
				>
				["at0065"] = <
					text = <"Πρόθεση/ Σκοπός">
					description = <"Περιγραφή της επιδιωκόμενης έκβασης της αίτησης.">
					comment = <"Συνιστάται η κωδικοποίηση της «πρόθεσης» με εξωτερική ορολογία, εάν υπάρχει. Αυτό το στοιχείο δεδομένων επιτρέπει πολλαπλές εμφανίσεις για να επιτρέψει στο χρήστη να καταγράψει πολλαπλές αποκρίσεις, εάν απαιτείται.">
				>
				["at0068"] = <
					text = <"Επείγον">
					description = <"Επείγον της αίτησης επίδοσης ή κοινοποίησης.">
					comment = <"Οι συγκεκριμένοι ορισμοί του επείγοντος και του επείγοντος θα διαφέρουν μεταξύ των κλινικών πλαισίων, των κλινικών συστημάτων και της φύσης του ίδιου του αιτήματος, επομένως δεν έχουν οριστεί σε αυτό το αρχέτυπο. Οι ακριβέστερες απαιτήσεις χρονισμού θα πρέπει να προσδιορίζονται χρησιμοποιώντας το στοιχείο δεδομένων «Οφειλόμενη υπηρεσία» ή το αρχέτυπο CLUSTER. service_direction εντός της υποδοχής «Σύνθετος χρονισμός».">
				>
				["at0076"] = <
					text = <"Συμπληρωματικές πληροφορίες">
					description = <"Συμπληρωματικές πληροφορίες θα παρέχονται κατόπιν αιτήματος.">
					comment = <"Καταγράψτε ως TRUE εάν έχουν εντοπιστεί πρόσθετες πληροφορίες και θα προωθηθούν όταν θα είναι διαθέσιμες. Για παράδειγμα: εκκρεμή αποτελέσματα δοκιμών.">
				>
				["at0078"] = <
					text = <"Περιγραφή πληροφοριών">
					description = <"Περιγραφή των συμπληρωματικών πληροφοριών.">
				>
				["at0112"] = <
					text = <"*Extension(en)">
					description = <"*Additional information required to extend the model with local content or to align with other reference models or formalisms.(en)">
					comment = <"*For example: local information requirements; or additional metadata to align with FHIR.(en)">
				>
				["at0116"] = <
					text = <"Απαιτήσεις ασθενών">
					description = <"Γλωσσικές, μεταφορικές ή άλλες προσωπικές απαιτήσεις για την υποστήριξη της παρακολούθησης ή της συμμετοχής του ασθενούς στην παροχή της υπηρεσίας.">
				>
				["at0121"] = <
					text = <"Όνομα υπηρεσίας">
					description = <"Το όνομα της υπηρεσίας ή των υπηρεσιών που ζητήθηκαν.">
					comment = <"Συνιστάται ιδιαίτερα η κωδικοποίηση του «ονόματος υπηρεσίας» με εξωτερική ορολογία, εάν υπάρχει. Αυτό το στοιχείο δεδομένων επιτρέπει πολλαπλές εμφανίσεις για να επιτρέψει στον χρήστη να καταγράψει πολλές υπηρεσίες ως μέρος ενός μόνο αιτήματος, εάν απαιτείτα">
				>
				["at0127"] = <
					text = <"Κατάσταση αιτήματος">
					description = <"Η κατάσταση της αίτησης επίδοσης ή κοινοποίησης, όπως υποδεικνύεται από τον αιτούντα.">
					comment = <"Η κατάσταση χρησιμοποιείται για να δηλώσει εάν αυτό είναι το αρχικό αίτημα ή ένα αίτημα παρακολούθησης για αλλαγή ή παροχή συμπληρωματικών πληροφοριών. Προτιμάται η κωδικοποίηση με ορολογία, όπου είναι δυνατόν">
				>
				["at0128"] = <
					text = <"Λίστα διανομής">
					description = <"Στοιχεία πρόσθετων κλινικών ιατρών, οργανισμών ή υπηρεσιών που απαιτούν αντίγραφα οποιασδήποτε επικοινωνίας.">
				>
				["at0132"] = <
					text = <"Ειδικές λεπτομέρειες">
					description = <"Πρόσθετες λεπτομέρειες σχετικά με την υπηρεσία που ζητήθηκε.">
				>
				["at0135"] = <
					text = <"Περιγραφή">
					description = <"Αφηγηματική περιγραφή σχετικά με την υπηρεσία που ζητήθηκε.">
					comment = <"Αυτό το σημείο δεδομένων θα πρέπει να χρησιμοποιείται για την περιγραφή της κατονομαζόμενης υπηρεσίας με περισσότερες λεπτομέρειες, συμπεριλαμβανομένου του τρόπου παροχής της, των ανησυχιών των ασθενών και των ζητημάτων που ενδέχεται να προκύψουν κατά την παροχή της υπηρεσίας.">
				>
				["at0136"] = <
					text = <"Έκτακτης ανάγκης">
					description = <"Το αίτημα απαιτεί άμεση προσοχή.">
				>
				["at0137"] = <
					text = <"Επείγων">
					description = <"Το αίτημα απαιτεί προσοχή κατά προτεραιότητα.">
				>
				["at0138"] = <
					text = <"Ρουτίνα">
					description = <"Το αίτημα δεν απαιτεί προγραμματισμό προτεραιότητας.">
				>
				["at0141"] = <
					text = <"Αιτών">
					description = <"Λεπτομέρειες σχετικά με τον κλινικό ιατρό ή τον οργανισμό που ζητά την υπηρεσία.">
				>
				["at0142"] = <
					text = <"Δέκτης">
					description = <"Λεπτομέρειες σχετικά με τον κλινικό ιατρό ή τον οργανισμό που λαμβάνει το αίτημα επίδοσης ή κοινοποίησης">
				>
				["at0148"] = <
					text = <"Τύπος υπηρεσίας">
					description = <"Κατηγορία ζητούμενης υπηρεσίας.">
					comment = <"Είναι επιθυμητή η κωδικοποίηση του «τύπου υπηρεσίας» με εξωτερική ορολογία, εφόσον υπάρχει. Εάν το «όνομα υπηρεσίας» ήταν κωδικοποιημένο, είναι πιθανό αυτό το σημείο δεδομένων να προέρχεται από τον κωδικό.">
				>
				["at0149"] = <
					text = <"Υποστηρικτικές πληροφορίες">
					description = <"Ψηφιακό έγγραφο, εικόνα, βίντεο ή διάγραμμα που παρέχονται ως πρόσθετες πληροφορίες για την υποστήριξη ή την ενημέρωση του αιτήματος.">
				>
				["at0150"] = <
					text = <"Σχόλιο">
					description = <"Πρόσθετη αφήγηση σχετικά με το αίτημα εξυπηρέτησης που δεν καταγράφεται σε άλλα πεδία.">
				>
				["at0151"] = <
					text = <"Πολύπλοκος χρονισμός">
					description = <"Λεπτομέρειες σχετικά με μια σύνθετη αίτηση εξυπηρέτησης που απαιτεί μια ακολουθία χρονισμών.">
					comment = <"Για παράδειγμα: «ωριαίες παρατηρήσεις ζωτικών σημείων για 4 ώρες, στη συνέχεια 4 ωριαίες για 20 ώρες» ή «κάθε τρίτη Τετάρτη για 3 επισκέψεις» ή «Ημέρα 14-16 του εμμηνορροϊκού κύκλου». Εάν απαιτείται πολύπλοκος χρονισμός ή ακολουθίες χρονισμών χρησιμοποιώντας το αρχέτυπο CLUSTER. service_direction σε αυτήν την υποδοχή, το στοιχείο δεδομένων «Οφειλόμενη υπηρεσία» καθίσταται περιττό.">
				>
				["at0152"] = <
					text = <"Κλινική ένδειξη">
					description = <"Το σύμπτωμα, το σημείο ή η διάγνωση που απαιτεί τη ζητούμενη υπηρεσία.">
					comment = <"Συνιστάται η κωδικοποίηση της «κλινικής ένδειξης» με εξωτερική ορολογία, εάν υπάρχει. Αυτό το στοιχείο δεδομένων επιτρέπει πολλαπλές εμφανίσεις για να επιτρέψει στο χρήστη να καταγράψει πολλαπλές αποκρίσεις, εάν απαιτείται.">
				>
				["at0153"] = <
					text = <"Άλλες πληροφορίες">
					description = <"Πρόσθετες λεπτομέρειες και οδηγίες σχετικά με τον τρόπο παροχής των υπηρεσιών.">
					comment = <"Η κωδικοποίηση των «λεπτομερειών παραγγελίας» με εξωτερική ορολογία είναι επιθυμητή, εάν υπάρχει. Αυτό το στοιχείο δεδομένων επιτρέπει πολλαπλές εμφανίσεις για να επιτρέψει στο χρήστη να καταγράψει πολλαπλές αποκρίσεις, εάν απαιτείται.">
				>
				["at0154"] = <
					text = <"Κλινικό πλαίσιο">
					description = <"Αφηγηματικές πληροφορίες σχετικά με το άτομο και την κατάστασή του, παρέχοντας σχετικό πλαίσιο για το αίτημα.">
				>
				["at0155"] = <
					text = <"Επαφή έκτατης ανάγκης">
					description = <"Λεπτομέρειες σχετικά με το πρόσωπο ή τον οργανισμό που έχει οριστεί και τον προτιμώμενο τρόπο επικοινωνίας για επείγουσες ή επείγουσες κοινοποιήσεις που σχετίζονται με το εν λόγω αίτημα.">
					comment = <"Για παράδειγμα: εάν η έκβαση του αιτήματος απαιτεί επείγουσα απάντηση ή απάντηση έκτακτης ανάγκης από τον αιτούντα.">
				>
				["at0156"] = <
					text = <"Οδηγίες χρέωσης">
					description = <"Σύσταση από τον αιτούντα προς τον παραλήπτη σχετικά με τον τρόπο πληρωμής για την υπηρεσία.">
					comment = <"Για παράδειγμα: \"Ιδιωτικό\". «Κρατικό σύστημα ασφάλισης»· ή «Ιδιωτική ασφάλιση».">
				>
				["at0157"] = <
					text = <"Υπεύθυνος πληρωτής">
					description = <"Λεπτομέρειες σχετικά με το άτομο ή τον οργανισμό που θα αναλάβει την ευθύνη για την πληρωμή της υπηρεσίας.">
					comment = <"Αυτό το στοιχείο δεδομένων θα χρησιμοποιηθεί μόνο εάν έχει ταυτοποιηθεί γνωστός πληρωτής. Για παράδειγμα: ένα άτομο, όπως ένας γονέας για λογαριασμό ενός παιδιού. ή οργανισμό, όπως χώρο εργασίας ή κρατικό ασφαλιστικό σύστημα·">
				>
				["at0158"] = <
					text = <"Οδηγίες επιλεξιμότητας">
					description = <"Συμβουλές από τον αιτούντα προς τον παραλήπτη σχετικά με την επιλεξιμότητα του ατόμου για την αιτούμενη υπηρεσία.">
				>
			>
		>
	>
