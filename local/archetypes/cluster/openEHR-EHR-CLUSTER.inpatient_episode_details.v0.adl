archetype (adl_version=1.4; uid=4fd4f954-b0dd-4c50-9483-74baca9b6a6a)
	openEHR-EHR-CLUSTER.inpatient_episode_details.v0

concept
	[at0000]	-- Encounter details
language
	original_language = <[ISO_639-1::en]>
	translations = <
		["nb"] = <
			language = <[ISO_639-1::nb]>
			author = <
				["name"] = <"Martin Milde">
				["organisation"] = <"Helse Vest IKT">
				["email"] = <"martin.milde@helse-vest-ikt.no">
			>
		>
	>
description
	original_author = <
		["name"] = <"Heather Leslie">
		["organisation"] = <"Atomica Informatics">
		["email"] = <"heather.leslie@atomicainformatics.com">
		["date"] = <"2022-06-13">
	>
	details = <
		["nb"] = <
			language = <[ISO_639-1::nb]>
			purpose = <"For å registrere detaljer om en klinisk kontakt.">
			use = <"Brukes til å registrere detaljer om en klinisk kontakt mellom en pasient og helsetjenester.

I konteksten av denne arketypen så tolkes klinisk kontakt i vid forstand, og inkluderer enhver kontakt mellom en pasient og helsetjenester som det er behov for å registrere. Dette inkluderer, men er ikke begrenset til, fastlegebesøk, polikliniske besøk, døgnbehandling, akuttinnleggelser, hjemmebesøk eller psykisk helsehjelp.

Som følge av dette så har både konseptet og dataelementene blitt gitt veldig generiske navn. Det forventes at disse ikke vil passe i alle myndighetsområder eller bruksområder, og må endres i templatet for å bedre passe den aktuelle bruken.

Del-episode slotten er designet for å motta gjentagende utgaver av dette clusteret for å modellere del-kontakter. For eksempel, en instans av dette clusteret kan brukes for å registrere et sykehusopphold, og en del-episode kan brukes for å registrere innleggelse ved akuttmottaket, men en annen del-episode kan brukes for å registrere overføringen til en annen avdeling. Disse clusterne kan deles videre opp som nødvendig for å registrere nødvendige kontakter.

Opphav, opphavskategori, destinasjon og destinasjonskategori er ment for å gi alternativer for hvordan man registrerer hvor pasienten kom fra og hvor de dro til. Opphavskategori og destinasjonskategori  er ment for å gi generell informasjon om hvor en pasient kom fra og hvor de dro til, mens opphav og destinasjon slottene er ment for å identifisere spesifikke organisasjoner og/eller lokasjoner.">
			keywords = <"innleggelse, utskrivning, overføring, besøk, opphold, sykehusinnleggelse, innlagt, kontakt, død", ...>
			misuse = <"Skal ikke brukes til planlegging av fremtidige kliniske kontakter. På tidspunktet for utarbeidelsen er det ennå ikke avklart hvilken arketype som bør brukes til dette formålet.">
			copyright = <"© openEHR Foundation">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record details about an encounter between a patient and healthcare services.">
			use = <"Use to record details about an encounter between a patient and healthcare services.

Within the context of this archetype, encounter is interpreted broadly, and includes any contact between a patient and healthcare services that needs to be recorded. This includes, but is not limited to, visits to a general practitioner, outpatient treatment, inpatient treatment, admission to an emergency room, hospital at home or mental health appointments. 

As a result, both the concept and the data elements have been given very generic names. It is expected that these names will not be appropriate in all jurisdictions or use cases, and will need to be renamed in templates to better fit the specific context.

The Sub-episode Slot is designed to accept recursive elements of this cluster in order to model sub-encounters as needed. For instance, one instance of this cluster could be used to record a hospitalization, and a sub-episode used to record admission to the emergency room, while a different episode could be used to record a transfer to a different department. These cluster can be further sub-divided as needed to record specific encounters as needed.

Source, Source category, Destination and Destination category are intended to provide alternatives to one another in regarding where the patient came from and where they departed to. Source category and Destination category are intended to give broad indications of the source and destination, while the Source and Destination slots are intended to identify specific organisations and/or locations.">
			keywords = <"admission, discharge, transfer, separation, visit, stay, hospitalization, inpatient, death, care episode", ...>
			misuse = <"Not to be used for planning future encounter. At the time of authoring it is not yet determined which archetype should be used for this purpose.">
			copyright = <"© openEHR Foundation">
		>
	>
	lifecycle_state = <"in_development">
	other_contributors = <>
	other_details = <
		["licence"] = <"This work is licensed under the Creative Commons Attribution-ShareAlike 4.0 International License. To view a copy of this license, visit http://creativecommons.org/licenses/by-sa/4.0/.">
		["custodian_organisation"] = <"openEHR Foundation">
		["references"] = <"">
		["original_namespace"] = <"org.openehr">
		["original_publisher"] = <"openEHR Foundation">
		["custodian_namespace"] = <"org.openehr">
		["MD5-CAM-1.0.1"] = <"AC6A6CDC9B7C49D44A6AEAD6E44E7A64">
		["build_uid"] = <"0b18e75c-1e6c-4878-af63-ba7e926a2908">
		["revision"] = <"0.0.1-alpha">
	>

definition
	CLUSTER[at0000] matches {    -- Encounter details
		items cardinality matches {1..*; unordered} matches {
			ELEMENT[at0046] occurrences matches {0..1} matches {    -- Encounter ID
				value matches {
					DV_IDENTIFIER matches {*}
					DV_TEXT matches {*}
				}
			}
			allow_archetype CLUSTER[at0021] occurrences matches {0..1} matches {    -- Source
				include
					archetype_id/value matches {/openEHR-EHR-CLUSTER\.organisation\.v1|openEHR-EHR-CLUSTER\.address\.v1/}
			}
			ELEMENT[at0022] occurrences matches {0..1} matches {    -- Source category
				value matches {
					DV_TEXT matches {*}
				}
			}
			ELEMENT[at0003] occurrences matches {0..1} matches {    -- Reason
				value matches {
					DV_TEXT matches {*}
				}
			}
			ELEMENT[at0001] occurrences matches {0..1} matches {    -- Location
				value matches {
					DV_TEXT matches {*}
				}
			}
			allow_archetype CLUSTER[at0002] occurrences matches {0..1} matches {    -- Structured location
				include
					archetype_id/value matches {/openEHR-EHR-CLUSTER\.organisation\.v1|openEHR-EHR-CLUSTER\.address\.v1/}
			}
			ELEMENT[at0004] occurrences matches {0..1} matches {    -- Start
				value matches {
					DV_DATE_TIME matches {*}
				}
			}
			allow_archetype CLUSTER[at0019] occurrences matches {0..*} matches {    -- Sub-episode
				include
					archetype_id/value matches {/openEHR-EHR-CLUSTER\.inpatient_episode_details\.v0/}
			}
			allow_archetype CLUSTER[at0045] occurrences matches {0..1} matches {    -- Destination
				include
					archetype_id/value matches {/openEHR-EHR-CLUSTER\.organisation\.v1|openEHR-EHR-CLUSTER\.address\.v1/}
			}
			ELEMENT[at0047] occurrences matches {0..1} matches {    -- Destination category
				value matches {
					DV_TEXT matches {*}
				}
			}
			ELEMENT[at0005] occurrences matches {0..1} matches {    -- End
				value matches {
					DV_DATE_TIME matches {*}
				}
			}
			allow_archetype CLUSTER[at0048] occurrences matches {0..*} matches {    -- Additional details
				include
					archetype_id/value matches {/.*/}
			}
			ELEMENT[at0020] occurrences matches {0..1} matches {    -- Comment
				value matches {
					DV_TEXT matches {*}
				}
			}
		}
	}


ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Encounter details">
					description = <"Details about an encounter.">
				>
				["at0001"] = <
					text = <"Location">
					description = <"The physical location where the encounter took place.">
					comment = <"Coding with an external terminology is preferred, where possible. For example: doctor's office, emergency room, clinic.">
				>
				["at0002"] = <
					text = <"Structured location">
					description = <"Structured details about where the encounter took place.">
				>
				["at0003"] = <
					text = <"Reason">
					description = <"The reason for the encounter.">
					comment = <"Coding with an external terminology is preferred, where possible. For example: diagnosis, elective surgery, or childbirth.">
				>
				["at0004"] = <
					text = <"Start">
					description = <"The date/date-time when the encounter started.">
					comment = <"For example: admitted to inpatient facility, transferred to different ward.">
				>
				["at0005"] = <
					text = <"End">
					description = <"The date/date-time when the encounter ended.">
				>
				["at0019"] = <
					text = <"Sub-episode">
					description = <"Details about a sub-episode that consitutes part of the original encounter.">
					comment = <"This slot is intended to be used to add details about sub-episodes using nested instances of this archetype. Examples of sub-episodes can be transfers to different department or room/bed changes.">
				>
				["at0020"] = <
					text = <"Comment">
					description = <"Additional narrative about the encounter not captured in other fields.">
				>
				["at0021"] = <
					text = <"Source">
					description = <"The location/organization the patient was prior to the encounter.">
				>
				["at0022"] = <
					text = <"Source category">
					description = <"The type of location the patient was prior to the encounter.">
					comment = <"Coding with a terminology is desirable, where possible. For example: home, nursing home, incident site">
				>
				["at0045"] = <
					text = <"Destination">
					description = <"Location/organization to which the patient went to following the encounter.">
				>
				["at0046"] = <
					text = <"Encounter ID">
					description = <"An identifier for the encounter.">
				>
				["at0047"] = <
					text = <"Destination category">
					description = <"The type of location to which the patient went to following the encounter.">
					comment = <"Coding with a terminology is desirable, where possible.  For example: home, nursing home, other healthcare facility">
				>
				["at0048"] = <
					text = <"Additional details">
					description = <"Further details about the encounter.">
				>
			>
		>
		["nb"] = <
			items = <
				["at0000"] = <
					text = <"Klinisk kontakt detaljer">
					description = <"Detaljer om en klinisk kontakt.">
				>
				["at0001"] = <
					text = <"Lokasjon">
					description = <"Den fysiske lokasjonen hvor den kliniske kontakten fant sted.">
				>
				["at0002"] = <
					text = <"Strukturert lokasjon">
					description = <"Strukturerte detaljer om den fysiske lokasjonen hvor den kliniske kontakten fant sted.">
				>
				["at0003"] = <
					text = <"Årsak">
					description = <"Årsaken for den kliniske kontakten.">
					comment = <"Koding av årsak med en terminologi er foretrukket om mulig. For eksempel, diagnose, elektiv kirurgi, eller fødsel.">
				>
				["at0004"] = <
					text = <"Start">
					description = <"Dato/dato‑tidspunkt for når den kliniske kontakten startet.">
					comment = <"For eksempel, innlagt i døgninstitusjon, overført til annen avdeling.">
				>
				["at0005"] = <
					text = <"Stopp">
					description = <"Dato/dato‑tidspunkt for når den kliniske kontakten sluttet.">
				>
				["at0019"] = <
					text = <"Del-episode">
					description = <"Detaljer om en del‑episode som utgjør en del av den opprinnelige kliniske kontakten.">
					comment = <"Dette SLOT-et er ment for å legge inn detaljer om del‑episoder ved bruk av nestede instanser av denne arketypen. Eksempler på del‑episoder kan være overføringer til annen avdeling eller endringer av rom/seng">
				>
				["at0020"] = <
					text = <"Kommentar">
					description = <"Tekstlig tilleggsinformasjon om den kliniske kontakten som ikke er registrert i andre felt. ">
				>
				["at0021"] = <
					text = <"Opphav">
					description = <"Stedet/organisasjonen pasienten var før den kliniske kontakten.">
				>
				["at0022"] = <
					text = <"Opphavskategori">
					description = <"Typen sted pasienten var før den kliniske kontakten.">
					comment = <"Koding av opphavskategori med en terminologi er foretrukket om mulig. For eksempel, hjem, sykehjem, eller skadested.">
				>
				["at0045"] = <
					text = <"Destinasjon">
					description = <"Stedet/organisasjonen pasienten dro til etter den kliniske kontakten.">
				>
				["at0046"] = <
					text = <"Klinisk kontakt ID">
					description = <"En identifikator for den kliniske kontakten.">
				>
				["at0047"] = <
					text = <"Destinasjonskategori">
					description = <"Typen sted pasienten dro til etter kliniske kontakten.">
					comment = <"Koding av destinasjonskategori med en terminologi er foretrukket om mulig. For eksempel, hjem, sykehjem, eller annen helseinstitusjon.">
				>
				["at0048"] = <
					text = <"Ytterligere detaljer">
					description = <"Ytterligere detaljer om den kliniske kontakten.">
				>
			>
		>
	>
