archetype (adl_version=1.4; uid=b851a462-7ac1-40d3-ab72-fa1007861ea5)
	openEHR-EHR-CLUSTER.catheter_cuff.v0

concept
	[at0000]	-- Catheter cuff/balloon
language
	original_language = <[ISO_639-1::en]>
	translations = <
		["nb"] = <
			language = <[ISO_639-1::nb]>
			author = <
				["name"] = <"">
			>
		>
	>
description
	original_author = <
		["name"] = <"Heather Leslie">
		["organisation"] = <"Atomica Informatics">
		["email"] = <"heather.leslie@atomicainformatics.com">
		["date"] = <"2021-05-04">
	>
	details = <
		["nb"] = <
			language = <[ISO_639-1::nb]>
			purpose = <"For å registrere fysiske og funksjonelle egenskaper til en oppblåsbar mansjett eller ballong på et kateter eller tubulært medisinsk utstyr.">
			use = <"Brukes for å registrere detaljer om en oppblåsbar mansjett eller ballongkomponent av et kateter eller lignende utstyr. Denne arketypen er designet for å brukes i CLUSTER.device_catheter-arketypen eller lignende arketyper for utstyrsegenskaper.

Vanlige eksempler inkluderer endotrakealtubemansjetter, urinkateterballonger og trakeostomitubemansjetter.">
			misuse = <"Skal ikke brukes for utstyr uten oppblåsbare mansjetter eller ballonger beregnet på å feste enheten.

Skal ikke brukes til å dokumentere innsettingsutstyr, oppblåsingsprosedyrer eller prosedyretrinn; bruk ACTION.procedure i stedet.">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record the physical and functional properties of an inflatable cuff or balloon on a catheter or tubular medical device.">
			use = <"Use to record details about an inflatable cuff or balloon component of a catheter or similar device. This archetype is designed to be nested within the CLUSTER.device_catheter archetype or similar device property archetypes.

Common examples include endotracheal tube cuffs, urinary catheter balloons, and tracheostomy tube cuffs.">
			misuse = <"Not to be used for devices without inflatable cuffs or balloons intended to fixate the device.

Not to be used to document insertion equipment, inflation procedures, or procedural steps; use ACTION.procedure instead.">
		>
	>
	lifecycle_state = <"in_development">
	other_contributors = <>
	other_details = <
		["licence"] = <"This work is licensed under the Creative Commons Attribution-ShareAlike 4.0 International License. To view a copy of this license, visit http://creativecommons.org/licenses/by-sa/4.0/.">
		["custodian_organisation"] = <"openEHR Foundation">
		["original_namespace"] = <"org.openehr">
		["original_publisher"] = <"openEHR Foundation">
		["custodian_namespace"] = <"org.openehr">
		["MD5-CAM-1.0.1"] = <"87D4B132E2DCED763929D166CFA34B21">
		["build_uid"] = <"003e47c4-607a-4fee-abe5-310e869c4f2c">
		["revision"] = <"0.0.1-alpha">
	>

definition
	CLUSTER[at0000] matches {    -- Catheter cuff/balloon
		items cardinality matches {1..*; unordered} matches {
			ELEMENT[at0030] occurrences matches {0..1} matches {    -- Cuff type
				value matches {
					DV_CODED_TEXT matches {
						defining_code matches {
							[local::
							at0031,    -- High pressure/low volume (HPLV)
							at0032]    -- Low pressure/high volume (LPHV)
						}
					}
				}
			}
			ELEMENT[at0033] occurrences matches {0..1} matches {    -- Cuff position
				value matches {
					DV_CODED_TEXT matches {
						defining_code matches {
							[local::
							at0034,    -- Proximal
							at0035]    -- Distal
						}
					}
				}
			}
			ELEMENT[at0036] occurrences matches {0..1} matches {    -- Cuff capacity
				value matches {
					C_DV_QUANTITY <
						property = <[openehr::129]>
						list = <
							["1"] = <
								units = <"ml">
								magnitude = <|>=0.0|>
							>
						>
					>
				}
			}
			ELEMENT[at0037] occurrences matches {0..1} matches {    -- Inflation pressure range
				value matches {
					DV_TEXT matches {*}
				}
			}
		}
	}


ontology
	term_definitions = <
		["en"] = <
			items = <
				["at0000"] = <
					text = <"Catheter cuff/balloon">
					description = <"Details about an inflatable cuff or balloon on a catheter or tubular medical device.">
				>
				["at0030"] = <
					text = <"Cuff type">
					description = <"The classification of the cuff based on pressure and volume characteristics.">
				>
				["at0031"] = <
					text = <"High pressure/low volume (HPLV)">
					description = <"A high-pressure, low-volume cuff design.">
				>
				["at0032"] = <
					text = <"Low pressure/high volume (LPHV)">
					description = <"A low-pressure, high-volume cuff design.">
				>
				["at0033"] = <
					text = <"Cuff position">
					description = <"The anatomical position of the cuff on the device.">
				>
				["at0034"] = <
					text = <"Proximal">
					description = <"The cuff is located near the insertion end of the device.">
				>
				["at0035"] = <
					text = <"Distal">
					description = <"The cuff is located away from the insertion end of the device.">
				>
				["at0036"] = <
					text = <"Cuff capacity">
					description = <"The volume of air or fluid required to fully inflate the cuff.">
				>
				["at0037"] = <
					text = <"Inflation pressure range">
					description = <"The recommended pressure range for cuff inflation.">
					comment = <"For example: '20-30 cmH₂O'.">
				>
			>
		>
		["nb"] = <
			items = <
				["at0000"] = <
					text = <"Kateter mansjett/ballong">
					description = <"Detaljer om en oppblåsbar mansjett eller ballong på et kateter eller tubulært medisinsk utstyr.">
				>
				["at0030"] = <
					text = <"Mansjetttype">
					description = <"Klassifiseringen av mansjetten basert på trykk- og volumkarakteristika.">
				>
				["at0031"] = <
					text = <"Høyt trykk/lavt volum (HPLV)">
					description = <"En høyttrykk, lavvolum mansjettdesign.">
				>
				["at0032"] = <
					text = <"Lavt trykk/høyt volum (LPHV)">
					description = <"En lavttrykk, høytvolum mansjettdesign.">
				>
				["at0033"] = <
					text = <"Mansjettposisjon">
					description = <"Den anatomiske posisjonen på mansjetten på enheten.">
				>
				["at0034"] = <
					text = <"Proksimal">
					description = <"Mansjetten er plassert nær innsettelsesenden av enheten.">
				>
				["at0035"] = <
					text = <"Distal">
					description = <"Mansjetten er plassert bort fra innsettelsesenden av enheten.">
				>
				["at0036"] = <
					text = <"Mansjettkapasitet">
					description = <"Volumet av luft eller væske som kreves for fullstendig oppblåsing av mansjetten.">
				>
				["at0037"] = <
					text = <"Oppblåsingstrykksområde">
					description = <"Det anbefalte trykksområde for oppblåsing av mansjett.">
					comment = <"For eksempel '20-30 cmH₂O'.">
				>
			>
		>
	>
