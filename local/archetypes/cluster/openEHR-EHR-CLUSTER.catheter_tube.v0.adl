definition
	CLUSTER[at0000] matches {    -- Catheter tube
		items cardinality matches {1..*; unordered} matches {
			ELEMENT[at0038] occurrences matches {0..1} matches {    -- Tip
				value matches {
					DV_TEXT matches {*}
				}
			}
			ELEMENT[at0001] occurrences matches {0..1} matches {    -- Material
				value matches {
					DV_CODED_TEXT matches {
						defining_code matches {
							[local::
							at0002,    -- Silicone
							at0003,    -- Latex
							at0004,    -- Polyurethane
							at0006,    -- PVC
							at0039,    -- Polyethylene (PE)
							at0040,    -- Polypropylene (PP)
							at0041,    -- Polytetrafluoroethylene (PTFE)
							at0042]    -- Nylon/Polyamide
						}
					}
				}
			}
			ELEMENT[at0008] occurrences matches {0..1} matches {    -- Overall length
				value matches {
					C_DV_QUANTITY <
						property = <[openehr::122]>
						list = <
							["1"] = <
								units = <"cm">
								magnitude = <|>=0.0|>
							>
						>
					>
				}
			}
			ELEMENT[at0009] occurrences matches {0..1} matches {    -- External diameter
				value matches {
					C_DV_QUANTITY <
						property = <[openehr::122]>
						list = <
							["1"] = <
								units = <"mm">
								magnitude = <|>=0.0|>
							>
							["2"] = <
								units = <"[Ch]">
								magnitude = <|>=0.0|>
								precision = <|0|>
							>
						>
					>
				}
			}
			ELEMENT[at0044] occurrences matches {0..1} matches {    -- Number of lumens
				value matches {
					DV_COUNT matches {
						magnitude matches {|>=1|}
					}
				}
			}
			ELEMENT[at0010] occurrences matches {0..1} matches {    -- Radiopaque
				value matches {
					DV_BOOLEAN matches {*}
				}
			}
			allow_archetype CLUSTER[at0011] occurrences matches {0..*} matches {    -- Additional details
				include
					archetype_id/value matches {/openEHR-EHR-CLUSTER\.[a-zA-Z0-9_]+(-[a-zA-Z0-9_]+)*\.v[0-9]+/}
			}
		}
	}


