archetype (adl_version=1.4; uid=7263a9fc-7841-41c1-936a-7758b8e54ae6)
	openEHR-EHR-CLUSTER.catheter_tube.v0

concept
	[at0000]	-- Catheter tube
language
	original_language = <[ISO_639-1::en]>
	translations = <
		["nb"] = <
			language = <[ISO_639-1::nb]>
			author = <
				["name"] = <"">
			>
		>
	>
description
	original_author = <
		["name"] = <"Heather Leslie">
		["organisation"] = <"Atomica Informatics">
		["email"] = <"heather.leslie@atomicainformatics.com">
		["date"] = <"2021-05-04">
	>
	details = <
		["nb"] = <
			language = <[ISO_639-1::nb]>
			purpose = <"For å registrere fysiske og funksjonelle egenskaper ved fleksibelt tubulært medisinsk utstyr som settes inn gjennom kroppsåpninger eller i kroppshulrom, inkludert katetere, tuber, dren og kanyler.">
			use = <"Brukes for å registrere generelle egenskaper ved fleksibelt tubulært medisinsk utstyr, enten det brukes intermitterende eller er liggende på plass, som endotrakealtuber, trakeostomituber, urinkatetere, arteriekatetere, sentralvenøse katetere, thoraxdren, sårdren og ernæringstuber.

Lumenspesifikke detaljer, inkludert intern diameter, registreres i CLUSTER.catheter_lumen.

Denne arketypen er designet for å brukes i SLOTet 'Egenskaper' i CLUSTER.device-arketypen.">
			misuse = <"Skal ikke brukes til å registrere tidspunktet for innsetting eller fjerning av enheten; bruk ACTION.procedure i stedet.
			
Skal ikke brukes til å dokumentere innsettingsteknikker, prosedyretrinn, innsettingsutstyr (for eksempel punkteringsnåler, obturatorer) eller andre innsettingsrelaterte detaljer; bruk ACTION.procedure for disse i stedet.">
		>
		["en"] = <
			language = <[ISO_639-1::en]>
			purpose = <"To record the physical and functional properties of flexible tubular medical devices inserted into body orifices or cavities, including catheters, tubes, drains and cannulas.">
			use = <"Use to record general properties of a flexible tubular medical device, whether used intermittently or left in place, such as endotracheal tubes, tracheostomy tubes, urinary catheters, arterial lines, central venous catheters, chest tubes, wound drains and feeding tubes.

Lumen-specific details, including internal diameter, are recorded in CLUSTER.catheter_lumen.

This archetype is designed to be nested within the 'Properties' SLOT of the CLUSTER.device archetype.">
			misuse = <"Not to be used to record the timing of insertion or removal of the device; use ACTION.procedure instead.
			
Not to be used to document insertion techniques, procedural steps, insertion equipment (e.g. puncture needles, obturators), or other insertion-related details; use ACTION.procedure for these instead.">
		>
	>
	lifecycle_state = <"in_development">
	other_contributors = <>
